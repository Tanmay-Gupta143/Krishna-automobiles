      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&family=Instrument+Sans:wght@400;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --crimson: #DC143C;\n    --accent-red: #FF0000;\n    --deep-gray: #050505;\n    --surface: #0A0A0A;\n    --canvas: #000000;\n    --alabaster: #E5E4E2;\n    --secondary-gray: #999999;\n    --border-dark: #1F1F1F;\n    --white: #FFFFFF;\n  }\n\n  body {\n    background-color: var(--canvas);\n    color: var(--white);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-display { font-family: 'Instrument Sans', sans-serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .grid-pattern {\n    background-image: linear-gradient(var(--border-dark) 1px, transparent 1px),\n                      linear-gradient(90deg, var(--border-dark) 1px, transparent 1px);\n    background-size: 80px 80px;\n  }\n\n  .brutalist-card {\n    border: 1px solid var(--border-dark);\n  }\n  .brutalist-card:hover {\n    box-shadow: 12px 12px 0 var(--accent-red);\n    transform: translate(-4px, -4px);\n    background-color: #0f0f0f;\n  }\n\n  @keyframes marquee {\n    from { transform: translateX(0); }\n    to { transform: translateX(-50%); }\n  }\n\n  .industrial-corner::after {\n    content: '';\n    position: absolute;\n    top: 0;\n    right: 0;\n    width: 20px;\n    height: 20px;\n    border-top: 2px solid var(--accent-red);\n    border-right: 2px solid var(--accent-red);\n  }\n\n  .text-stroke {\n    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.2);\n    color: transparent;\n  }\n\n  .tech-line {\n    background: repeating-linear-gradient(90deg, var(--border-dark), var(--border-dark) 1px, transparent 1px, transparent 10px);\n  }\n\n  /* Lenis smooth scrolling support */\n  html.lenis {\n    height: auto;\n  }\n  .lenis.lenis-smooth {\n    scroll-behavior: auto !important;\n  }\n  .lenis.lenis-smooth [data-lenis-prevent] {\n    overscroll-behavior: contain;\n  }\n  .lenis.lenis-stopped {\n    overflow: hidden;\n  }\n</style>\n\n<div class=\"fixed top-8 left-1/2 -translate-x-1/2 z-[100] opacity-0 pointer-events-none\" data-kid=\"1\" id=\"magnetic-dock-container\">\n<div class=\"flex items-center gap-6 p-4 bg-black/80 backdrop-blur-2xl border border-white/10 rounded-full shadow-2xl\" data-kid=\"1-1\">\n<div class=\"pr-6 border-r border-white/10 flex items-center\" data-kid=\"1-1-1\">\n<div class=\"w-8 h-8 bg-[var(--accent-red)] rounded-full flex items-center justify-center font-bold text-xs italic\" data-kid=\"1-1-1-1\">K</div>\n</div>\n<div class=\"flex gap-4\" data-kid=\"1-1-2\">\n<a class=\"text-[10px] font-mono font-bold uppercase tracking-widest text-white/40 hover:text-white transition-colors\" data-kid=\"1-1-2-1\" href=\"#hero\">Home</a>\n<a class=\"text-[10px] font-mono font-bold uppercase tracking-widest text-white/40 hover:text-white transition-colors\" data-kid=\"1-1-2-2\" href=\"#services\">Matrix</a>\n<a class=\"text-[10px] font-mono font-bold uppercase tracking-widest text-white/40 hover:text-white transition-colors\" data-kid=\"1-1-2-3\" href=\"#about\">Legacy</a>\n<a class=\"text-[10px] font-mono font-bold uppercase tracking-widest text-white/40 hover:text-white transition-colors\" data-kid=\"1-1-2-4\" href=\"#testimonials\">Words</a>\n</div>\n<button class=\"bg-white text-black text-[10px] font-mono font-black uppercase tracking-widest px-6 py-2 rounded-full hover:bg-[var(--accent-red)] hover:text-white transition-all\" data-kid=\"1-1-3\">\n      Quick Call\n    </button>\n</div>\n</div>\n<main data-kid=\"2\" id=\"main-content\">\n\n<section class=\"relative min-h-screen flex flex-col justify-end px-6 md:px-12 pb-24 md:pb-40 bg-black overflow-hidden border