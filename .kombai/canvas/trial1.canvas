    "var_10ebfacaf8b1": {
      "type": "variant",
      "label": "Home Page - Final",
      "parentId": "var_875d06dcbd37",
      "rect": {
        "x": 11954,
        "y": 253,
        "w": 1440,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css');\n\n  :root {\n    --color-background: #000000;\n    --color-surface: #0a0a0a;\n    --color-primary: #ffffff;\n    --color-secondary: #999999;\n    --color-accent: #ff0000;\n    --color-border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    background-color: var(--color-background);\n    color: var(--color-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .text-huge {\n    font-size: clamp(3.5rem, 10vw, 7rem);\n    letter-spacing: -0.04em;\n    line-height: 0.9;\n  }\n\n  .label-upper {\n    text-transform: uppercase;\n    letter-spacing: 0.15em;\n    font-size: 0.75rem;\n    font-weight: 600;\n  }\n\n  .grid-structure {\n    border-left: 1px solid var(--color-border);\n    border-right: 1px solid var(--color-border);\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .animate-marquee {\n    animation: marquee 40s linear infinite;\n  }\n\n  .hover-trigger:hover .hover-target {\n    transform: translateY(-5px);\n  }\n\n  .red-dot {\n    width: 6px;\n    height: 6px;\n    background-color: var(--color-accent);\n    border-radius: 9999px;\n    display: inline-block;\n  }\n</style>\n\n<div class=\"min-h-screen flex flex-col selection:bg-red-600 selection:text-white\" data-kid=\"1\">\n  \n  <header class=\"fixed top-0 w-full z-50 bg-black/80 backdrop-blur-xl border-b border-white/10\" data-kid=\"2\">\n    <nav class=\"max-w-[1440px] mx-auto px-6 md:px-12 h-20 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-4\" data-kid=\"4\">\n        <img src=\"/api/local/images/frontend/public/krishna-logo.png\" alt=\"Krishna Automobile\" class=\"h-10 w-auto\" decoding=\"async\" loading=\"lazy\" data-kid=\"5\">\n        <div class=\"hidden sm:block\" data-kid=\"6\">\n          <span class=\"block text-sm font-bold tracking-tighter uppercase leading-none\" data-kid=\"7\">Krishna</span>\n          <span class=\"block text-[10px] label-upper text-white/40 mt-1\" data-kid=\"8\">Automobile</span>\n        </div>\n      </div>\n      \n      <div class=\"hidden lg:flex items-center gap-10\" data-kid=\"9\">\n        <a href=\"#\" class=\"label-upper hover:text-red-600 transition-colors\" data-kid=\"10\">Home</a>\n        <a href=\"#\" class=\"label-upper text-white/50 hover:text-white transition-colors\" data-kid=\"11\">Services</a>\n        <a href=\"#\" class=\"label-upper text-white/50 hover:text-white transition-colors\" data-kid=\"12\">Insurance</a>\n        <a href=\"#\" class=\"label-upper text-white/50 hover:text-white transition-colors\" data-kid=\"13\">About</a>\n        <a href=\"#\" class=\"label-upper text-white/50 hover:text-white transition-colors\" data-kid=\"14\">Contact</a>\n      </div>\n\n      <button class=\"bg-white text-black px-6 py-2.5 rounded-full text-[11px] font-bold uppercase tracking-widest hover:bg-red-600 hover:text-white transition-all duration-300 shadow-xl shadow-white/5\" data-kid=\"15\">\n        Book Now\n      </button>\n    </nav>\n  </header>\n\n  \n  <section class=\"pt-40 pb-20 px-6 md:px-12 max-w-[1440px] mx-auto w-full relative\" data-kid=\"16\">\n    <div class=\"absolute top-40 right-12 opacity-10 pointer-events-none hidden xl:block\" data-kid=\"17\">\n      <span class=\"text-[20rem] font-black tracking-tighter select-none leading-none\" data-kid=\"18\">09</span>\n    </div>\n\n    <div class=\"relative z-10\" data-kid=\"19\">\n      <div class=\"flex items-center gap-4 mb-8 gsap-hero-reveal\" data-kid=\"20\">\n        <span class=\"text-red-600 font-bold text-xl\" data-kid=\"21\">01</span>\n        <div class=\"h-[1px] w-20 bg-white/20\" data-kid=\"22\"></div>\n        <span class=\"label-upper text-white/40\" data-kid=\"23\">Since 2009 • Mira Road East</span>\n      </div>\n\n      <h1 class=\"text-huge font-bold uppercase max-w-6xl gsap-hero-reveal\" data-kid=\"24\">\n        Krishna <br data-kid=\"25\">\n        <span class=\"text-red-600\" data-kid=\"26\">Automobile</span><br data-kid=\"27\">\n        Trusted Servicing.\n      </h1>\n\n      <div class=\"mt-16 max-w-4xl gsap-hero-reveal\" data-kid=\"28\">\n        <p class=\"text-2xl md:text-3xl text-white/70 font-light leading-tight mb-16\" data-kid=\"29\">\n          Expert bike and scooter servicing, engine diagnostics, oil change, brake repair, clutch work, battery replacement, and complete maintenance for all major brands.\n        </p>\n        \n        <div class=\"flex flex-wrap gap-6\" data-kid=\"30\">\n          <a href=\"tel:09322245569\" class=\"group flex items-center gap-6 bg-white text-black pl-10 pr-2 py-2 rounded-full hover:bg-red-600 hover:text-white transition-all duration-500\" data-kid=\"31\">\n            <span class=\"text-sm font-black uppercase tracking-widest pl-2\" data-kid=\"32\">Call Primary 093222 45569</span>\n            <div class=\"w-12 h-12 rounded-full bg-black/5 flex items-center justify-center group-hover:bg-white/10 transition-colors\" data-kid=\"33\">\n              <i class=\"ri-phone-fill text-xl\" data-kid=\"34\"></i>\n            </div>\n          </a>\n          <a href=\"#\" class=\"group flex items-center gap-6 bg-red-600 text-white pl-10 pr-2 py-2 rounded-full hover:bg-white hover:text-black transition-all duration-500\" data-kid=\"35\">\n            <span class=\"text-sm font-black uppercase tracking-widest\" data-kid=\"36\">Chat on WhatsApp</span>\n            <div class=\"w-12 h-12 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-black/5 transition-colors\" data-kid=\"37\">\n              <i class=\"ri-whatsapp-line text-xl\" data-kid=\"38\"></i>\n            </div>\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"border-y border-white/5 py-8 overflow-hidden bg-white/[0.02]\" data-kid=\"39\">\n    <div class=\"flex whitespace-nowrap gap-16 animate-marquee\" data-kid=\"40\">\n      <div class=\"flex gap-16 items-center\" data-kid=\"41\">\n        <span class=\"label-upper text-white/30\" data-kid=\"42\">Honda Activa</span> <div class=\"red-dot\" data-kid=\"43\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"44\">TVS</span> <div class=\"red-dot\" data-kid=\"45\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"46\">Suzuki</span> <div class=\"red-dot\" data-kid=\"47\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"48\">Yamaha</span> <div class=\"red-dot\" data-kid=\"49\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"50\">Hero</span> <div class=\"red-dot\" data-kid=\"51\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"52\">Bajaj</span> <div class=\"red-dot\" data-kid=\"53\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"54\">Royal Enfield</span> <div class=\"red-dot\" data-kid=\"55\"></div>\n      </div>\n      <div class=\"flex gap-16 items-center\" data-kid=\"56\">\n        <span class=\"label-upper text-white/30\" data-kid=\"57\">Honda Activa</span> <div class=\"red-dot\" data-kid=\"58\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"59\">TVS</span> <div class=\"red-dot\" data-kid=\"60\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"61\">Suzuki</span> <div class=\"red-dot\" data-kid=\"62\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"63\">Yamaha</span> <div class=\"red-dot\" data-kid=\"64\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"65\">Hero</span> <div class=\"red-dot\" data-kid=\"66\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"67\">Bajaj</span> <div class=\"red-dot\" data-kid=\"68\"></div>\n        <span class=\"label-upper text-white/30\" data-kid=\"69\">Royal Enfield</span> <div class=\"red-dot\" data-kid=\"70\"></div>\n      </div>\n    </div>\n  </div>\n\n  \n  <section class=\"py-32 px-6 md:px-12 max-w-[1440px] mx-auto w-full border-b border-white/5\" data-kid=\"71\">\n    <div class=\"flex items-center gap-4 mb-16\" data-kid=\"72\">\n      <span class=\"text-red-600 font-bold text-xl\" data-kid=\"73\">02</span>\n      <div class=\"h-[1px] w-20 bg-white/20\" data-kid=\"74\"></div>\n      <span class=\"label-upper text-white/40\" data-kid=\"75\">Walk-in Policy & Focus</span>\n    </div>\n\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24\" data-kid=\"76\">\n      <div class=\"lg:col-span-5\" data-kid=\"77\">\n        <h2 class=\"text-6xl md:text-7xl font-bold uppercase tracking-tighter leading-[0.85] mb-12 gsap-reveal\" data-kid=\"78\">\n          No Appointments <br data-kid=\"79\"> <span class=\"text-red-600\" data-kid=\"80\">Required.</span>\n        </h2>\n        <p class=\"text-2xl text-white/60 font-light leading-tight mb-12 gsap-reveal\" data-kid=\"81\">\n          We understand that vehicle issues don't follow a schedule. Bring your bike, and we'll take it from there.\n        </p>\n        <div class=\"flex items-center gap-6 gsap-reveal\" data-kid=\"82\">\n          <div class=\"p-6 border border-white/10 flex flex-col items-center justify-center min-w-[140px]\" data-kid=\"83\">\n            <span class=\"text-4xl font-black\" data-kid=\"84\">15+</span>\n            <span class=\"text-[10px] label-upper text-white/40 mt-2\" data-kid=\"85\">Years Exp</span>\n          </div>\n          <div class=\"p-6 border border-white/10 flex flex-col items-center justify-center min-w-[140px]\" data-kid=\"86\">\n            <span class=\"text-4xl font-black\" data-kid=\"87\">7/7</span>\n            <span class=\"text-[10px] label-upper text-white/40 mt-2\" data-kid=\"88\">Open Daily</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"lg:col-span-7 flex flex-col lg:border-l lg:border-white/5 lg:pl-12\" data-kid=\"89\">\n        <div class=\"gsap-reveal group py-12 border-t border-white/5 hover:bg-white/[0.02] transition-colors duration-300 px-4\" data-kid=\"90\">\n          <div class=\"flex items-start gap-12\" data-kid=\"91\">\n            <span class=\"text-5xl font-black text-white/10 group-hover:text-red-600 transition-colors duration-300\" data-kid=\"92\">01</span>\n            <div data-kid=\"93\">\n              <h3 class=\"text-2xl font-bold uppercase tracking-tight mb-4\" data-kid=\"94\">Reliable Service</h3>\n              <p class=\"text-white/40 text-lg leading-relaxed max-w-xl\" data-kid=\"95\">Commitment to excellence in every nut and bolt. We don't just repair; we restore with factory-grade precision.</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"gsap-reveal group py-10 border-t border-white/5 hover:bg-white/[0.02] transition-colors duration-300 px-4\" data-kid=\"96\">\n          <div class=\"flex items-start gap-12\" data-kid=\"97\">\n            <span class=\"text-5xl font-black text-white/10 group-hover:text-red-600 transition-colors duration-300\" data-kid=\"98\">02</span>\n            <div data-kid=\"99\">\n              <h3 class=\"text-2xl font-bold uppercase tracking-tight mb-4\" data-kid=\"100\">Transparent Work</h3>\n              <p class=\"text-white/40 text-lg leading-relaxed max-w-xl\" data-kid=\"101\">No hidden charges. Clear diagnostics and honest pricing. You see what we fix, every single time.</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"gsap-reveal group py-10 border-t border-white/5 hover:bg-white/[0.02] transition-colors duration-300 px-4\" data-kid=\"102\">\n          <div class=\"flex items-start gap-12\" data-kid=\"103\">\n            <span class=\"text-5xl font-black text-white/10 group-hover:text-red-600 transition-colors duration-300\" data-kid=\"104\">03</span>\n            <div data-kid=\"105\">\n              <h3 class=\"text-2xl font-bold uppercase tracking-tight mb-4\" data-kid=\"106\">Genuine Parts</h3>\n              <p class=\"text-white/40 text-lg leading-relaxed max-w-xl\" data-kid=\"107\">We only stock high-quality, authentic spares to ensure your vehicle's safety and long-term performance.</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"gsap-reveal group py-10 border-t border-b border-white/5 hover:bg-white/[0.02] transition-colors duration-300 px-4\" data-kid=\"108\">\n          <div class=\"flex items-start gap-12\" data-kid=\"109\">\n            <span class=\"text-5xl font-black text-white/10 group-hover:text-red-600 transition-colors duration-300\" data-kid=\"110\">04</span>\n            <div data-kid=\"111\">\n              <h3 class=\"text-2xl font-bold uppercase tracking-tight mb-4\" data-kid=\"112\">Legacy Trust</h3>\n              <p class=\"text-white/40 text-lg leading-relaxed max-w-xl\" data-kid=\"113\">A customer-first approach that has kept us running as Mira Road's favorite servicing hub since 2009.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"mt-auto border-t border-white/10 pt-24 pb-12 px-6 md:px-12 bg-surface\" data-kid=\"114\">\n    <div class=\"max-w-[1440px] mx-auto\" data-kid=\"115\">\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-24\" data-kid=\"116\">\n        <div data-kid=\"117\">\n          <div class=\"flex items-center gap-3 mb-8\" data-kid=\"118\">\n            <img src=\"/api/local/images/frontend/public/krishna-logo.png\" alt=\"Logo\" class=\"h-12 w-auto filter grayscale invert\" decoding=\"async\" loading=\"lazy\" data-kid=\"119\">\n            <span class=\"text-xl font-black uppercase tracking-tighter\" data-kid=\"120\">Krishna</span>\n          </div>\n          <p class=\"text-white/40 text-sm leading-relaxed max-w-xs\" data-kid=\"121\">\n            Keeping Mira Road moving since 2009. Expert mechanics, genuine parts, and a commitment to your safety on the road.\n          </p>\n        </div>\n\n        <div data-kid=\"122\">\n          <h4 class=\"label-upper text-red-600 mb-8\" data-kid=\"123\">Contact Us</h4>\n          <div class=\"space-y-6\" data-kid=\"124\">\n            <div data-kid=\"125\">\n              <span class=\"block text-[10px] label-upper text-white/30 mb-2\" data-kid=\"126\">Direct Line</span>\n              <a href=\"tel:09322245569\" class=\"text-xl font-bold hover:text-red-600 transition-colors tracking-tight\" data-kid=\"127\">093222 45569</a>\n            </div>\n            <div data-kid=\"128\">\n              <span class=\"block text-[10px] label-upper text-white/30 mb-2\" data-kid=\"129\">Secondary</span>\n              <a href=\"tel:09082744210\" class=\"text-lg font-medium text-white/60\" data-kid=\"130\">090827 44210</a>\n            </div>\n          </div>\n        </div>\n\n        <div data-kid=\"131\">\n          <h4 class=\"label-upper text-red-600 mb-8\" data-kid=\"132\">Operation Hours</h4>\n          <div class=\"space-y-4\" data-kid=\"133\">\n            <div class=\"flex justify-between items-center text-sm\" data-kid=\"134\">\n              <span class=\"text-white/40\" data-kid=\"135\">Mon — Sun</span>\n              <span class=\"font-bold\" data-kid=\"136\">9:00 AM – 9:30 PM</span>\n            </div>\n            <div class=\"pt-4 border-t border-white/5\" data-kid=\"137\">\n              <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/10 text-green-500 text-[10px] font-bold uppercase tracking-widest\" data-kid=\"138\">\n                <span class=\"w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse\" data-kid=\"139\"></span>\n                Workshop Open\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div data-kid=\"140\">\n          <h4 class=\"label-upper text-red-600 mb-8\" data-kid=\"141\">Location</h4>\n          <p class=\"text-sm text-white/40 leading-relaxed\" data-kid=\"142\">\n            Shop No.11, Gaurav Sankalp Chintan 11, Hatkesh, Mira Road East, Thane, Maharashtra 401107, IN.\n          </p>\n          <div class=\"mt-6 flex gap-4\" data-kid=\"143\">\n             <i class=\"ri-facebook-box-line text-xl text-white/20 hover:text-white transition-colors cursor-pointer\" data-kid=\"144\"></i>\n             <i class=\"ri-instagram-line text-xl text-white/20 hover:text-white transition-colors cursor-pointer\" data-kid=\"145\"></i>\n             <i class=\"ri-google-line text-xl text-white/20 hover:text-white transition-colors cursor-pointer\" data-kid=\"146\"></i>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"147\">\n        <div class=\"text-[10px] label-upper text-white/20\" data-kid=\"148\">\n          © 2024 Krishna Automobiles • Digital Brutalism v1.0\n        </div>\n        <div class=\"flex gap-10\" data-kid=\"149\">\n          <a href=\"#\" class=\"text-[10px] label-upper text-white/40 hover:text-red-600 transition-colors\" data-kid=\"150\">Privacy</a>\n          <a href=\"#\" class=\"text-[10px] label-upper text-white/40 hover:text-red-600 transition-colors\" data-kid=\"151\">Terms</a>\n          <a href=\"#\" class=\"text-[10px] label-upper text-white/40 hover:text-red-600 transition-colors\" data-kid=\"152\">Cookies</a>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"153\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"154\"></script>\n<script data-kid=\"155\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Reveal\n  gsap.from(\".gsap-hero-reveal\", {\n    y: 100,\n    opacity: 0,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power4.out\"\n  });\n\n  // Section Reveal with batching for multiple triggers\n  const revealElements = document.querySelectorAll(\".gsap-reveal\");\n  revealElements.forEach((el) => {\n    gsap.from(el, {\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 85%\",\n        toggleActions: \"play none none none\"\n      },\n      y: 30,\n      opacity: 0,\n      duration: 1,\n      ease: \"power2.out\"\n    });\n  });\n</script>\n",
