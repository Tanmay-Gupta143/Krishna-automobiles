      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css');\n\n  :root {\n    --background: #000000;\n    --surface: #0a0a0a;\n    --primary: #ffffff;\n    --secondary: #999999;\n    --accent: #ff0000;\n    --border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    background-color: var(--background);\n    color: var(--primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .text-huge {\n    font-size: clamp(4rem, 12vw, 10rem);\n    line-height: 0.8;\n    letter-spacing: -0.06em;\n  }\n\n  .label-upper {\n    text-transform: uppercase;\n    letter-spacing: 0.2em;\n    font-size: 0.7rem;\n    font-weight: 700;\n    color: var(--secondary);\n  }\n\n  .grid-bg {\n    background-image: linear-gradient(var(--border) 1px, transparent 1px),\n      linear-gradient(90deg, var(--border) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .animate-marquee {\n    animation: marquee 40s linear infinite;\n  }\n\n  .tech-line {\n    background: repeating-linear-gradient(90deg, var(--border), var(--border) 1px, transparent 1px, transparent 10px);\n  }\n\n  .brutal-border {\n    border: 1px solid var(--border);\n  }\n\n  .section-index {\n    font-size: clamp(8rem, 20vw, 24rem);\n    line-height: 1;\n    font-weight: 900;\n    color: rgba(255, 255, 255, 0.03);\n    pointer-events: none;\n    z-index: 0;\n  }\n\n  .insurance-glow {\n    box-shadow: 0 0 80px rgba(255, 0, 0, 0.1);\n  }\n\n  .no-scroll {\n    overflow-x: clip;\n  }\n</style>\n\n<div class=\"no-scroll\" data-kid=\"1\">\n  \n  <header class=\"fixed top-0 w-full z-50 bg-black/80 backdrop-blur-xl border-b border-white/10\" data-kid=\"2\">\n    <nav class=\"max-w-[1440px] mx-auto px-8 md:px-12 h-20 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-4\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-red-600 rounded-sm flex items-center justify-center font-black italic\" data-kid=\"5\">K</div>\n        <div data-kid=\"6\">\n          <span class=\"block text-sm font-black uppercase tracking-tighter leading-none\" data-kid=\"7\">Krishna</span>\n          <span class=\"block text-[9px] label-upper mt-1 opacity-50\" data-kid=\"8\">Automobile</span>\n        </div>\n      </div>\n      \n      <div class=\"hidden lg:flex items-center gap-10\" data-kid=\"9\">\n        <a href=\"#home\" class=\"label-upper text-white hover:text-red-600 transition-colors\" data-kid=\"10\">Home</a>\n        <a href=\"#services\" class=\"label-upper hover:text-white transition-colors\" data-kid=\"11\">Services</a>\n        <a href=\"#insurance\" class=\"label-upper hover:text-white transition-colors\" data-kid=\"12\">Insurance</a>\n        <a href=\"#about\" class=\"label-upper hover:text-white transition-colors\" data-kid=\"13\">About</a>\n        <a href=\"#contact\" class=\"label-upper hover:text-white transition-colors\" data-kid=\"14\">Contact</a>\n      </div>\n\n      <a href=\"tel:09322245569\" class=\"bg-white text-black px-8 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest hover:bg-red-600 hover:text-white transition-all shadow-xl shadow-white/5\" data-kid=\"15\">\n        Book Service\n      </a>\n    </nav>\n  </header>\n\n  <main data-kid=\"16\">\n    \n    <section id=\"home\" class=\"relative pt-48 pb-32 px-8 md:px-12 max-w-[1440px] mx-auto grid-bg\" data-kid=\"17\">\n      <div class=\"absolute top-48 right-12 section-index\" data-kid=\"18\">01</div>\n      \n      <div class=\"relative z-10\" data-kid=\"19\">\n        <div class=\"flex items-center gap-4 mb-10\" data-kid=\"20\">\n          <span class=\"text-red-600 font-black text-2xl\" data-kid=\"21\">01</span>\n          <div class=\"h-px w-24 bg-red-600\" data-kid=\"22\"></div>\n          <span class=\"label-upper\" data-kid=\"23\">Trusted Servicing Since 2009</span>\n        </div>\n\n        <h1 class=\"text-huge font-black uppercase max-w-6xl reveal-item leading-[0.75]\" data-kid=\"24\">\n          Krishna <br data-kid=\"25\">\n          <span class=\"text-red-600\" data-kid=\"26\">Automobile</span><br data-kid=\"27\">\n          <span class=\"text-white/90\" data-kid=\"28\">Master Precision.</span>\n        </h1>\n\n        <div class=\"mt-20 max-w-4xl\" data-kid=\"29\">\n          <p class=\"text-2xl md:text-3xl text-white/60 font-light leading-tight mb-16 reveal-item\" data-kid=\"30\">\n            Expert bike and scooter servicing, engine diagnostics, oil change, and precision maintenance for all major brands.\n          </p>\n          \n          <div class=\"flex flex-wrap gap-6 reveal-item\" data-kid=\"31\">\n            <a href=\"tel:09322245569\" class=\"group flex items-center gap-6 bg-white text-black px-8 py-4 rounded-full hover:bg-red-600 hover:text-white transition-all duration-500\" data-kid=\"32\">\n              <span class=\"text-xs font-black uppercase tracking-widest\" data-kid=\"33\">Primary: 093222 45569</span>\n              <i class=\"ri-phone-fill text-xl\" data-kid=\"34\"></i>\n            </a>\n            <a href=\"#\" class=\"group flex items-center gap-6 border border-white/20 px-8 py-4 rounded-full hover:bg-white hover:text-black transition-all duration-500\" data-kid=\"35\">\n              <span class=\"text-xs font-black uppercase tracking-widest\" data-kid=\"36\">WhatsApp Support</span>\n              <i class=\"ri-whatsapp-line text-xl\" data-kid=\"37\"></i>\n            </a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <div class=\"border-y border-white/10 py-20 bg-white/[0.01] overflow-hidden\" data-kid=\"38\">\n      <div class=\"flex whitespace-nowrap gap-16 animate-marquee\" data-kid=\"39\">\n        <div class=\"flex gap-16 items-center\" data-kid=\"40\">\n          <span class=\"label-upper\" data-kid=\"41\">Honda Activa</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"42\"></div>\n          <span class=\"label-upper\" data-kid=\"43\">TVS</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"44\"></div>\n          <span class=\"label-upper\" data-kid=\"45\">Suzuki</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"46\"></div>\n          <span class=\"label-upper\" data-kid=\"47\">Yamaha</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"48\"></div>\n          <span class=\"label-upper\" data-kid=\"49\">Hero</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"50\"></div>\n          <span class=\"label-upper\" data-kid=\"51\">Royal Enfield</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"52\"></div>\n        </div>\n        <div class=\"flex gap-16 items-center\" data-kid=\"53\">\n          <span class=\"label-upper\" data-kid=\"54\">Honda Activa</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"55\"></div>\n          <span class=\"label-upper\" data-kid=\"56\">TVS</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"57\"></div>\n          <span class=\"label-upper\" data-kid=\"58\">Suzuki</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"59\"></div>\n          <span class=\"label-upper\" data-kid=\"60\">Yamaha</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"61\"></div>\n          <span class=\"label-upper\" data-kid=\"62\">Hero</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"63\"></div>\n          <span class=\"label-upper\" data-kid=\"64\">Royal Enfield</span> <div class=\"w-1.5 h-1.5 bg-red-600 rounded-full\" data-kid=\"65\"></div>\n        </div>\n      </div>\n    </div>\n\n    \n    <section class=\"py-40 px-8 md:px-12 max-w-[1440px] mx-auto border-b border-white/5 relative\" data-kid=\"66\">\n      <div class=\"absolute top-32 right-12 section-index\" data-kid=\"67\">02</div>\n      <div class=\"flex items-center gap-4 mb-20 relative z-10\" data-kid=\"68\">\n        <span class=\"text-red-600 font-black text-2xl\" data-kid=\"69\">02</span>\n        <div class=\"h-px w-24 bg-red-600\" data-kid=\"70\"></div>\n        <span class=\"label-upper\" data-kid=\"71\">Operational Strategy</span>\n      </div>\n\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-24 relative z-10\" data-kid=\"72\">\n        <div class=\"lg:col-span-6\" data-kid=\"73\">\n          <h2 class=\"text-7xl font-black uppercase leading-[0.85] mb-12\" data-kid=\"74\">No Appointments <br data-kid=\"75\"> <span class=\"text-red-600\" data-kid=\"76\">Required.</span></h2>\n          <p class=\"text-2xl text-white/40 font-light leading-tight mb-16\" data-kid=\"77\">\n            We understand vehicle emergencies. Bring your machine directly to our workshop — we prioritize your road safety.\n          </p>\n          <div class=\"flex gap-8\" data-kid=\"78\">\n            <div class=\"p-8 brutal-border bg-surface flex flex-col items-center min-w-[160px]\" data-kid=\"79\">\n              <span class=\"text-5xl font-black text-red-600\" data-kid=\"80\">15+</span>\n              <span class=\"label-upper mt-3 opacity-50\" data-kid=\"81\">Years Legacy</span>\n            </div>\n            <div class=\"p-8 brutal-border bg-surface flex flex-col items-center min-w-[160px]\" data-kid=\"82\">\n              <span class=\"text-5xl font-black\" data-kid=\"83\">7/7</span>\n              <span class=\"label-upper mt-3 opacity-50\" data-kid=\"84\">Open Daily</span>\n            </div>\n          </div>\n        </div>\n        <div class=\"lg:col-span-6 space-y-1\" data-kid=\"85\">\n          <div class=\"p-10 brutal-border bg-surface hover:bg-white/[0.02] transition-colors group\" data-kid=\"86\">\n            <div class=\"flex gap-10\" data-kid=\"87\">\n              <span class=\"text-4xl font-black text-white/5 group-hover:text-red-600/30 transition-colors\" data-kid=\"88\">01</span>\n              <div data-kid=\"89\">\n                <h3 class=\"text-2xl font-bold uppercase mb-4 tracking-tighter\" data-kid=\"90\">Reliable Service</h3>\n                <p class=\"text-white/40 leading-relaxed\" data-kid=\"91\">Precision restoration for every component. We use factory-grade standards for all repairs.</p>\n              </div>\n            </div>\n          </div>\n          <div class=\"p-10 brutal-border bg-surface hover:bg-white/[0.02] transition-colors group\" data-kid=\"92\">\n            <div class=\"flex gap-10\" data-kid=\"93\">\n              <span class=\"text-4xl font-black text-white/5 group-hover:text-red-600/30 transition-colors\" data-kid=\"94\">02</span>\n              <div data-kid=\"95\">\n                <h3 class=\"text-2xl font-bold uppercase mb-4 tracking-tighter\" data-kid=\"96\">Transparent Work</h3>\n                <p class=\"text-white/40 leading-relaxed\" data-kid=\"97\">No hidden costs. Clear diagnostics and honest pricing on all spares and labor.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"services\" class=\"py-40 px-8 md:px-12 max-w-[1440px] mx-auto border-b border-white/5 relative\" data-kid=\"98\">\n      <div class=\"absolute top-32 right-12 section-index\" data-kid=\"99\">03</div>\n      <div class=\"flex items-center gap-4 mb-20 relative z-10\" data-kid=\"100\">\n        <span class=\"text-red-600 font-black text-2xl\" data-kid=\"101\">03</span>\n        <div class=\"h-px w-24 bg-red-600\" data-kid=\"102\"></div>\n        <span class=\"label-upper\" data-kid=\"103\">Precision Maintenance Matrix</span>\n      </div>\n\n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-px bg-white/10 border border-white/10 relative z-10\" data-kid=\"104\">\n        <div class=\"bg-surface p-12 lg:p-20 group relative overflow-hidden\" data-kid=\"105\">\n          <span class=\"absolute top-8 right-8 text-8xl font-black text-white/5 group-hover:text-red-600/20 transition-colors\" data-kid=\"106\">01</span>\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"107\">\n            <span class=\"text-red-600 font-mono text-3xl font-black\" data-kid=\"108\">₹150</span>\n            <div class=\"h-px w-12 bg-red-600/30\" data-kid=\"109\"></div>\n          </div>\n          <h3 class=\"text-5xl font-black uppercase mb-8 leading-none\" data-kid=\"110\">Industrial <br data-kid=\"111\">Battery Charging</h3>\n          <p class=\"text-white/40 text-lg mb-12 max-w-md\" data-kid=\"112\">Systematic power restoration using industrial-grade chargers to maximize cell longevity and starting strength.</p>\n          <button class=\"bg-white text-black px-10 py-4 rounded-full font-black uppercase tracking-widest text-[10px] hover:bg-red-600 hover:text-white transition-all\" data-kid=\"113\">Execute Service</button>\n        </div>\n        <div class=\"bg-surface p-12 lg:p-20 group relative overflow-hidden\" data-kid=\"114\">\n          <span class=\"absolute top-8 right-8 text-8xl font-black text-white/5 group-hover:text-red-600/20 transition-colors\" data-kid=\"115\">02</span>\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"116\">\n            <span class=\"text-red-600 font-mono text-3xl font-black\" data-kid=\"117\">₹200</span>\n            <div class=\"h-px w-12 bg-red-600/30\" data-kid=\"118\"></div>\n          </div>\n          <h3 class=\"text-5xl font-black uppercase mb-8 leading-none\" data-kid=\"119\">Brake / Safety <br data-kid=\"120\">Calibrated Repair</h3>\n          <p class=\"text-white/40 text-lg mb-12 max-w-md\" data-kid=\"121\">Pad replacement, fluid inspection, and disc remediation protocols for critical safety assurance.</p>\n          <button class=\"bg-white text-black px-10 py-4 rounded-full font-black uppercase tracking-widest text-[10