      "html": "\n<div class=\"bg-[#000000] text-[#E6E6E6] font-['Geist'] selection:bg-[#E6E6E6] selection:text-[#000000] min-h-screen\" data-kid=\"0\">\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n    <style data-kid=\"2\">\n        @import url('https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400&family=Geist:wght@400;600&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n        :root {\n            --ground: #000000;\n            --on-ground: #E6E6E6;\n            --on-ground-muted: #757575;\n            --hairline: #1F1F1F;\n            --hairline-strong: #2A2A2A;\n            --surface-raised: #161616;\n            --surface-chip: #2E2E2E;\n            --wordmark: #CCCCCC;\n        }\n\n        .tracking-tight-custom { letter-spacing: -0.04em; }\n        .leading-tight-custom { line-height: 0.9em; }\n        \n        /* Grid Lines */\n        .grid-line-v { width: 1px; background-color: var(--hairline); height: 100%; position: absolute; top: 0; }\n        .grid-line-h { height: 1px; background-color: var(--hairline); width: 100%; position: absolute; left: 0; }\n\n        .service-card::after {\n            content: '';\n            position: absolute;\n            inset: 0;\n            border: 1px solid transparent;\n            transition: border-color 0.4s cubic-bezier(0.65, 0, 0.35, 1);\n            pointer-events: none;\n        }\n        .service-card:hover::after {\n            border-color: var(--on-ground);\n        }\n\n        /* Custom Scrollbar */\n        ::-webkit-scrollbar { width: 4px; }\n        ::-webkit-scrollbar-track { background: var(--ground); }\n        ::-webkit-scrollbar-thumb { background: var(--hairline-strong); }\n\n        .geist-mono { font-family: 'Geist Mono', monospace; }\n\n        /* GSAP specific: No CSS transitions on animated elements */\n        .animate-gsap { transition: none !important; }\n\n        details summary::-webkit-details-marker { display: none; }\n        details summary { list-style: none; }\n        \n        details[open] .faq-icon { transform: rotate(45deg); }\n        .faq-icon { transition: transform 0.4s cubic-bezier(0.65, 0, 0.35, 1); }\n    </style>\n\n    \n    <nav class=\"fixed top-0 left-0 w-full z-[100] px-8 py-6 flex justify-between items-center border-b border-[#1F1F1F] bg-black/80 backdrop-blur-md\" data-kid=\"3\">\n        <div class=\"flex items-center gap-3\" data-kid=\"4\">\n            <div class=\"w-6 h-6 bg-white flex items-center justify-center\" data-kid=\"5\">\n                <i class=\"ti ti-settings-filled text-black text-sm\" data-kid=\"6\"></i>\n            </div>\n            <div class=\"flex flex-col\" data-kid=\"7\">\n                <span class=\"text-[10px] font-bold uppercase tracking-tight leading-none\" data-kid=\"8\">Krishna.</span>\n                <span class=\"geist-mono text-[8px] text-[#757575] leading-none mt-1\" data-kid=\"9\">EST. 2009</span>\n            </div>\n        </div>\n        <div class=\"hidden md:flex gap-12 text-[12px] font-semibold uppercase tracking-tight\" data-kid=\"10\">\n            <a href=\"#services\" class=\"hover:text-white transition-colors\" data-kid=\"11\">Services</a>\n            <a href=\"#components\" class=\"hover:text-white transition-colors\" data-kid=\"12\">Components</a>\n            <a href=\"#trusted\" class=\"hover:text-white transition-colors\" data-kid=\"13\">Brands</a>\n            <a href=\"#faq\" class=\"hover:text-white transition-colors\" data-kid=\"14\">FAQ</a>\n        </div>\n        <div class=\"flex items-center gap-6\" data-kid=\"15\">\n            <a href=\"tel:+910000000000\" class=\"text-[12px] font-semibold uppercase border border-[#E6E6E6] px-5 py-2 hover:bg-[#E6E6E6] hover:text-black transition-colors\" data-kid=\"16\">Book Now</a>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative min-h-screen flex flex-col justify-end p-8 pb-16 overflow-hidden\" data-kid=\"17\">\n        <div class=\"absolute inset-0 z-0\" data-kid=\"18\">\n            <video src=\"https://videos.pexels.com/video-files/30355025/13011391_640_360_60fps.mp4\" poster=\"https://images.pexels.com/videos/30355025/pexels-photo-30355025.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover grayscale opacity-30\" data-kid=\"19\"></video>\n            <div class=\"absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent\" data-kid=\"20\"></div>\n        </div>\n        \n        <div class=\"relative z-10 w-full\" data-kid=\"21\">\n            <div class=\"mb-8 overflow-hidden\" data-kid=\"22\">\n                <p class=\"hero-eyebrow text-[#757575] text-2xl font-semibold tracking-tight-custom translate-y-full\" data-kid=\"23\">Technical Precision.</p>\n            </div>\n            <h1 class=\"hero-title text-[12vw] md:text-[180px] font-semibold tracking-tight-custom leading-[0.85em] uppercase max-w-6xl\" data-kid=\"24\">\n                Engineered <br data-kid=\"25\"> Performance.\n            </h1>\n            <div class=\"mt-12 flex flex-col md:flex-row items-start md:items-end justify-between gap-12 border-t border-[#1F1F1F] pt-8\" data-kid=\"26\">\n                <div class=\"max-w-md\" data-kid=\"27\">\n                    <p class=\"text-[#757575] text-lg leading-snug\" data-kid=\"28\">Advanced diagnostics and master repairs for modern machines. Mira Road's premier technical workshop focusing on structural integrity and performance.</p>\n                </div>\n                <div class=\"flex flex-col items-end gap-2\" data-kid=\"29\">\n                    <span class=\"geist-mono text-xs text-[#757575]\" data-kid=\"30\">LAT: 19.2813° N / LONG: 72.8752° E</span>\n                    <span class=\"geist-mono text-xs text-[#757575]\" data-kid=\"31\">SINCE 2009 — VER 4.2.1</span>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"services\" class=\"py-32 px-8 border-t border-[#1F1F1F]\" data-kid=\"32\">\n        <div class=\"mb-16\" data-kid=\"33\">\n            <span class=\"text-[#757575] text-2xl font-semibold tracking-tighter block mb-2 uppercase\" data-kid=\"34\">Capabilities</span>\n            <h2 class=\"text-4xl md:text-6xl font-semibold uppercase tracking-tighter\" data-kid=\"35\">System Operations.</h2>\n        </div>\n\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 border-l border-t border-[#1F1F1F] service-grid\" data-kid=\"36\">\n            \n            <div class=\"service-card border-r border-b border-[#1F1F1F] p-10 aspect-square flex flex-col justify-between hover:bg-[#161616] group relative overflow-hidden\" data-kid=\"37\">\n                <div class=\"flex justify-between items-start relative z-10\" data-kid=\"38\">\n                    <span class=\"geist-mono text-xs text-[#757575] group-hover:text-white\" data-kid=\"39\">01</span>\n                    <i class=\"ti ti-settings-automation text-2xl\" data-kid=\"40\"></i>\n                </div>\n                <div class=\"relative z-10\" data-kid=\"41\">\n                    <h3 class=\"text-2xl font-semibold uppercase mb-2 leading-none\" data-kid=\"42\">General <br data-kid=\"43\"> Service</h3>\n                    <p class=\"text-[#757575] text-sm\" data-kid=\"44\">Full periodic check-up and systems validation.</p>\n                </div>\n            </div>\n            <div class=\"service-card border-r border-b border-[#1F1F1F] p-10 aspect-square flex flex-col justify-between hover:bg-[#161616] group relative overflow-hidden\" data-kid=\"45\">\n                <div class=\"flex justify-between items-start relative z-10\" data-kid=\"46\">\n                    <span class=\"geist-mono text-xs text-[#757575] group-hover:text-white\" data-kid=\"47\">02</span>\n                    <i class=\"ti ti-engine text-2xl\" data-kid=\"48\"></i>\n                </div>\n                <div class=\"relative z-10\" data-kid=\"49\">\n                    <h3 class=\"text-2xl font-semibold uppercase mb-2 leading-none\" data-kid=\"50\">Engine <br data-kid=\"51\"> Restoral</h3>\n                    <p class=\"text-[#757575] text-sm\" data-kid=\"52\">Piston calibration and cylinder re-mapping.</p>\n                </div>\n            </div>\n            <div class=\"service-card border-r border-b border-[#1F1F1F] p-10 aspect-square flex flex-col justify-between hover:bg-[#161616] group relative overflow-hidden\" data-kid=\"53\">\n                <div class=\"flex justify-between items-start relative z-10\" data-kid=\"54\">\n                    <span class=\"geist-mono text-xs text-[#757575] group-hover:text-white\" data-kid=\"55\">03</span>\n                    <i class=\"ti ti-bolt text-2xl\" data-kid=\"56\"></i>\n                </div>\n                <div class=\"relative z-10\" data-kid=\"57\">\n                    <h3 class=\"text-2xl font-semibold uppercase mb-2 leading-none\" data-kid=\"58\">Electrical <br data-kid=\"59\"> Grid</h3>\n                    <p class=\"text-[#757575] text-sm\" data-kid=\"60\">Advanced wiring diagnostics and sensor repair.</p>\n                </div>\n            </div>\n            <div class=\"service-card border-r border-b border-[#1F1F1F] p-10 aspect-square flex flex-col justify-between hover:bg-[#161616] group relative overflow-hidden\" data-kid=\"61\">\n                <div class=\"flex justify-between items-start relative z-10\" data-kid=\"62\">\n                    <span class=\"geist-mono text-xs text-[#757575] group-hover:text-white\" data-kid=\"63\">04</span>\n                    <i class=\"ti ti-droplet text-2xl\" data-kid=\"64\"></i>\n                </div>\n                <div class=\"relative z-10\" data-kid=\"65\">\n                    <h3 class=\"text-2xl font-semibold uppercase mb-2 leading-none\" data-kid=\"66\">Fluid <br data-kid=\"67\"> Dynamics</h3>\n                    <p class=\"text-[#757575] text-sm\" data-kid=\"68\">Performance-grade lubrication and cooling.</p>\n                </div>\n            </div>\n            \n            <div class=\"service-card border-r border-b border-[#1F1F1F] p-10 aspect-square flex flex-col justify-between hover:bg-[#161616] group relative overflow-hidden\" data-kid=\"69\">\n                <div class=\"flex justify-between items-start relative z-10\" data-kid=\"70\">\n                    <span class=\"geist-mono text-xs text-[#757575] group-hover:text-white\" data-kid=\"71\">05</span>\n                    <i class=\"ti ti-circle-half-2 text-2xl\" data-kid=\"72\"></i>\n                </div>\n                <div class=\"relative z-10\" data-kid=\"73\">\n                    <h3 class=\"text-2xl font-semibold uppercase mb-2 leading-none\" data-kid=\"74\">Brake <br data-kid=\"75\"> Assembly</h3>\n                    <p class=\"text-[#757575] text-sm\" data-kid=\"76\">Safety-first disk and drum restoration.</p>\n                </div>\n            </div>\n            <div class=\"service-card border-r border-b border-[#1F1F1F] p-10 aspect-square flex flex-col justify-between hover:bg-[#161616] group relative overflow-hidden\" data-kid=\"77\">\n                <div class=\"flex justify-between items-start relative z-10\" data-kid=\"78\">\n                    <span class=\"geist-mono text-xs text-[#757575] group-hover:text-white\" data-kid=\"79\">06</span>\n                    <i class=\"ti ti-battery-automotive text-2xl\" data-kid=\"80\"></i>\n                </div>\n                <div class=\"relative z-10\" data-kid=\"81\">\n                    <h3 class=\"text-2xl font-semibold uppercase mb-2 leading-none\" data-kid=\"82\">Power <br data-kid=\"83\"> Cells</h3>\n                    <p class=\"text-[#757575] text-sm\" data-kid=\"84\">Battery optimization and charging cycles.</p>\n                </div>\n            </div>\n            <div class=\"service-card border-r border-b border-[#1F1F1F] p-10 aspect-square flex flex-col justify-between hover:bg-[#161616] group relative overflow-hidden\" data-kid=\"85\">\n                <div class=\"flex justify-between items-start relative z-10\" data-kid=\"86\">\n                    <span class=\"geist-mono text-xs text-[#757575] group-hover:text-white\" data-kid=\"87\">07</span>\n                    <i class=\"ti ti-microscope text-2xl\" data-kid=\"88\"></i>\n                </div>\n                <div class=\"relative z-10\" data-kid=\"89\">\n                    <h3 class=\"text-2xl font-semibold uppercase mb-2 leading-none\" data-kid=\"90\">BS6 <br data-kid=\"91\"> Scanner</h3>\n                    <p class=\"text-[#757575] text-sm\" data-kid=\"92\">Full digital diagnostics for fuel injection.</p>\n                </div>\n            </div>\n            <div class=\"service-card border-r border-b border-[#1F1F1F] p-10 aspect-square flex flex-col justify-between hover:bg-[#161616] group relative overflow-hidden\" data-kid=\"93\">\n                <div class=\"flex justify-between items-start relative z-10\" data-kid=\"94\">\n                    <span class=\"geist-mono text-xs text-[#757575] group-hover:text-white\" data-kid=\"95\">08</span>\n                    <i class=\"ti ti-truck-delivery text-2xl\" data-kid=\"96\"></i>\n                </div>\n                <div class=\"relative z-10\" data-kid=\"97\">\n                    <h3 class=\"text-2xl font-semibold uppercase mb-2 leading-none\" data-kid=\"98\">Logistic <br data-kid=\"99\"> Support</h3>\n                    <p class=\"text-[#757575] text-sm\" data-kid=\"100\">Doorstep collection for immobilised units.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"components\" class=\"py-32 px-8 bg-[#000000] border-t border-[#1F1F1F]\" data-kid=\"101\">\n        <div class=\"mb-16\" data-kid=\"102\">\n            <span class=\"text-[#757575] text-2xl font-semibold tracking-tighter block mb-2 uppercase\" data-kid=\"103\">Components</span>\n            <h2 class=\"text-4xl md:text-6xl font-semibold uppercase tracking-tighter\" data-kid=\"104\">Inventory.</h2>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-[#1F1F1F]\" data-kid=\"105\">\n            <div class=\"border-b md:border-r border-[#1F1F1F] p-8 hover:bg-[#161616] transition-all group\" data-kid=\"106\">\n                <div class=\"aspect-[4/3] bg-[#161616] mb-8 overflow-hidden grayscale\" data-kid=\"107\">\n                    <img src=\"https://images.pexels.com/photos/11536993/pexels-photo-11536993.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Engine Pistons\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"108\">\n                </div>\n                <div class=\"flex justify-between items-end\" data-kid=\"109\">\n                    <div data-kid=\"110\">\n                        <h4 class=\"text-xl font-semibold uppercase tracking-tight\" data-kid=\"111\">Forge Pistons</h4>\n                        <p class=\"geist-mono text-[10px] text-[#757575] mt-1\" data-kid=\"112\">CAT: ENG-SYS-092</p>\n                    </div>\n                    <div class=\"bg-[#2E2E2E] px-3 py-1 text-[10px] font-semibold uppercase tracking-widest\" data-kid=\"113\">In Stock</div>\n                </div>\n            </div>\n            <div class=\"border-b md:border-r border-[#1F1F1F] p-8 hover:bg-[#161616] transition-all group\" data-kid=\"114\">\n                <div class=\"aspect-[4/3] bg-[#161616] mb-8 overflow-hidden grayscale\" data-kid=\"115\">\n                    <img src=\"https://images.pexels.com/photos/29409960/pexels-photo-29409960.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Drive Components\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"116\">\n                </div>\n                <div class=\"flex justify-between items-end\" data-kid=\"117\">\n                    <div data-kid=\"118\">\n                        <h4 class=\"text-xl font-semibold uppercase tracking-tight\" data-kid=\"119\">Rolon Chains</h4>\n                        <p class=\"geist-mono text-[10px] text-[#757575] mt-1\" data-kid=\"120\">CAT: DRV-LNK-411</p>\n                    </div>\n                    <div class=\"bg-[#2E2E2E] px-3 py-1 text-[10px] font-semibold uppercase tracking-widest\" data-kid=\"121\">Genuine</div>\n                </div>\n            </div>\n            <div class=\"border-b border-[#1F1F1F] p-8 hover:bg-[#161616] transition-all group\" data-kid=\"122\">\n                <div class=\"aspect-[4/3] bg-[#161616] mb-8 overflow-hidden grayscale\" data-kid=\"123\">\n                    <img src=\"https://images.pexels.com/photos/5252118/pexels-photo-5252118.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Diagnostic Tools\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"124\">\n                </div>\n                <div class=\"flex justify-between items-end\" data-kid=\"125\">\n                    <div data-kid=\"126\">\n                        <h4 class=\"text-xl font-semibold uppercase tracking-tight\" data-kid=\"127\">OBD Scanners</h4>\n                        <p class=\"geist-mono text-[10px] text-[#757575] mt-1\" data-kid=\"128\">CAT: DGN-SYS-V3</p>\n                    </div>\n                    <div class=\"bg-[#2E2E2E] px-3 py-1 text-[10px] font-semibold uppercase tracking-widest\" data-kid=\"129\">Technical</div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"trusted\" class=\"py-32 px-8 border-t border-[#1F1F1F]\" data-kid=\"130\">\n        <div class=\"mb-16\" data-kid=\"131\">\n            <span class=\"text-[#757575] text-2xl font-semibold tracking-tighter block mb-2 uppercase\" data-kid=\"132\">Trusted By</span>\n            <h2 class=\"text-4xl md:text-6xl font-semibold uppercase tracking-tighter\" data-kid=\"133\">Manufacturer Grid.</h2>\n        </div>\n        \n        <div class=\"grid grid-cols-2 lg:grid-cols-5 border-l border-t border-[#1F1F1F]\" data-kid=\"134\">\n            <div class=\"border-r border-b border-[#1F1F1F] h-48 flex items-center justify-center grayscale opacity-40 hover:opacity-100 hover:bg-[#161616] transition-all group\" data-kid=\"135\">\n                <span class=\"text-2xl font-bold tracking-[0.2em] uppercase\" data-kid=\"136\">Honda</span>\n            </div>\n            <div class=\"border-r border-b border-[#1F1F1F] h-48 flex items-center justify-center grayscale opacity-40 hover:opacity-100 hover:bg-[#161616] transition-all group\" data-kid=\"137\">\n                <span class=\"text-2xl font-bold tracking-[0.2em] uppercase\" data-kid=\"138\">Hero</span>\n            </div>\n            <div class=\"border-r border-b border-[#1F1F1F] h-48 flex items-center justify-center grayscale opacity-40 hover:opacity-100 hover:bg-[#161616] transition-all group\" data-kid=\"139\">\n                <span class=\"text-2xl font-bold tracking-[0.2em] uppercase\" data-kid=\"140\">Bajaj</span>\n            </div>\n            <div class=\"border-r border-b border-[#1F1F1F] h-48 flex items-center justify-center grayscale opacity-40 hover:opacity-100 hover:bg-[#161616] transition-all group\" data-kid=\"141\">\n                <span class=\"text-2xl font-bold tracking-[0.2em] uppercase\" data-kid=\"142\">TVS</span>\n            </div>\n            <div class=\"border-r border-b border-[#1F1F1F] h-48 flex items-center justify-center grayscale opacity-40 hover:opacity-100 hover:bg-[#161616] transition-all group col-span-2 lg:col-span-1\" data-kid=\"143\">\n                <span class=\"text-2xl font-bold tracking-[0.2em] uppercase\" data-kid=\"144\">Enfield</span>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"faq\" class=\"py-32 px-8 border-t border-[#1F1F1F]\" data-kid=\"145\">\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row gap-24\" data-kid=\"146\">\n            <div class=\"md:w-1/3\" data-kid=\"147\">\n                <span class=\"text-[#757575] text-2xl font-semibold tracking-tighter block mb-2 uppercase\" data-kid=\"148\">FAQ</span>\n                <h2 class=\"text-4xl md:text-5xl font-semibold uppercase tracking-tighter leading-none\" data-kid=\"149\">Operations <br data-kid=\"150\"> Guide.</h2>\n            </div>\n            <div class=\"md:w-2/3 border-t border-[#1F1F1F]\" data-kid=\"151\">\n                <details class=\"border-b border-[#1F1F1F] group\" data-kid=\"152\">\n                    <summary class=\"py-10 flex justify-between items-center cursor-pointer outline-none\" data-kid=\"153\">\n                        <span class=\"text-xl md:text-2xl font-semibold uppercase tracking-tight\" data-kid=\"154\">Do you use original components?</span>\n                        <div class=\"flex items-center gap-4\" data-kid=\"155\">\n                            <span class=\"geist-mono text-[10px] text-[#757575] hidden sm:inline\" data-kid=\"156\">GENUINE</span>\n                            <i class=\"ti ti-plus faq-icon text-[#757575] text-2xl\" data-kid=\"157\"></i>\n                        </div>\n                    </summary>\n                    <div class=\"pb-10 px-0\" data-kid=\"158\">\n                        <p class=\"text-[#757575] max-w-xl text-lg\" data-kid=\"159\">We only use authorized spares directly from Honda, Hero, Bajaj, and Royal Enfield retailers. No aftermarket compromises.</p>\n                    </div>\n                </details>\n                <details class=\"border-b border-[#1F1F1F] group\" data-kid=\"160\">\n                    <summary class=\"py-10 flex justify-between items-center cursor-pointer outline-none\" data-kid=\"161\">\n                        <span class=\"text-xl md:text-2xl font-semibold uppercase tracking-tight\" data-kid=\"162\">Is diagnostic scanning available?</span>\n                        <div class=\"flex items-center gap-4\" data-kid=\"163\">\n                            <span class=\"geist-mono text-[10px] text-[#757575] hidden sm:inline\" data-kid=\"164\">BS6-SCAN</span>\n                            <i class=\"ti ti-plus faq-icon text-[#757575] text-2xl\" data-kid=\"165\"></i>\n                        </div>\n                    </summary>\n                    <div class=\"pb-10 px-0\" data-kid=\"166\">\n                        <p class=\"text-[#757575] max-w-xl text-lg\" data-kid=\"167\">Our facility is equipped with the latest OBD-II digital scanners for full BS6 performance mapping and error clearing.</p>\n                    </div>\n                </details>\n                <details class=\"border-b border-[#1F1F1F] group\" data-kid=\"168\">\n                    <summary class=\"py-10 flex justify-between items-center cursor-pointer outline-none\" data-kid=\"169\">\n                        <span class=\"text-xl md:text-2xl font-semibold uppercase tracking-tight\" data-kid=\"170\">What is the pickup range?</span>\n                        <div class=\"flex items-center gap-4\" data-kid=\"171\">\n                            <span class=\"geist-mono text-[10px] text-[#757575] hidden sm:inline\" data-kid=\"172\">MIRA-RD</span>\n                            <i class=\"ti ti-plus faq-icon text-[#757575] text-2xl\" data-kid=\"173\"></i>\n                        </div>\n                    </summary>\n                    <div class=\"pb-10 px-0\" data-kid=\"174\">\n                        <p class=\"text-[#757575] max-w-xl text-lg\" data-kid=\"175\">We provide doorstep collection services within Mira Road East and West for all immobilized machines.</p>\n                    </div>\n                </details>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"pt-48 pb-12 px-8 border-t border-[#1F1F1F]\" data-kid=\"176\">\n        <div class=\"overflow-hidden mb-24\" data-kid=\"177\">\n            <h2 class=\"footer-wordmark text-[clamp(120px,28vw,600px)] font-semibold text-[#CCCCCC] uppercase tracking-[-0.05em] leading-[0.75em] text-center select-none\" data-kid=\"178\">\n                AUTO\n            </h2>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-12 gap-16 pt-16 border-t border-[#1F1F1F]\" data-kid=\"179\">\n            <div class=\"md:col-span-5 flex flex-col justify-between\" data-kid=\"180\">\n                <div data-kid=\"181\">\n                    <div class=\"flex items-center gap-3 mb-6\" data-kid=\"182\">\n                        <div class=\"w-8 h-8 bg-white flex items-center justify-center\" data-kid=\"183\">\n                            <i class=\"ti ti-settings-filled text-black text-xl\" data-kid=\"184\"></i>\n                        </div>\n                        <span class=\"text-xl font-semibold uppercase\" data-kid=\"185\">Krishna Automobiles</span>\n                    </div>\n                    <p class=\"text-[#757575] max-w-sm text-lg leading-snug\" data-kid=\"186\">Precision mechanical services since 2009. Engineered for longevity and performance in Mira Road East.</p>\n                </div>\n                <div class=\"mt-12 md:mt-0\" data-kid=\"187\">\n                    <a href=\"https://wa.me/910000000000\" class=\"inline-flex items-center gap-4 border border-[#1F1F1F] text-[#E6E6E6] px-8 py-4 font-semibold uppercase tracking-widest text-sm hover:bg-[#E6E6E6] hover:text-black transition-all group\" data-kid=\"188\">\n                        <i class=\"ti ti-brand-whatsapp text-xl group-hover:scale-110 transition-transform\" data-kid=\"189\"></i> Initiate Contact\n                    </a>\n                </div>\n            </div>\n\n            <div class=\"md:col-span-2 space-y-4\" data-kid=\"190\">\n                <p class=\"text-[#757575] text-[10px] font-semibold uppercase tracking-widest\" data-kid=\"191\">Sitemap</p>\n                <div class=\"flex flex-col gap-2 text-sm font-semibold uppercase tracking-tight\" data-kid=\"192\">\n                    <a href=\"#services\" class=\"hover:text-white transition-colors\" data-kid=\"193\">System Ops</a>\n                    <a href=\"#components\" class=\"hover:text-white transition-colors\" data-kid=\"194\">Inventory</a>\n                    <a href=\"#trusted\" class=\"hover:text-white transition-colors\" data-kid=\"195\">Network</a>\n                    <a href=\"#faq\" class=\"hover:text-white transition-colors\" data-kid=\"196\">Guide</a>\n                </div>\n            </div>\n\n            <div class=\"md:col-span-2 space-y-4\" data-kid=\"197\">\n                <p class=\"text-[#757575] text-[10px] font-semibold uppercase tracking-widest\" data-kid=\"198\">Connect</p>\n                <div class=\"flex flex-col gap-2 text-sm font-semibold uppercase tracking-tight\" data-kid=\"199\">\n                    <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"200\">Instagram</a>\n                    <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"201\">LinkedIn</a>\n                    <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"202\">Support</a>\n                </div>\n            </div>\n\n            <div class=\"md:col-span-3 space-y-4\" data-kid=\"203\">\n                <p class=\"text-[#757575] text-[10px] font-semibold uppercase tracking-widest\" data-kid=\"204\">Facility</p>\n                <div class=\"text-sm font-semibold uppercase tracking-tight leading-relaxed\" data-kid=\"205\">\n                    Mira Road East, Thane<br data-kid=\"206\">\n                    9:00 AM — 9:30 PM<br data-kid=\"207\">\n                    Mon — Sun\n                </div>\n                <div class=\"pt-4\" data-kid=\"208\">\n                    <span class=\"geist-mono text-[10px] text-[#757575]\" data-kid=\"209\">SYS-STAT: ONLINE</span>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"mt-32 pt-12 border-t border-[#1F1F1F] flex flex-col md:flex-row justify-between items-center gap-8 text-[10px] geist-mono text-[#757575] uppercase tracking-widest\" data-kid=\"210\">\n            <div class=\"flex gap-12\" data-kid=\"211\">\n                <span data-kid=\"212\">© 2024 Krishna Automobiles</span>\n                <span class=\"hidden md:inline\" data-kid=\"213\">Mira Road Technical Hub</span>\n            </div>\n            <div class=\"flex gap-12\" data-kid=\"214\">\n                <span data-kid=\"215\">Terms of Service</span>\n                <span data-kid=\"216\">Privacy Protocol</span>\n                <span class=\"text-white\" data-kid=\"217\">Built by Basement</span>\n            </div>\n        </div>\n    </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"218\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"219\"></script>\n<script type=\"module\" data-kid=\"220\">\n    import Lenis from \"https://esm.sh/lenis@1\";\n    \n    // Smooth scroll\n    const lenis = new Lenis({\n        duration: 1.2,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n        smoothWheel: true,\n    });\n\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    // GSAP Animations\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Hero entrance\n    const tl = gsap.timeline({ defaults: { ease: \"power4.out\", duration: 1.5 } });\n    \n    tl.to(\".hero-eyebrow\", { y: 0, opacity: 1 })\n      .from(\".hero-title\", { y: 100, opacity: 0, skewY: 5 }, \"-=1.2\")\n      .from(\"nav\", { y: -100, opacity: 0 }, \"-=1\");\n\n    // Grid entrance animations\n    gsap.from(\".service-card\", {\n        scrollTrigger: {\n            trigger: \".service-grid\",\n            start: \"top 80%\",\n        },\n        y: 50,\n        opacity: 0,\n        stagger: 0.1,\n        duration: 1,\n        ease: \"power3.out\"\n    });\n\n    // Wordmark parallax\n    gsap.from(\".footer-wordmark\", {\n        scrollTrigger: {\n            trigger: \".footer-wordmark\",\n            start: \"top bottom\",\n            end: \"bottom top\",\n            scrub: 1,\n        },\n        scale: 0.8,\n        opacity: 0.05,\n    });\n</script>\n",
