      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&family=Instrument+Sans:wght@800;900&family=JetBrains+Mono:wght@400;700&display=swap');\n\n  :root {\n    --crimson: #DC143C;\n    --accent-red: #FF0000;\n    --deep-gray: #050505;\n    --surface: #0A0A0A;\n    --canvas: #000000;\n    --alabaster: #E5E4E2;\n    --secondary-gray: #999999;\n    --border-dark: #1F1F1F;\n    --white: #FFFFFF;\n  }\n\n  body {\n    background-color: var(--canvas);\n    color: var(--white);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n    overflow-x: clip;\n  }\n\n  .font-instrument { font-family: 'Instrument Sans', sans-serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .brutalist-grid {\n    background-image: linear-gradient(var(--border-dark) 1px, transparent 1px),\n      linear-gradient(90deg, var(--border-dark) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .shadow-brutalist {\n    transition: all 0.3s cubic-bezier(.2,0,0,1);\n  }\n  .shadow-brutalist:hover {\n    box-shadow: 8px 8px 0 var(--accent-red);\n    transform: translate(-2px, -2px);\n  }\n\n  .glow-red {\n    box-shadow: 0 0 50px rgba(255, 0, 0, 0.1);\n  }\n\n  .line-mask {\n    background: linear-gradient(to right, var(--accent-red), transparent);\n    height: 1px;\n    width: 100%;\n  }\n\n  /* Marquee */\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-marquee {\n    display: flex;\n    animation: marquee 40s linear infinite;\n  }\n\n  .technical-border {\n    border: 1px solid var(--border-dark);\n  }\n  .technical-border:hover {\n    border-color: var(--accent-red);\n  }\n\n  /* Scroll Progress */\n</style>\n<link data-kid=\"1\" data-name=\"lenis scroll library stylesheet link\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" rel=\"stylesheet\">\n<div class=\"fixed top-0 left-0 h-[3px] bg-[var(--accent-red)] z-[1000] w-0\" data-dynamic=\"true\" data-kid=\"2\" data-name=\"scroll progress bar\" data-reason=\"width updated by scroll progress script\" id=\"progress-bar\"></div>\n\n<nav class=\"fixed bottom-8 left-1/2 -translate-x-1/2 z-[100] bg-black/80 backdrop-blur-xl border border-[var(--border-dark)] px-8 py-4 rounded-full flex flex-row items-center gap-10 shadow-2xl\" data-kid=\"3\" data-name=\"navigation dock container\">\n<div class=\"flex items-center gap-2\" data-kid=\"3-1\" data-name=\"brand logo and name container\">\n<div class=\"w-6 h-6 bg-[var(--accent-red)]\" data-kid=\"3-1-1\" data-name=\"brand identifier square\"></div>\n<span class=\"font-instrument font-black text-sm uppercase tracking-tighter\" data-kid=\"3-1-2\" data-name=\"brand name text\">KRISHNA</span>\n</div>\n<div class=\"h-4 w-[1px] bg-[var(--border-dark)]\" data-kid=\"3-2\" data-name=\"navigation separator line\"></div>\n<div class=\"flex items-center gap-8\" data-kid=\"3-3\" data-name=\"navigation menu links container\">\n<a class=\"font-mono text-[10px] font-bold uppercase text-[var(--secondary-gray)] hover:text-[var(--accent-red)] transition-colors\" data-kid=\"3-3-1\" data-name=\"home link\" href=\"#\">01. Home</a>\n<a class=\"font-mono text-[10px] font-bold uppercase text-[var(--secondary-gray)] hover:text-[var(--accent-red)] transition-colors\" data-kid=\"3-3-2\" data-name=\"shop link\" href=\"#\">02. Shop</a>\n<a class=\"font-mono text-[10px] font-bold uppercase text-[var(--accent-red)]\" data-kid=\"3-3-3\" data-name=\"legal link\" href=\"#\">03. Legal</a>\n<a class=\"font-mono text-[10px] font-bold uppercase text-[var(--secondary-gray)] hover:text-[var(--accent-red)] transition-colors\" data-kid=\"3-3-4\" data-name=\"about link\" href=\"#\">04. About</a>\n</div>\n<div class=\"h-4 w-[1px] bg-[var(--border-dark)]\" data-kid=\"3-4\" data-name=\"navigation separator line\"></div>\n<button class=\"bg-white text-black font-mono text-[10px] font-bold px-6 py-2 rounded-full hover:bg-[var(--accent-red)] hover:text-white transition-all uppercase\" data-kid=\"3-5\" data-name=\"emergency call-to-action button\">\n    Emergency\n  </button>\n</nav>\n\n<section class=\"min-h-screen relative flex flex-col justify-center px-6 md:px-12 brutalist-grid overflow-hidden border-b border-[var(--border-dark)]\" data-kid=\"4\" data-name=\"hero section container\">\n<div class=\"absolute inset-0 bg-gradient-to-b from-transparent via-black/40 to-black pointer-events-none\" data-kid=\"4-1\" data-name=\"hero background gradient overlay\"></div>\n<div class=\"max-w-7xl mx-auto w-full relative z-10 pt-20\" data-kid=\"4-2\" data-name=\"hero content wrapper\">\n<div class=\"flex items-center gap-4 mb-12 translate-y-reveal\" data-kid=\"4-2-1\" data-name=\"hero sub-header status group\">\n<div class=\"w-16 h-[2px] bg-[var(--accent-red)]\" data-kid=\"4-2-1-1\" data-name=\"status decorator bar\"></div>\n<span class=\"font-mono text-[11px] font-bold tracking-[0.3em] uppercase text-[var(--accent-red)]\" data-kid=\"4-2-1-2\" data-name=\"operational status text\">Operational Status: Direct Claims Hub Active</span>\n</div>\n<h1 class=\"font-instrument text-[clamp(64px,12vw,140px)] leading-[0.9] font-black uppercase tracking-[-0.06em] mb-16 staggered-reveal\" data-kid=\"4-2-2\" data-name=\"hero main headline\">\n      Insurance <br data-kid=\"4-2-2-1\" data-name=\"headline line break\">\n<span class=\"text-[var(--secondary-gray)]\" data-kid=\"4-2-2-2\" data-name=\"headline hollow text\" style=\"-webkit-text-stroke: 1px var(--white); opacity: 0.6;\">&amp; Legal</span><br data-kid=\"4-2-2-3\" data-name=\"headline line break\">\n<span class=\"text-[var(--accent-red)]\" data-kid=\"4-2-2-4\" data-name=\"headline red text\">Management</span>\n</h1>\n<div class=\"grid grid-cols-12 gap-12 items-end staggered-reveal\" data-kid=\"4-2-3\" data-name=\"hero secondary content grid\">\n<div class=\"col-span-12 lg:col-span-6\" data-kid=\"4-2-3-1\" data-name=\"hero descriptive text wrapper\">\n<p class=\"font-instrument text-3xl font-bold text-[var(--secondary-gray)] leading-tight max-w-xl\" data-kid=\"4-2-3-1-1\" data-name=\"hero descriptive text\">\n          Surgical precision in administrative protocols. We manage the paper trail so you focus on the road.\n        </p>\n</div>\n<div class=\"col-span-12 lg:col-span-6 flex lg:justify-end\" data-kid=\"4-2-3-2\" data-name=\"hero info card container\">\n<div class=\"p-8 bg-[var(--surface)] border border-[var(--border-dark)] shadow-brutalist relative group\" data-kid=\"4-2-3-2-1\" data-name=\"hero info card\">\n<div class=\"absolute -top-4 -left-4 w-8 h-8 border-t-2 border-l-2 border-[var(--accent-red)]\" data-kid=\"4-2-3-2-1-1\" data-name=\"card corner decorative bracket\"></div>\n<span class=\"font-mono text-[10px] text-[var(--accent-red)] block mb-4\" data-kid=\"4-2-3-2-1-2\" data-name=\"card label text\">PROTOCOL_INDEX: HUB_ACTIVE</span>\n<div class=\"flex items-center gap-6\" data-kid=\"4-2-3-2-1-3\" data-name=\"card content container\">\n<div class=\"w-12 h-12 flex items-center justify-center border border-[var(--accent-red)] text-[var(--accent-red)]\" data-kid=\"4-2-3-2-1-3-1\" data-name=\"card icon wrapper\">\n<svg class=\"w-6 h-6\" data-kid=\"4-2-3-2-1-3-1-1\" data-name=\"heart shield icon\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04M12 21.355r.01-.011c3.43-1.93 5.732-5.122 5.732-8.773 0-1.78-.474-3.453-1.305-4.897L12 11.332l-4.427-3.647A11.97 11.97 0 006.268 12.582c0 3.651 2.302 6.843 5.732 8.773z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" data-kid=\"10\"></path></svg>\n</div>\n<div data-kid=\"4-2-3-2-1-3-2\" data-name=\"card text wrapper\">\n<h4 class=\"font-instrument font-black text-xl uppercase tracking-tighter\" data-kid=\"4-2-3-2-1-3-2-1\" data-name=\"card title text\">Krishna Claims Hub</h4>\n<p class=\"text-xs font-mono text-[var(--secondary-gray)] uppercase 