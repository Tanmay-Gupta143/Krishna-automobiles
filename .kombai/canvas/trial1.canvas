an class=\"text-red-600\" data-kid=\"258\">Out.</span></h2>\n          <div class=\"space-y-16\" data-kid=\"259\">\n            <div data-kid=\"260\">\n              <span class=\"label-upper block mb-6\" data-kid=\"261\">Workstation Coordinate</span>\n              <p class=\"text-2xl font-bold leading-tight\" data-kid=\"262\">Shop No.11, Gaurav sankalp chintan 11, hatkesh, Mira Road East, Thane 401107</p>\n            </div>\n            <div class=\"grid grid-cols-2 gap-10\" data-kid=\"263\">\n              <div data-kid=\"264\">\n                <span class=\"label-upper block mb-4\" data-kid=\"265\">Direct Line</span>\n                <p class=\"text-3xl font-black hover:text-red-600 transition-colors\" data-kid=\"266\">093222 45569</p>\n              </div>\n              <div data-kid=\"267\">\n                <span class=\"label-upper block mb-4\" data-kid=\"268\">Uptime</span>\n                <p class=\"text-2xl font-black text-red-600\" data-kid=\"269\">09:00 - 21:30</p>\n              </div>\n            </div>\n            <div class=\"p-8 bg-red-600/5 border-l-4 border-red-600 rounded-r-xl\" data-kid=\"270\">\n              <span class=\"label-upper !text-red-600 block mb-4\" data-kid=\"271\">Financial Notice</span>\n              <p class=\"text-sm font-bold leading-relaxed uppercase opacity-80 italic\" data-kid=\"272\">Payment Protocol: Cash, Tez & GPay accepted. Credit/Debit cards strictly NOT accepted.</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"lg:col-span-7 bg-surface brutal-border p-12 md:p-16 rounded-xl relative\" data-kid=\"273\">\n          <div class=\"flex justify-between items-start mb-12\" data-kid=\"274\">\n            <div data-kid=\"275\">\n              <h3 class=\"text-4xl font-black uppercase italic mb-2 tracking-tighter\" data-kid=\"276\">Contact Form</h3>\n              <p class=\"label-upper !text-[9px] opacity-50\" data-kid=\"277\">Digital Dispatch System v5.4</p>\n            </div>\n            <div class=\"w-12 h-12 brutal-border rounded-lg flex items-center justify-center text-red-600\" data-kid=\"278\">\n              <i class=\"ri-mail-send-line text-2xl\" data-kid=\"279\"></i>\n            </div>\n          </div>\n          <form class=\"space-y-10\" data-kid=\"280\">\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-10\" data-kid=\"281\">\n              <div class=\"border-b border-white/10 pb-4 focus-within:border-red-600 transition-colors\" data-kid=\"282\">\n                <label class=\"label-upper !text-[9px] block mb-2\" data-kid=\"283\">Operator Name</label>\n                <input type=\"text\" placeholder=\"Full Name\" class=\"bg-transparent w-full outline-none text-xl font-bold placeholder:text-white/40\" data-kid=\"284\">\n              </div>\n              <div class=\"border-b border-white/10 pb-4 focus-within:border-red-600 transition-colors\" data-kid=\"285\">\n                <label class=\"label-upper !text-[9px] block mb-2\" data-kid=\"286\">Secure Link (Phone)</label>\n                <input type=\"tel\" placeholder=\"+91\" class=\"bg-transparent w-full outline-none text-xl font-bold placeholder:text-white/40\" data-kid=\"287\">\n              </div>\n            </div>\n            <div class=\"border-b border-white/10 pb-4 focus-within:border-red-600 transition-colors\" data-kid=\"288\">\n              <label class=\"label-upper !text-[9px] block mb-2\" data-kid=\"289\">Vehicle Specification</label>\n              <input type=\"text\" placeholder=\"e.g. Honda Activa 6G / Royal Enfield\" class=\"bg-transparent w-full outline-none text-xl font-bold placeholder:text-white/40\" data-kid=\"290\">\n            </div>\n            <div class=\"border-b border-white/10 pb-4 focus-within:border-red-600 transition-colors\" data-kid=\"291\">\n              <label class=\"label-upper !text-[9px] block mb-2\" data-kid=\"292\">Service Requirements</label>\n              <textarea placeholder=\"Describe technical issues...\" rows=\"3\" class=\"bg-transparent w-full outline-none text-xl font-bold placeholder:text-white/40 resize-none\" data-kid=\"293\"></textarea>\n            </div>\n            <button class=\"w-full bg-white text-black py-6 rounded-full font-black uppercase tracking-[0.3em] text-xs hover:bg-red-600 hover:text-white transition-all\" data-kid=\"294\">\n              Submit Secure Dispatch\n            </button>\n          </form>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  \n  <footer class=\"bg-surface border-t border-white/10 py-24 px-8 md:px-12 mt-20\" data-kid=\"295\">\n    <div class=\"max-w-[1440px] mx-auto\" data-kid=\"296\">\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-20 mb-20\" data-kid=\"297\">\n        <div class=\"lg:col-span-1\" data-kid=\"298\">\n          <div class=\"flex items-center gap-4 mb-10\" data-kid=\"299\">\n            <div class=\"w-10 h-10 bg-red-600 rounded-sm flex items-center justify-center font-black italic\" data-kid=\"300\">K</div>\n            <span class=\"text-xl font-black uppercase tracking-tighter\" data-kid=\"301\">Krishna Automobile</span>\n          </div>\n          <p class=\"text-white/40 text-sm leading-relaxed mb-10\" data-kid=\"302\">\n            Mira Road East's most trusted repair shop since 2009. Precision servicing for all major brands and insurance management.\n          </p>\n          <div class=\"flex gap-4\" data-kid=\"303\">\n            <a href=\"#\" class=\"w-10 h-10 brutal-border rounded-full flex items-center justify-center hover:border-red-600 transition-colors\" data-kid=\"304\"><i class=\"ri-whatsapp-line\" data-kid=\"305\"></i></a>\n            <a href=\"#\" class=\"w-10 h-10 brutal-border rounded-full flex items-center justify-center hover:border-red-600 transition-colors\" data-kid=\"306\"><i class=\"ri-instagram-line\" data-kid=\"307\"></i></a>\n            <a href=\"#\" class=\"w-10 h-10 brutal-border rounded-full flex items-center justify-center hover:border-red-600 transition-colors\" data-kid=\"308\"><i class=\"ri-facebook-fill\" data-kid=\"309\"></i></a>\n          </div>\n        </div>\n        \n        <div data-kid=\"310\">\n          <h4 class=\"label-upper !text-white mb-10\" data-kid=\"311\">Navigation</h4>\n          <ul class=\"space-y-4\" data-kid=\"312\">\n            <li data-kid=\"313\"><a href=\"#home\" class=\"text-sm text-white/40 hover:text-red-600 transition-colors\" data-kid=\"314\">Base Foundation</a></li>\n            <li data-kid=\"315\"><a href=\"#services\" class=\"text-sm text-white/40 hover:text-red-600 transition-colors\" data-kid=\"316\">Service Protocols</a></li>\n            <li data-kid=\"317\"><a href=\"#insurance\" class=\"text-sm text-white/40 hover:text-red-600 transition-colors\" data-kid=\"318\">Insurance Management</a></li>\n            <li data-kid=\"319\"><a href=\"#about\" class=\"text-sm text-white/40 hover:text-red-600 transition-colors\" data-kid=\"320\">Legacy Profile</a></li>\n          </ul>\n        </div>\n\n        <div data-kid=\"321\">\n          <h4 class=\"label-upper !text-white mb-10\" data-kid=\"322\">Operation</h4>\n          <ul class=\"space-y-4 text-sm text-white/40\" data-kid=\"323\">\n            <li class=\"flex justify-between border-b border-white/5 pb-2\" data-kid=\"324\">\n              <span data-kid=\"325\">Mon — Sun</span>\n              <span class=\"text-white font-bold\" data-kid=\"326\">09:00 - 21:30</span>\n            </li>\n            <li class=\"pt-2 text-[10px] label-upper !text-red-600 font-black italic\" data-kid=\"327\">Walk-ins Encouraged</li>\n            <li class=\"text-[10px] label-upper opacity-30 italic leading-relaxed\" data-kid=\"328\">System Status: OPERATIONAL_OK</li>\n          </ul>\n        </div>\n\n        <div data-kid=\"329\">\n          <h4 class=\"label-upper !text-white mb-10\" data-kid=\"330\">Compliance</h4>\n          <ul class=\"space-y-4 text-[10px] label-upper opacity-50 font-black italic\" data-kid=\"331\">\n            <li data-kid=\"332\">Secure Claims Handling</li>\n            <li data-kid=\"333\">Safe Space Certified</li>\n            <li data-kid=\"334\">Free Legal Consultation</li>\n            <li data-kid=\"335\">OEM Parts Integration</li>\n          </ul>\n        </div>\n      </div>\n\n      <div class=\"pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"336\">\n        <div class=\"text-[9px] label-upper opacity-30\" data-kid=\"337\">\n          © 2024 Krishna Automobiles • Mira Road East Hub • v5.4.0\n        </div>\n        <div class=\"flex gap-8 text-[9px] label-upper opacity-40\" data-kid=\"338\">\n          <a href=\"#\" class=\"hover:text-red-600 transition-colors\" data-kid=\"339\">Privacy Protocol</a>\n          <a href=\"#\" class=\"hover:text-red-600 transition-colors\" data-kid=\"340\">Terms of Service</a>\n          <a href=\"#\" class=\"hover:text-red-600 transition-colors\" data-kid=\"341\">Digital Cookies</a>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"342\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"343\"></script>\n<script data-kid=\"344\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Smooth scroll and entrance reveal\n  window.addEventListener('load', () => {\n    // Reveal main items\n    gsap.from(\".reveal-item\", {\n      y: 80,\n      opacity: 0,\n      duration: 1.5,\n      stagger: 0.25,\n      ease: \"power4.out\"\n    });\n\n    // Parallax Section Indices\n    gsap.utils.toArray(\".section-index\").forEach(el => {\n      gsap.to(el, {\n        scrollTrigger: {\n          trigger: el,\n          start: \"top bottom\",\n          end: \"bottom top\",\n          scrub: 1\n        },\n        y: -100,\n        opacity: 0.1,\n        ease: \"none\"\n      });\n    });\n\n    // Reveal containers\n    gsap.utils.toArray(\".brutal-border, .bg-surface\").forEach(el => {\n      gsap.from(el, {\n        scrollTrigger: {\n          trigger: el,\n          start: \"top 95%\",\n          toggleActions: \"play none none none\"\n        },\n        y: 40,\n        opacity: 0,\n        duration: 1,\n        ease: \"power2.out\"\n      });\n    });\n  });\n\n  // Nav scroll behavior\n  const nav = document.querySelector('header');\n  window.addEventListener('scroll', () => {\n    if (window.scrollY > 50) {\n      nav.classList.add('py-2', 'bg-black/95');\n      nav.classList.remove('py-0');\n    } else {\n      nav.classList.remove('py-2', 'bg-black/95');\n      nav.classList.add('py-0');\n    }\n  });\n</script>\n",
      "comments": [],
      "created": "2026-07-05T02:17:56.942910+00:00",
