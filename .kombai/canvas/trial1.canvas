      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Instrument+Sans:wght@400;700;800;900&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n    @import url('https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css');\n\n    :root {\n        --k-color-accent: #ff0000;\n        --k-color-bg-page: #000000;\n        --k-color-bg-surface: #0a0a0a;\n        --k-color-text-primary: #ffffff;\n    }\n\n    body {\n        background-color: var(--k-color-bg-page);\n        color: var(--k-color-text-primary);\n        font-family: 'Inter', sans-serif;\n        margin: 0;\n        overflow-x: hidden;\n        -webkit-font-smoothing: antialiased;\n        width: 100%;\n    }\n\n    h1, h2, h3, h4 { font-family: 'Instrument Sans', sans-serif; }\n\n    #magnetic-dock-container {\n        position: fixed;\n        top: 2rem;\n        left: 50%;\n        transform: translateX(-50%) translateY(-150%);\n        z-index: 1000;\n        opacity: 0;\n        pointer-events: auto;\n    }\n\n    .dock-wrapper {\n        display: flex;\n        align-items: center;\n        gap: 1.5rem;\n        padding: 1rem 1.5rem;\n        background: rgba(15, 15, 15, 0.7);\n        backdrop-filter: blur(24px) saturate(200%);\n        border: 1px solid rgba(255, 255, 255, 0.15);\n        border-radius: 2.5rem;\n        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.8);\n    }\n\n    .dock-item {\n        position: relative;\n        width: 56px;\n        height: 56px;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        border-radius: 1.25rem;\n        background: linear-gradient(180deg, rgba(40, 40, 40, 0.8) 0%, rgba(10, 10, 10, 0.9) 100%);\n        border: 1px solid rgba(255, 255, 255, 0.1);\n        color: white;\n        cursor: pointer;\n        transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n    }\n\n    .dock-item:hover {\n        background: linear-gradient(180deg, var(--k-color-accent) 0%, #b30000 100%);\n    }\n\n    .dock-tooltip {\n        position: absolute;\n        top: calc(100% + 15px);\n        left: 50%;\n        transform: translateX(-50%);\n        background: rgba(0,0,0,0.95);\n        color: white;\n        padding: 6px 12px;\n        border-radius: 8px;\n        font-size: 11px;\n        opacity: 0;\n        pointer-events: none;\n        transition: all 0.2s;\n    }\n\n    .dock-item:hover .dock-tooltip {\n        opacity: 1;\n        transform: translateX(-50%) translateY(5px);\n    }\n\n    .brand-marquee {\n        display: flex;\n        overflow: hidden;\n        user-select: none;\n        gap: 2rem;\n        mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);\n    }\n\n    .brand-track {\n        display: flex;\n        gap: 4rem;\n        animation: scroll 40s linear infinite;\n        white-space: nowrap;\n    }\n\n    @keyframes scroll {\n        from { transform: translateX(0); }\n        to { transform: translateX(-50%); }\n    }\n\n    .brand-item {\n        text-shadow: 0 0 20px rgba(255, 255, 255, 0.05);\n    }\n\n    .price-tag {\n        background: rgba(255, 0, 0, 0.1);\n        color: var(--k-color-accent);\n        padding: 4px 12px;\n        border-radius: 8px;\n        font-size: 13px;\n        font-weight: 800;\n        border: 1px solid rgba(255,0,0,0.2);\n    }\n\n    .service-card {\n        background: linear-gradient(145deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.05) 100%);\n        backdrop-blur: 10px;\n    }\n\n    .brutalist-border {\n        border: 2px solid rgba(255, 255, 255, 0.15);\n    }\n\n    .scattered-card {\n        transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);\n        max-height: 140px;\n        overflow: hidden;\n        cursor: pointer;\n    }\n\n    .scattered-card:hover {\n        max-height: 600px;\n        z-index: 100 !important;\n        transform: translate(-10px, -10px) scale(1.1) rotate(0deg) !important;\n        box-shadow: 20px 20px 0 var(--k-color-accent);\n        background: #111 !important;\n    }\n\n    .review-text {\n        display: -webkit-box;\n        -webkit-line-clamp: 2;\n        -webkit-box-orient: vertical;\n        overflow: hidden;\n        transition: all 0.5s ease;\n    }\n\n    .scattered-card:hover .review-text {\n        -webkit-line-clamp: unset;\n        display: block;\n    }\n</style>\n<div data-kid=\"1\" id=\"magnetic-dock-container\">\n<div class=\"dock-wrapper\" data-kid=\"1-1\">\n<div class=\"pr-5 mr-2 border-r border-white/10 flex items-center\" data-kid=\"1-1-1\">\n<img alt=\"Logo\" class=\"h-10 w-auto\" data-kid=\"1-1-1-1\" src=\"/api/local/images/.kombai/krishna-logo-new.png\">\n</div>\n<div class=\"dock-item\" data-kid=\"1-1-2\">\n<i class=\"ti ti-smart-home text-2xl\" data-kid=\"1-1-2-1\"></i>\n<span class=\"dock-tooltip\" data-kid=\"1-1-2-2\">Home</span>\n</div>\n<div class=\"dock-item\" data-kid=\"1-1-3\">\n<i class=\"ti ti-tools text-2xl\" data-kid=\"1-1-3-1\"></i>\n<span class=\"dock-tooltip\" data-kid=\"1-1-3-2\">Services</span>\n</div>\n<div class=\"dock-item bg-[var(--k-color-accent)] !border-none\" data-kid=\"1-1-4\">\n<i class=\"ti ti-phone-filled text-2xl\" data-kid=\"1-1-4-1\"></i>\n<span class=\"dock-tooltip\" data-kid=\"1-1-4-2\">Call Now</span>\n</div>\n</div>\n</div>\n<section class=\"relative min-h-[120vh] flex flex-col justify-end px-6 md:px-12 pb-24 md:pb-40 bg-black overflow-hidden\" data-kid=\"2\">\n<div class=\"absolute inset-0 z-0\" data-kid=\"2-1\">\n<video autoplay=\"\" class=\"w-full h-full object-cover brightness-75\" data-kid=\"2-1-1\" loop=\"\" muted=\"\" playsinline=\"\" poster=\"https://images.pexels.com/videos/30355025/pexels-photo-30355025.jpeg?auto=compress&amp;cs=tinysrgb&amp;fit=crop&amp;h=630&amp;w=1200\" preload=\"metadata\" src=\"https://v