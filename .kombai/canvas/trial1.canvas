      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;600&family=Geist+Mono:wght@400;600&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n@import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n:root {\n  --color-ground: #000000;\n  --color-on-ground: #E6E6E6;\n  --color-on-ground-muted: #757575;\n  --color-on-ground-bright: #FFFFFF;\n  --color-hairline: #1F1F1F;\n  --color-hairline-strong: #2A2A2A;\n  --color-surface-chip: #2E2E2E;\n  --color-surface-raised: #161616;\n  --color-wordmark: #CCCCCC;\n}\n\nbody {\n  background-color: var(--color-ground);\n  color: var(--color-on-ground);\n  font-family: 'Geist', sans-serif;\n  margin: 0;\n  overflow-x: clip;\n}\n\n.font-mono { font-family: 'Geist Mono', monospace; }\n\n.hairline-border { border: 1px solid var(--color-hairline); }\n\n/* Typography Overrides based on style guide */\n.display-xl { font-size: 180px; font-weight: 600; line-height: 0.9; letter-spacing: -0.04em; }\n.display { font-size: clamp(48px, 8.5vw, 110px); font-weight: 600; line-height: 0.85; letter-spacing: -0.05em; }\n.headline-lg { font-size: 44px; font-weight: 600; line-height: 1; letter-spacing: -0.03em; }\n.section-eyebrow { font-size: 24px; font-weight: 600; line-height: 24px; letter-spacing: -0.03em; color: var(--color-on-ground-muted); text-transform: uppercase; }\n.subhead { font-size: 20px; font-weight: 600; line-height: 20px; letter-spacing: -0.02em; }\n.label-text { font-size: 12px; font-weight: 600; line-height: 16px; text-transform: uppercase; }\n.mono-text { font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 400; line-height: 16px; }\n\n/* Grid Primitives */\n.hairline-grid { border-top: 1px solid var(--color-hairline); border-left: 1px solid var(--color-hairline); }\n.hairline-cell { border-right: 1px solid var(--color-hairline); border-bottom: 1px solid var(--color-hairline); }\n.hairline-t { border-top: 1px solid var(--color-hairline); }\n.hairline-b { border-bottom: 1px solid var(--color-hairline); }\n.hairline-r { border-right: 1px solid var(--color-hairline); }\n\n.project-row {\n  border-top: 1px solid var(--color-hairline);\n  padding: 80px 32px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  transition: background-color 0.4s cubic-bezier(0.65, 0, 0.35, 1);\n}\n.project-row:hover { background-color: var(--color-surface-raised); }\n.project-row:hover .headline-lg { color: var(--color-on-ground-bright); }\n\n.chip {\n  background: var(--color-surface-chip);\n  padding: 4px 8px;\n  font-size: 10px;\n  font-weight: 600;\n  text-transform: uppercase;\n  color: var(--color-on-ground);\n}\n\n/* Animations */\n.reveal-item { will-change: transform, opacity; }\n.reveal-item-grid { will-change: transform, opacity; }\n\n</style>\n\n\n<nav class=\"fixed top-0 left-0 w-full flex justify-between items-center px-8 py-6 md:px-12 z-50 mix-blend-difference\" data-kid=\"1\">\n  <div class=\"flex items-center gap-4\" data-kid=\"2\">\n    <img src=\"/api/local/images/public/krishna-logo.png\" alt=\"Krishna logo\" class=\"h-8 grayscale brightness-[10] contrast-[2]\" data-kid=\"3\">\n    <span class=\"label-text text-[var(--color-on-ground-bright)] tracking-tight\" data-kid=\"4\">Krishna Automobiles.</span>\n  </div>\n  <div class=\"flex items-center gap-10\" data-kid=\"5\">\n    <div class=\"hidden md:flex gap-8\" data-kid=\"6\">\n      <a href=\"#services\" class=\"label-text hover:text-white\" data-kid=\"7\">Capabilities</a>\n      <a href=\"#process\" class=\"label-text hover:text-white\" data-kid=\"8\">Process</a>\n      <a href=\"#location\" class=\"label-text hover:text-white\" data-kid=\"9\">Location</a>\n    </div>\n    <div class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"10\">\n      <div class=\"flex flex-col gap-1 w-5\" data-kid=\"11\">\n        <div class=\"h-0.5 w-full bg-white transition-all group-hover:translate-x-1\" data-kid=\"12\"></div>\n        <div class=\"h-0.5 w-full bg-white transition-all group-hover:-translate-x-1\" data-kid=\"13\"></div>\n      </div>\n      <span class=\"label-text\" data-kid=\"14\">Menu</span>\n    </div>\n  </div>\n</nav>\n\n\n<section class=\"relative min-h-screen flex flex-col justify-end p-8 md:p-16 overflow-hidden\" data-kid=\"15\">\n  <div class=\"absolute inset-0 z-0\" data-kid=\"16\">\n    <video src=\"https://videos.pexels.com/video-files/30355025/13011391_640_360_60fps.mp4\" poster=\"https://images.pexels.com/videos/30355025/pexels-photo-30355025.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover grayscale brightness-40\" data-kid=\"17\"></video>\n  </div>\n  \n  <div class=\"relative z-10 max-w-4xl reveal-item\" data-kid=\"18\">\n    <span class=\"subhead text-[var(--color-on-ground-muted)] mb-6 block uppercase tracking-tight\" data-kid=\"19\">Mira Road East / Est. 2009</span>\n    <h1 class=\"display uppercase mb-10 reveal-item\" data-kid=\"20\">\n      Superior <br data-kid=\"21\"> Engineering <br data-kid=\"22\"> for the Street.\n    </h1>\n    <div class=\"flex flex-col md:flex-row gap-12 items-start md:items-end\" data-kid=\"23\">\n      <p class=\"text-[20px] max-w-lg leading-relaxed text-[var(--color-on-ground)] font-normal reveal-item\" data-kid=\"24\">\n        Precision-led maintenance and authorized spares for high-performance machines. We specialize in restorations that perform as good as they look.\n      </p>\n      <div class=\"flex gap-4 reveal-item\" data-kid=\"25\">\n        <a href=\"tel:+910000000000\" class=\"px-8 py-4 hairline-border label-text hover:bg-white hover:text-black transition-colors\" data-kid=\"26\">Book Service</a>\n        <a href=\"https://wa.me/910000000000\" class=\"px-8 py-4 hairline-border label-text hover:bg-white hover:text-black transition-colors\" data-kid=\"27\">WhatsApp</a>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"process\" class=\"grid grid-cols-1 md:grid-cols-3 hairline-t hairline-b\" data-kid=\"28\">\n    <div class=\"p-8 md:p-12 hairline-cell reveal-item flex flex-col justify-between min-h-[340px]\" data-kid=\"29\">\n        <span class=\"mono-text text-[var(--color-on-ground-muted)]\" data-kid=\"30\">(01)</span>\n        <div data-kid=\"31\">\n            <h3 class=\"section-eyebrow text-white mb-4\" data-kid=\"32\">Diagnostics</h3>\n            <p class=\"body text-[var(--color-on-ground-muted)]\" data-kid=\"33\">Advanced digital scanner testing for BS6 compliance and fuel-injection mapping to ensure peak efficiency.</p>\n        </div>\n    </div>\n    <div class=\"p-8 md:p-12 hairline-cell reveal-item flex flex-col justify-between min-h-[340px]\" data-kid=\"34\">\n        <span class=\"mono-text text-[var(--color-on-ground-muted)]\" data-kid=\"35\">(02)</span>\n        <div data-kid=\"36\">\n            <h3 class=\"section-eyebrow text-white mb-4\" data-kid=\"37\">Precision Repair</h3>\n            <p class=\"body text-[var(--color-on-ground-muted)]\" data-kid=\"38\">Master mechanics executing technical restorations with genuine OEM components from Honda, Bajaj, and Royal Enfield.</p>\n        </div>\n    </div>\n    <div class=\"p-8 md:p-12 hairline-cell md:border-r-0 reveal-item flex flex-col justify-between min-h-[340px]\" data-kid=\"39\">\n        <span class=\"mono-text text-[var(--color-on-ground-muted)]\" data-kid=\"40\">(03)</span>\n        <div data-kid=\"41\">\n            <h3 class=\"section-eyebrow text-white mb-4\" data-kid=\"42\">System Testing</h3>\n            <p class=\"body text-[var(--color-on-ground-muted)]\" data-kid=\"43\">A rigorous 20-point quality control check and road-testing protocol before any machine is cleared for delivery.</p>\n        </div>\n    </div>\n</section>\n\n\n<section id=\"services\" class=\"py-32\" data-kid=\"44\">\n    <div class=\"px-8 md:px-16 mb-20 reveal-item\" data-kid=\"45\">\n        <span class=\"section-eyebrow block mb-6\" data-kid=\"46\">Capabilities</span>\n        <h2 class=\"display-xl uppercase leading-none tracking-tight max-w-4xl\" data-kid=\"47\">A technical ecosystem for your machine.</h2>\n    </div>\n\n    <div class=\"grid grid-cols-2 md:grid-cols-4 hairline-grid\" data-kid=\"48\">\n        <div class=\"hairline-cell aspect-square p-8 md:p-12 flex flex-col justify-between hover:bg-[var(--color-surface-raised)] group reveal-item-grid\" data-kid=\"49\">\n            <i class=\"ti ti-settings text-[16px] text-[var(--color-on-ground)] opacity-40 group-hover:opacity-100\" data-kid=\"50\"></i>\n            <div data-kid=\"51\">\n                <h3 class=\"subhead uppercase mb-3\" data-kid=\"52\">General Service</h3>\n                <span class=\"chip\" data-kid=\"53\">System Sync</span>\n            </div>\n        </div>\n        <div class=\"hairline-cell aspect-square p-8 md:p-12 flex flex-col justify-between hover:bg-[var(--color-surface-raised)] group reveal-item-grid\" data-kid=\"54\">\n            <i class=\"ti ti-engine text-[16px] text-[var(--color-on-ground)] opacity-40 group-hover:opacity-100\" data-kid=\"55\"></i>\n            <div data-kid=\"56\">\n                <h3 class=\"subhead uppercase mb-3\" data-kid=\"57\">Engine Work</h3>\n                <span class=\"chip\" data-kid=\"58\">Calibration</span>\n            </div>\n        </div>\n        <div class=\"hairline-cell aspect-square p-8 md:p-12 flex flex-col justify-between hover:bg-[var(--color-surface-raised)] group reveal-item-grid\" data-kid=\"59\">\n            <i class=\"ti ti-plug text-[16px] text-[var(--color-on-ground)] opacity-40 group-hover:opacity-100\" data-kid=\"60\"></i>\n            <div data-kid=\"61\">\n                <h3 class=\"subhead uppercase mb-3\" data-kid=\"62\">BS6 Diagnostics</h3>\n                <span class=\"chip\" data-kid=\"63\">Digital Scan</span>\n            </div>\n        </div>\n        <div class=\"hairline-cell aspect-square p-8 md:p-12 flex flex-col justify-between hover:bg-[var(--color-surface-raised)] group reveal-item-grid\" data-kid=\"64\">\n            <i class=\"ti ti-shield-check text-[16px] text-[var(--color-on-ground)] opacity-40 group-hover:opacity-100\" data-kid=\"65\"></i>\n            <div data-kid=\"66\">\n                <h3 class=\"subhead uppercase mb-3\" data-kid=\"67\">Safety Check</h3>\n                <span class=\"chip\" data-kid=\"68\">Rigorous</span>\n            </div>\n        </div>\n        <div class=\"hairline-cell aspect-square p-8 md:p-12 flex flex-col justify-between hover:bg-[var(--color-surface-raised)] group reveal-item-grid\" data-kid=\"69\">\n            <i class=\"ti ti-droplet text-[16px] text-[var(--color-on-ground)] opacity-40 group-hover:opacity-100\" data-kid=\"70\"></i>\n            <div data-kid=\"71\">\n                <h3 class=\"subhead uppercase mb-3\" data-kid=\"72\">Oil Service</h3>\n                <span class=\"chip\" data-kid=\"73\">Performance</span>\n            </div>\n        </div>\n        <div class=\"hairline-cell aspect-square p-8 md:p-12 flex flex-col justify-between hover:bg-[var(--color-surface-raised)] group reveal-item-grid\" data-kid=\"74\">\n            <i class=\"ti ti-bolt text-[16px] text-[var(--color-on-ground)] opacity-40 group-hover:opacity-100\" data-kid=\"75\"></i>\n            <div data-kid=\"76\">\n                <h3 class=\"subhead uppercase mb-3\" data-kid=\"77\">Electrical</h3>\n                <span class=\"chip\" data-kid=\"78\">Rewiring</span>\n            </div>\n        </div>\n        <div class=\"hairline-cell aspect-square p-8 md:p-12 flex flex-col justify-between hover:bg-[var(--color-surface-raised)] group reveal-item-grid\" data-kid=\"79\">\n            <i class=\"ti ti-circle-half-2 text-[16px] text-[var(--color-on-ground)] opacity-40 group-hover:opacity-100\" data-kid=\"80\"></i>\n            <div data-kid=\"81\">\n                <h3 class=\"subhead uppercase mb-3\" data-kid=\"82\">Brakes</h3>\n                <span class=\"chip\" data-kid=\"83\">Precision</span>\n            </div>\n        </div>\n        <div class=\"hairline-cell aspect-square p-8 md:p-12 flex flex-col justify-between hover:bg-[var(--color-surface-raised)] group reveal-item-grid\" data-kid=\"84\">\n            <i class=\"ti ti-tool text-[16px] text-[var(--color-on-ground)] opacity-40 group-hover:opacity-100\" data-kid=\"85\"></i>\n            <div data-kid=\"86\">\n                <h3 class=\"subhead uppercase mb-3\" data-kid=\"87\">Fabrication</h3>\n                <span class=\"chip\" data-kid=\"88\">Structural</span>\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<section class=\"py-32\" data-kid=\"89\">\n    <div class=\"px-8 md:px-16 mb-16 reveal-item\" data-kid=\"90\">\n        <span class=\"section-eyebrow block mb-4\" data-kid=\"91\">Genuine Supply</span>\n        <h2 class=\"headline-lg uppercase max-w-2xl\" data-kid=\"92\">Only the parts your machine deserves.</h2>\n    </div>\n\n    <div class=\"reveal-item px-0 md:px-0\" data-kid=\"93\">\n        <div class=\"project-row group\" data-kid=\"94\">\n            <div class=\"max-w-[340px] hidden md:block\" data-kid=\"95\">\n                <p class=\"mono-text text-[var(--color-on-ground-muted)] mb-2 uppercase tracking-widest\" data-kid=\"96\">(Authorized Retail)</p>\n                <p class=\"body text-[var(--color-on-ground-muted)]\" data-kid=\"97\">We use Castrol Power1 and Mobil Super Moto exclusively for endurance performance.</p>\n            </div>\n            <h3 class=\"headline-lg uppercase text-right transition-colors duration-300\" data-kid=\"98\">Mobil & Castrol</h3>\n        </div>\n\n        <div class=\"project-row group\" data-kid=\"99\">\n            <div class=\"max-w-[340px] hidden md:block\" data-kid=\"100\">\n                <p class=\"mono-text text-[var(--color-on-ground-muted)] mb-2 uppercase tracking-widest\" data-kid=\"101\">(Certified Stock)</p>\n                <p class=\"body text-[var(--color-on-ground-muted)]\" data-kid=\"102\">Factory-fresh Exide cells with zero-delay replacement for all modern two-wheelers.</p>\n            </div>\n            <h3 class=\"headline-lg uppercase text-right transition-colors duration-300\" data-kid=\"103\">Exide Batteries</h3>\n        </div>\n\n        <div class=\"project-row group\" data-kid=\"104\">\n            <div class=\"max-w-[340px] hidden md:block\" data-kid=\"105\">\n                <p class=\"mono-text text-[var(--color-on-ground-muted)] mb-2 uppercase tracking-widest\" data-kid=\"106\">(OEM Supply)</p>\n                <p class=\"body text-[var(--color-on-ground-muted)]\" data-kid=\"107\">100% genuine components sourced directly from authorized brand distribution channels.</p>\n            </div>\n            <h3 class=\"headline-lg uppercase text-right transition-colors duration-300\" data-kid=\"108\">Genuine Spares</h3>\n        </div>\n    </div>\n</section>\n\n\n<section class=\"py-32 hairline-t\" data-kid=\"109\">\n    <div class=\"px-8 md:px-16 mb-20 reveal-item text-center\" data-kid=\"110\">\n        <span class=\"section-eyebrow block mb-4\" data-kid=\"111\">Rider Feedback</span>\n        <h2 class=\"headline-lg uppercase\" data-kid=\"112\">Engineered Trust.</h2>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-2 hairline-grid\" data-kid=\"113\">\n        <div class=\"hairline-cell p-12 reveal-item flex flex-col justify-between min-h-[300px]\" data-kid=\"114\">\n            <span class=\"mono-text text-[var(--color-on-ground-muted)]\" data-kid=\"115\">(01)</span>\n            <p class=\"text-xl md:text-2xl leading-relaxed italic mb-8\" data-kid=\"116\">\"The only place in Mira Road I trust with my Bullet. They don't just fix things; they explain the 'why' behind it.\"</p>\n            <span class=\"label-text\" data-kid=\"117\">Amit Sharma / Classic 350</span>\n        </div>\n        <div class=\"hairline-cell p-12 reveal-item flex flex-col justify-between min-h-[300px]\" data-kid=\"118\">\n            <span class=\"mono-text text-[var(--color-on-ground-muted)]\" data-kid=\"119\">(02)</span>\n            <p class=\"text-xl md:text-2xl leading-relaxed italic mb-8\" data-kid=\"120\">\"BS6 issues are a nightmare, but their digital scanner caught the sensor fault in 5 minutes. Highly recommended.\"</p>\n            <span class=\"label-text\" data-kid=\"121\">Rohan Varma / Pulsar NS200</span>\n        </div>\n    </div>\n</section>\n\n\n<section id=\"location\" class=\"py-32 hairline-t\" data-kid=\"122\">\n    <div class=\"px-8 md:px-16 mb-16 reveal-item\" data-kid=\"123\">\n        <span class=\"section-eyebrow block mb-4\" data-kid=\"124\">Find the Hub</span>\n        <h2 class=\"headline-lg uppercase\" data-kid=\"125\">Mira Road East.</h2>\n    </div>\n    \n    <div class=\"px-8 md:px-16 reveal-item\" data-kid=\"126\">\n        <div class=\"relative w-full aspect-[21/9] overflow-hidden hairline-border\" data-kid=\"127\">\n            <img src=\"https://images.pexels.com/photos/5252118/pexels-photo-5252118.jpeg?auto=format&w=1600&q=80&fit=crop\" alt=\"Shop Front\" class=\"w-full h-full object-cover grayscale brightness-50\" decoding=\"async\" loading=\"lazy\" data-kid=\"128\">\n            <div class=\"absolute bottom-0 left-0 max-w-sm p-8 bg-black border-r border-t border-[var(--color-hairline)]\" data-kid=\"129\">\n                <p class=\"label-text text-white mb-2\" data-kid=\"130\">Service Hub</p>\n                <p class=\"body text-[var(--color-on-ground)]\" data-kid=\"131\">Shop No. 4, Mira Road East, Thane, Maharashtra 401107.</p>\n                <a href=\"#\" class=\"inline-block mt-4 label-text border-b border-white pb-1\" data-kid=\"132\">Open in Maps</a>\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<footer class=\"pt-32\" data-kid=\"133\">\n  <div class=\"wordmark-container overflow-hidden reveal-item\" data-kid=\"134\">\n    <div class=\"display-xl text-[clamp(80px,20vw,260px)] text-[var(--color-wordmark)] text-center leading-[0.8] mb-12\" data-kid=\"135\">KRISHNA</div>\n  </div>\n  \n  <div class=\"px-8 md:px-16 py-12 hairline-t flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"136\">\n    <div class=\"flex gap-10\" data-kid=\"137\">\n        <a href=\"#services\" class=\"label-text hover:text-white transition-colors\" data-kid=\"138\">Capabilities</a>\n        <a href=\"#process\" class=\"label-text hover:text-white transition-colors\" data-kid=\"139\">Process</a>\n        <a href=\"#location\" class=\"label-text hover:text-white transition-colors\" data-kid=\"140\">Location</a>\n    </div>\n    \n    <div class=\"flex items-center gap-10\" data-kid=\"141\">\n        <div class=\"flex gap-6\" data-kid=\"142\">\n            <a href=\"#\" class=\"label-text hover:text-white transition-colors\" data-kid=\"143\">Instagram</a>\n            <a href=\"#\" class=\"label-text hover:text-white transition-colors\" data-kid=\"144\">WhatsApp</a>\n        </div>\n        <span class=\"mono-text text-[var(--color-on-ground-muted)]\" data-kid=\"145\">© 2024 / Mira Road East</span>\n    </div>\n  </div>\n  \n  <div class=\"px-8 md:px-16 py-6 hairline-t flex justify-between text-[10px] text-[var(--color-on-ground-muted)] uppercase tracking-[0.2em]\" data-kid=\"146\">\n    <span data-kid=\"147\">Engineering trust since 2009.</span>\n    <span data-kid=\"148\">GPay & Cash only. No cards.</span>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"149\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"150\"></script>\n<script type=\"module\" data-kid=\"151\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    \n    gsap.registerPlugin(ScrollTrigger);\n\n    const lenis = new Lenis({\n        duration: 1.2,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n        orientation: 'vertical',\n        smoothWheel: true,\n        wheelMultiplier: 1,\n        smoothTouch: false,\n        touchMultiplier: 2,\n        infinite: false,\n    })\n\n    lenis.on('scroll', ScrollTrigger.update)\n\n    gsap.ticker.add((time) => {\n        lenis.raf(time * 1000)\n    })\n\n    gsap.ticker.lagSmoothing(0)\n\n    // Fade up animations for sections\n    const items = document.querySelectorAll('.reveal-item');\n    items.forEach((item) => {\n        gsap.from(item, {\n            scrollTrigger: {\n                trigger: item,\n                start: 'top 90%',\n                toggleActions: 'play none none none'\n            },\n            y: 40,\n            opacity: 0,\n            duration: 1,\n            ease: \"expo.out\"\n        });\n    });\n\n    // Stagger for grid items\n    const gridItems = document.querySelectorAll('.reveal-item-grid');\n    gsap.from(gridItems, {\n        scrollTrigger: {\n            trigger: '.hairline-grid',\n            start: 'top 85%',\n        },\n        y: 30,\n        opacity: 0,\n        stagger: 0.1,\n        duration: 0.8,\n        ease: \"power3.out\"\n    });\n\n    // Logo grayscale logic is already in CSS\n</script>\n",
