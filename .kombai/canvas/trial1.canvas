d=\"2-6-2\">\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 md:gap-24 mb-32 items-end\" data-kid=\"2-6-2-1\">\n<div class=\"lg:col-span-8\" data-kid=\"2-6-2-1-1\">\n<span class=\"font-mono text-[var(--accent-red)] text-xs uppercase tracking-[0.5em] block mb-6\" data-kid=\"2-6-2-1-1-1\">04 // SOCIAL_PROOF</span>\n<h2 class=\"text-7xl md:text-[9rem] font-display font-black uppercase tracking-[-0.08em] leading-[0.8]\" data-kid=\"2-6-2-1-1-2\">\n            THE RIDER'S<br data-kid=\"2-6-2-1-1-2-1\"><span class=\"text-[var(--accent-red)]\" data-kid=\"2-6-2-1-1-2-2\">WORD.</span>\n</h2>\n</div>\n<div class=\"lg:col-span-4 bg-[var(--accent-red)] p-12 text-black shadow-[16px_16px_0_#111] relative overflow-hidden\" data-kid=\"2-6-2-1-2\">\n<div class=\"absolute top-4 right-4 font-mono text-[8px] font-black opacity-20\" data-kid=\"2-6-2-1-2-1\" data-name=\"rating verification small code\">VERIFIED_DATA_V2.0</div>\n<span class=\"font-mono text-[10px] font-black uppercase tracking-[0.4em] mb-4 block\" data-kid=\"2-6-2-1-2-2\">Unstoppable Trust</span>\n<div class=\"flex items-end gap-2 mb-4\" data-kid=\"2-6-2-1-2-3\">\n<h3 class=\"text-8xl font-display font-black leading-none tracking-tighter\" data-kid=\"2-6-2-1-2-3-1\">4.8</h3>\n<span class=\"text-2xl font-bold mb-2\" data-kid=\"2-6-2-1-2-3-2\">/ 5.0</span>\n</div>\n<div class=\"h-1 bg-black/20 mb-6\" data-kid=\"2-6-2-1-2-4\">\n<div class=\"w-[96%] h-full bg-black\" data-kid=\"2-6-2-1-2-4-1\"></div>\n</div>\n<span class=\"text-[10px] font-black uppercase tracking-widest opacity-60\" data-kid=\"2-6-2-1-2-5\">Verified Google Reviews</span>\n</div>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 items-start\" data-kid=\"2-6-2-2\" id=\"masonry-grid\">\n\n<div class=\"space-y-8 md:space-y-12 testimonial-col\" data-kid=\"2-6-2-2-1\" data-speed=\"0.1\">\n<div class=\"bg-[var(--surface)] p-10 brutalist-card group\" data-kid=\"2-6-2-2-1-1\">\n<p class=\"text-xl md:text-2xl font-black italic mb-8 leading-tight\" data-kid=\"2-6-2-2-1-1-1\">\"Had a very good experience. Fixed my scooty perfectly. Fast service, fair price.\"</p>\n<div class=\"flex flex-col\" data-kid=\"2-6-2-2-1-1-2\">\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--accent-red)]\" data-kid=\"2-6-2-2-1-1-2-1\">Sahil Raj</span>\n<span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"2-6-2-2-1-1-2-2\">Local Guide</span>\n</div>\n</div>\n<div class=\"bg-[var(--surface)] p-10 brutalist-card border-l-4 border-l-[var(--accent-red)] group\" data-kid=\"2-6-2-2-1-2\">\n<div class=\"flex items-center gap-2 mb-6 text-[var(--accent-red)]\" data-kid=\"2-6-2-2-1-2-1\">\n<i class=\"ti ti-bolt text-2xl\" data-kid=\"2-6-2-2-1-2-1-1\"></i>\n<span class=\"text-xs font-black uppercase tracking-widest\" data-kid=\"2-6-2-2-1-2-1-2\">OLA / EV SPECIALIST</span>\n</div>\n<p class=\"text-lg text-white/80 leading-relaxed mb-8\" data-kid=\"2-6-2-2-1-2-2\">\"Finally found someone who understands EV electronics in this area. Highly recommended for EV owners.\"</p>\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--accent-red)]\" data-kid=\"2-6-2-2-1-2-3\">Asif Sayyed</span>\n</div>\n</div>\n\n<div class=\"space-y-8 md:space-y-12 md:pt-32 testimonial-col\" data-kid=\"2-6-2-2-2\" data-speed=\"-0.1\">\n<div class=\"bg-[var(--surface)] p-10 brutalist-card group\" data-kid=\"2-6-2-2-2-1\">\n<p class=\"text-lg text-white/80 leading-relaxed mb-8\" data-kid=\"2-6-2-2-2-1-1\">\"Mechanics Shiva and Deepak are highly skilled and provide excellent service. Genuine master hands at work here.\"</p>\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--accent-red)]\" data-kid=\"2-6-2-2-2-1-2\">Roshan Anand</span>\n</div>\n<div class=\"aspect-square brutalist-card overflow-hidden\" data-kid=\"2-6-2-2-2-2\">\n<img class=\"w-full h-full object-cover grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all duration-700\" data-kid=\"2-6-2-2-2-2-1\" src=\"https://images.pexels.com/photos/11890963/pexels-photo-11890963.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n</div>\n\n<div class=\"space-y-8 md:space-y-12 md:pt-16 testimonial-col\" data-kid=\"2-6-2-2-3\" data-speed=\"0.2\">\n<div class=\"bg-[var(--surface)] p-10 brutalist-card group\" data-kid=\"2-6-2-2-3-1\">\n<p class=\"text-xl md:text-2xl font-black italic mb-8 leading-tight\" data-kid=\"2-6-2-2-3-1-1\">\"Excellent Ola repair centre. They successfully resolved my electric charging system issue.\"</p>\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--accent-red)]\" data-kid=\"2-6-2-2-3-1-2\">Paresh Jani</span>\n</div>\n<div class=\"bg-[var(--surface)] p-10 brutalist-card border-l-4 border-l-white/20 group\" data-kid=\"2-6-2-2-3-2\">\n<p class=\"text-lg text-white/80 leading-relaxed mb-8\" data-kid=\"2-6-2-2-3-2-1\">\"My Hunter 350 feels like new. The tuning is surgical. Highly skilled technicians.\"</p>\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--accent-red)]\" data-kid=\"2-6-2-2-3-2-2\">Vikram Singh</span>\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<footer class=\"py-24 px-6 md:px-12 bg-black border-t border-[var(--border-dark)] relative overflow-hidden\" data-kid=\"2-7\">\n<div class=\"absolute bottom-0 right-0 p-12 opacity-[0.05] pointer-events-none\" data-kid=\"2-7-1\">\n<span class=\"font-display font-black text-[25vw] leading-none uppercase tracking-tighter\" data-kid=\"2-7-1-1\">KRISHNA</span>\n</div>\n<div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"2-7-2\">\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 mb-24\" data-kid=\"2-7-2-1\">\n<div class=\"col-span-12 lg:col-span-5\" data-kid=\"2-7-2-1-1\">\n<div class=\"flex items-center gap-4 mb-12\" data-kid=\"2-7-2-1-1-1\">\n<div class=\"w-12 h-12 bg-[var(--accent-red)] rounded-full flex items-center justify-center font-bold text-xl italic text-black\" data-kid=\"2-7-2-1-1-1-1\">K</div>\n<span class=\"text-3xl font-display font-black uppercase tracking-tighter\" data-kid=\"2-7-2-1-1-1-2\">KRISHNA AUTOMOBILE</span>\n</div>\n<p class=\"text-xl text-white/40 uppercase tracking-tight max-w-sm mb-12\" data-kid=\"2-7-2-1-1-2\">\n            Mira Road East's most trusted repair shop since 2009. Precision servicing for all major brands.\n          </p>\n<div class=\"flex gap-6\" data-kid=\"2-7-2-1-1-3\">\n<a class=\"w-16 h-16 border border-white/10 rounded-2xl flex items-center justify-center hover:bg-[var(--accent-red)] transition-all\" data-kid=\"2-7-2-1-1-3-1\" href=\"tel:+9109322245569\">\n<i class=\"ti ti-phone-filled text-2xl\" data-kid=\"2-7-2-1-1-3-1-1\"></i>\n</a>\n<a class=\"w-16 h-16 border border-white/10 rounded-2xl flex items-center justify-center hover:bg-[#25D366] transition-all\" data-kid=\"2-7-2-1-1-3-2\" href=\"https://wa.me/9109322245569\">\n<i class=\"ti ti-brand-whatsapp text-3xl\" data-kid=\"2-7-2-1-1-3-2-1\"></i>\n</a>\n</div>\n</div>\n<div class=\"col-span-6 lg:col-span-3\" data-kid=\"2-7-2-1-2\">\n<h4 class=\"font-mono text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent-red)] mb-10\" data-kid=\"2-7-2-1-2-1\">Contact Matrix</h4>\n<div class=\"space-y-6\" data-kid=\"2-7-2-1-2-2\">\n<div data-kid=\"2-7-2-1-2-2-1\">\n<span class=\"block text-[10px] font-mono uppercase text-white/30 mb-2\" data-kid=\"2-7-2-1-2-2-1-1\">Primary Line</span>\n<a class=\"text-2xl font-display font-bold hover:text-[var(--accent-red)] transition-colors\" data-kid=\"2-7-2-1-2-2-1-2\" href=\"tel:+9109322245569\">093222 45569</a>\n</div>\n<div data-kid=\"2-7-2-1-2-2-2\">\n<span class=\"block text-[10px] font-mono uppercase text-white/30 mb-2\" data-kid=\"2-7-2-1-2-2-2-1\">Secondary Line</span>\n<a class=\"text-2xl font-display font-bold hover:text-[var(--accent-red)] transition-colors\" data-kid=\"2-7-2-1-2-2-2-2\" href=\"tel:+9109082744210\">090827 44210</a>\n</div>\n<div data-kid=\"2-7-2-1-2-2-3\">\n<span class=\"block text-[10px] font-mono uppercase text-white/30 mb-2\" data-kid=\"2-7-2-1-2-2-3-1\">Terminal Location</span>\n<p class=\"text-sm text-white/60 leading-relaxed uppercase tracking-tighter\" data-kid=\"2-7-2-1-2-2-3-2\">Shop No.11, Gaurav sankalp chintan 11, hatkesh, Mira Road East, 401107</p>\n</div>\n</div>\n</div>\n<div class=\"col-span-6 lg:col-span-4\" data-kid=\"2-7-2-1-3\">\n<h4 class=\"font-mono text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent-red)] mb-10\" data-kid=\"2-7-2-1-3-1\">Operation Protocol</h4>\n<div class=\"space-y-6\" data-kid=\"2-7-2-1-3-2\">\n<div class=\"flex justify-between border-b border-white/10 pb-4\" data-kid=\"2-7-2-1-3-2-1\">\n<span class=\"text-xs font-mono uppercase text-white/60\" data-kid=\"2-7-2-1-3-2-1-1\">MON - SUN</span>\n<span class=\"text-xs font-mono font-bold uppercase\" data-kid=\"2-7-2-1-3-2-1-2\">9:00 AM - 9:30 PM</span>\n</div>\n<div class=\"p-6 bg-[var(--surface)] border border-white/5 rounded-xl\" data-kid=\"2-7-2-1-3-2-2\">\n<p class=\"text-[10px] font-mono uppercase tracking-widest text-[var(--accent-red)] font-black\" data-kid=\"2-7-2-1-3-2-2-1\">SYSTEM STATUS: ACTIVE</p>\n<p class=\"text-xs text-white/40 mt-2 uppercase tracking-tighter\" data-kid=\"2-7-2-1-3-2-2-2\">No Appointments Required — Walk-in Protocol Enabled.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"flex flex-col md:flex-row justify-between items-center pt-12 border-t border-white/10 text-[10px] font-mono text-white/20 uppercase tracking-[0.3em]\" data-kid=\"2-7-2-2\">\n<p data-kid=\"2-7-2-2-1\">© 2024 KRISHNA AUTOMOBILE. ALL SYSTEMS OPERATIONAL.</p>\n<p data-kid=\"2-7-2-2-2\">MECHANICAL PRECISION GUARANTEED</p>\n</div>\n</div>\n</footer>\n</main>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"3\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"4\"></script>\n<script type=\"module\" data-kid=\"5\">\n  import Lenis from \"https://esm.sh/lenis@1\";\n  import Snap from \"https://esm.sh/lenis@1/snap\";\n  \n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initialize Lenis\n  const lenis = new Lenis({\n    duration: 1.2,\n    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n    smoothWheel: true\n  });\n\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // Animations\n  window.addEventListener('load', () => {\n    // Dock Entrance\n    gsap.to('#magnetic-dock-container', {\n      opacity: 1,\n      y: 0,\n      pointerEvents: 'auto',\n      scrollTrigger: {\n        trigger: '#hero',\n        start: 'bottom top',\n        toggleActions: 'play none none reverse'\n      }\n    });\n\n    // Hero Reveal\n    const heroTl = gsap.timeline();\n    heroTl.from('#hero-protocol-label', { opacity: 0, x: -30, duration: 1, ease: 'power4.out' })\n          .from('#hero-title', { opacity: 0, y: 100, duration: 1.2, ease: 'expo.out' }, '-=0.8')\n          .from('#hero-cta-block', { opacity: 0, y: 50, duration: 1, ease: 'power3.out' }, '-=1');\n\n    // Matrix Watermark Parallax\n    gsap.to('#matrix-watermark', {\n      xPercent: -30,\n      ease: 'none',\n      scrollTrigger: {\n        trigger: '#services',\n        start: 'top bottom',\n        end: 'bottom top',\n        scrub: true\n      }\n    });\n\n    // Testimonial Watermark Parallax\n    gsap.to('#testimonial-watermark', {\n      xPercent: 20,\n      ease: 'none',\n      scrollTrigger: {\n        trigger: '#testimonials',\n        start: 'top bottom',\n        end: 'bottom top',\n        scrub: true\n      }\n    });\n\n    // Service Cards Entrance\n    gsap.from('.service-reveal', {\n      opacity: 0,\n      y: 100,\n      stagger: 0.2,\n      duration: 1.2,\n      ease: 'expo.out',\n      scrollTrigger: {\n        trigger: '#services',\n        start: 'top 70%'\n      }\n    });\n\n    // Refined Masonry Parallax\n    gsap.utils.toArray('.testimonial-col').forEach(col => {\n      const speed = parseFloat(col.getAttribute('data-speed'));\n      gsap.to(col, {\n        y: speed * 300,\n        ease: 'none',\n        scrollTrigger: {\n          trigger: '#testimonials',\n          start: 'top bottom',\n          end: 'bottom top',\n          scrub: true\n        }\n      });\n    });\n  });\n</script>\n",
