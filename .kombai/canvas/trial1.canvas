      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');\n\n    :root {\n        --color-secondary: #999999;\n        --color-border: #1f1f1f;\n        --color-surface: #0a0a0a;\n        --color-accent: #ff0000;\n        --color-background: #000000;\n        --color-primary: #ffffff;\n    }\n\n    body {\n        background-color: var(--color-background);\n        color: var(--color-primary);\n        font-family: 'Inter', sans-serif;\n        margin: 0;\n        overflow-x: clip;\n    }\n\n    .ticker-wrapper {\n        overflow: hidden;\n        white-space: nowrap;\n        border-top: 1px solid var(--color-border);\n        border-bottom: 1px solid var(--color-border);\n        background: var(--color-surface);\n        padding: 20px 0;\n    }\n\n    .ticker-content {\n        display: inline-block;\n        animation: ticker 30s linear infinite;\n    }\n\n    @keyframes ticker {\n        0% { transform: translateX(0); }\n        100% { transform: translateX(-50%); }\n    }\n\n    .grid-pattern {\n        background-image: linear-gradient(var(--color-border) 1px, transparent 1px),\n                          linear-gradient(90deg, var(--color-border) 1px, transparent 1px);\n        background-size: 60px 60px;\n    }\n\n    .industrial-corner::after {\n        content: '';\n        position: absolute;\n        top: 0;\n        right: 0;\n        width: 10px;\n        height: 10px;\n        border-top: 2px solid var(--color-accent);\n        border-right: 2px solid var(--color-accent);\n    }\n</style>\n\n<div class=\"relative min-h-screen\" data-kid=\"1\">\n    \n    <div class=\"fixed inset-0 grid-pattern opacity-10 pointer-events-none z-0\" data-kid=\"2\"></div>\n\n    \n    <nav class=\"sticky top-0 z-50 bg-black/80 backdrop-blur-md border-b border-[#ffffff]/10 px-8 py-4 flex justify-between items-center\" data-kid=\"3\">\n        <div class=\"flex items-center gap-3\" data-kid=\"4\">\n            <div class=\"w-8 h-8 bg-[#ff0000] flex items-center justify-center font-bold italic text-white rounded-xs\" data-kid=\"5\">K</div>\n            <span class=\"font-bold tracking-tighter text-xl uppercase\" data-kid=\"6\">Krishna <span class=\"text-[#ff0000]\" data-kid=\"7\">Automobile</span></span>\n        </div>\n        <div class=\"hidden lg:flex gap-8 items-center uppercase text-[10px] font-bold tracking-[0.2em]\" data-kid=\"8\">\n            <a href=\"#\" class=\"hover:text-[#ff0000] transition-colors\" data-kid=\"9\">Home</a>\n            <a href=\"#\" class=\"text-[#ff0000] underline underline-offset-8\" data-kid=\"10\">Services</a>\n            <a href=\"#\" class=\"hover:text-[#ff0000] transition-colors\" data-kid=\"11\">Insurance & Legal</a>\n            <a href=\"#\" class=\"hover:text-[#ff0000] transition-colors\" data-kid=\"12\">About Us</a>\n            <a href=\"#\" class=\"hover:text-[#ff0000] transition-colors\" data-kid=\"13\">Contact</a>\n        </div>\n        <button class=\"bg-white text-black px-6 py-2 rounded-full font-bold text-[10px] uppercase tracking-widest hover:bg-[#ff0000] hover:text-white transition-all cursor-pointer\" data-kid=\"14\">Quick Call</button>\n    </nav>\n    \n    \n    <header class=\"relative pt-48 pb-32 px-8 md:px-24 overflow-hidden border-b border-[#1f1f1f]\" data-kid=\"15\">\n        <div class=\"relative z-10\" data-kid=\"16\">\n            <div class=\"flex items-center gap-4 mb-12\" data-kid=\"17\">\n                <span class=\"text-[#ff0000] font-mono text-4xl font-black\" data-kid=\"18\">02</span>\n                <div class=\"h-px w-24 bg-[#ff0000]\" data-kid=\"19\"></div>\n                <span class=\"uppercase tracking-[0.5em] text-[10px] font-black text-[#ffffff]\" data-kid=\"20\">TECHNICAL SERVICE PROTOCOLS</span>\n            </div>\n            <h1 class=\"text-[14vw] lg:text-[12vw] leading-[0.75] font-black uppercase tracking-[-0.08em] mb-20\" data-kid=\"21\">\n                Precision <br data-kid=\"22\">\n                <span class=\"text-transparent\" style=\"-webkit-text-stroke: 2px #ff0000;\" data-kid=\"23\">Maintenance</span><br data-kid=\"24\">\n                Matrix\n            </h1>\n            <div class=\"flex flex-col md:flex-row md:items-start justify-between gap-16\" data-kid=\"25\">\n                <div class=\"max-w-xl\" data-kid=\"26\">\n                    <p class=\"text-[#ffffff] text-xl lg:text-2xl leading-none uppercase font-bold tracking-tight mb-6\" data-kid=\"27\">\n                        ENGINEERED RELIABILITY SINCE 2009.\n                    </p>\n                    <p class=\"text-[#999999] text-sm lg:text-base leading-relaxed uppercase tracking-widest opacity-80\" data-kid=\"28\">\n                        Industrial-grade charging. Precision carburetor calibration. Authorized multi-brand component handling.\n                    </p>\n                </div>\n                <div class=\"flex items-center gap-8 border-l border-[#1f1f1f] pl-8\" data-kid=\"29\">\n                    <div class=\"text-right\" data-kid=\"30\">\n                        <span class=\"block text-[10px] uppercase tracking-widest text-[#999999] mb-1\" data-kid=\"31\">Status</span>\n                        <span class=\"text-[#ff0000] font-bold uppercase text-sm flex items-center gap-2 justify-end\" data-kid=\"32\">\n                            <span class=\"w-2 h-2 bg-[#ff0000] rounded-full animate-pulse\" data-kid=\"33\"></span> Open Now\n                        </span>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"absolute -bottom-20 -right-20 w-96 h-96 border border-[#ffffff]/5 rotate-45 pointer-events-none\" data-kid=\"34\"></div>\n    </header>\n\n    \n    <div class=\"ticker-wrapper z-10 relative\" data-kid=\"35\">\n        <div class=\"ticker-content flex items-center gap-24 uppercase font-bold text-sm tracking-[0.2em]\" data-kid=\"36\">\n            <span data-kid=\"37\">Battery Service ₹150</span>\n            <span class=\"text-[#ff0000]\" data-kid=\"38\">/</span>\n            <span data-kid=\"39\">Brake Service ₹200</span>\n            <span class=\"text-[#ff0000]\" data-kid=\"40\">/</span>\n            <span data-kid=\"41\">Carburetor Cleaning ₹450</span>\n            <span class=\"text-[#ff0000]\" data-kid=\"42\">/</span>\n            <span data-kid=\"43\">Vehicle Delivery ₹100</span>\n            <span class=\"text-[#ff0000]\" data-kid=\"44\">/</span>\n            <span data-kid=\"45\">Oil Change Special Offer</span>\n            <span class=\"text-[#ff0000]\" data-kid=\"46\">/</span>\n            <span data-kid=\"47\">Battery Service ₹150</span>\n            <span class=\"text-[#ff0000]\" data-kid=\"48\">/</span>\n            <span data-kid=\"49\">Brake Service ₹200</span>\n            <span class=\"text-[#ff0000]\" data-kid=\"50\">/</span>\n            <span data-kid=\"51\">Carburetor Cleaning ₹450</span>\n            <span class=\"text-[#ff0000]\" data-kid=\"52\">/</span>\n            <span data-kid=\"53\">Vehicle Delivery ₹100</span>\n        </div>\n    </div>\n\n    \n    <section class=\"py-40 px-8 md:px-24 relative overflow-x-clip border-b border-[#1f1f1f]\" data-kid=\"54\">\n        <div class=\"mb-32\" data-kid=\"55\">\n            <span class=\"text-[#ff0000] font-mono text-xl font-bold block mb-4\" data-kid=\"56\">01 // CORE_SYSTEMS</span>\n            <h2 class=\"text-8xl lg:text-9xl font-black uppercase tracking-[-0.08em] leading-[0.8]\" data-kid=\"57\">Service <br data-kid=\"58\">Infrastructure</h2>\n        </div>\n\n        <div class=\"flex flex-col gap-px bg-[#1f1f1f]\" data-kid=\"59\">\n            \n            <div class=\"flex flex-col lg:flex-row gap-px\" data-kid=\"60\">\n                <div class=\"lg:w-2/3 bg-[#0a0a0a] rounded-xl p-12 lg:p-16 group relative industrial-corner service-card-anim m-1\" data-kid=\"61\">\n                    <span class=\"text-7xl lg:text-9xl font-black opacity-10 group-hover:opacity-30 group-hover:text-[#ff0000] transition-all absolute top-8 right-8 pointer-events-none\" data-kid=\"62\">01</span>\n                    <div class=\"relative z-10\" data-kid=\"63\">\n                        <div class=\"flex items-center gap-6 mb-12\" data-kid=\"64\">\n                            <span class=\"w-12 h-12 rounded-full bg-[#ff0000] flex items-center justify-center text-white\" data-kid=\"65\"><i class=\"fa-solid fa-battery-bolt\" data-kid=\"66\"></i></span>\n                            <span class=\"text-[#ff0000] font-mono text-2xl font-black\" data-kid=\"67\">₹150</span>\n                        </div>\n                        <h3 class=\"text-4xl lg:text-6xl font-black uppercase tracking-tighter mb-8 leading-none\" data-kid=\"68\">Industrial <br data-kid=\"69\">Battery Charging</h3>\n                        <p class=\"text-[#999999] text-lg max-w-lg mb-12 font-medium\" data-kid=\"70\">Systematic power restoration using industrial-grade chargers to maximize cell longevity and starting strength for all OEM battery units.</p>\n                        <button class=\"bg-white text-black px-12 py-4 rounded-full font-black text-xs uppercase tracking-[0.2em] hover:bg-[#ff0000] hover:text-white transition-all\" data-kid=\"71\">Execute Service</button>\n                    </div>\n                </div>\n                <div class=\"lg:w-1/3 bg-[#0a0a0a] rounded-xl p-12 group relative service-card-anim m-1 overflow-hidden\" data-kid=\"72\">\n                    <span class=\"text-6xl font-black opacity-10 absolute top-8 right-8\" data-kid=\"73\">04</span>\n                    <div class=\"relative z-10 h-full flex flex-col\" data-kid=\"74\">\n                        <span class=\"text-[#ff0000] font-mono text-2xl font-black mb-8\" data-kid=\"75\">₹100</span>\n                        <h3 class=\"text-3xl font-black uppercase tracking-tighter mb-6\" data-kid=\"76\">Logistics / <br data-kid=\"77\">Delivery</h3>\n                        <p class=\"text-[#999999] text-sm mb-12\" data-kid=\"78\">Automated pickup and delivery routing within the Mira Road East perimeter.</p>\n                        <div class=\"mt-auto\" data-kid=\"79\">\n                             <div class=\"w-full h-1 bg-[#1f1f1f] overflow-hidden\" data-kid=\"80\">\n                                <div class=\"h-full bg-[#ff0000] w-1/3 group-hover:w-full transition-all duration-1000\" data-kid=\"81\"></div>\n                             </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"flex flex-col lg:flex-row gap-px\" data-kid=\"82\">\n                <div class=\"lg:w-1/2 bg-[#0a0a0a] rounded-xl p-12 group relative service-card-anim m-1\" data-kid=\"83\">\n                    <span class=\"text-8xl font-black opacity-10 group-hover:text-[#ff0000] transition-all absolute -bottom-4 right-8 pointer-events-none\" data-kid=\"84\">02</span>\n                    <div class=\"relative z-10\" data-kid=\"85\">\n                        <span class=\"text-[#ff0000] font-mono text-2xl font-black mb-6 block\" data-kid=\"86\">₹200</span>\n                        <h3 class=\"text-4xl font-black uppercase tracking-tighter mb-6\" data-kid=\"87\">Brake / Safety <br data-kid=\"88\">Calibrated Repair</h3>\n                        <p class=\"text-[#999999] text-sm max-w-sm mb-8\" data-kid=\"89\">Pad replacement, adjustment, fluid inspection, and disc surface remediation. Safety-critical protocol application.</p>\n                    </div>\n                </div>\n                <div class=\"lg:w-1/2 bg-[#0a0a0a] rounded-xl p-12 group relative service-card-anim m-1\" data-kid=\"90\">\n                    <span class=\"text-8xl font-black opacity-10 group-hover:text-[#ff0000] transition-all absolute -bottom-4 right-8 pointer-events-none\" data-kid=\"91\">03</span>\n                    <div class=\"relative z-10\" data-kid=\"92\">\n                        <span class=\"text-[#ff0000] font-mono text-2xl font-black mb-6 block\" data-kid=\"93\">₹450</span>\n                        <h3 class=\"text-4xl font-black uppercase tracking-tighter mb-6\" data-kid=\"94\">Carburetor <br data-kid=\"95\">Sonic Cleaning</h3>\n                        <p class=\"text-[#999999] text-sm max-w-sm mb-8\" data-kid=\"96\">Chemical cleaning and precise needle tuning for optimized air-fuel ratio and throttle response dynamics.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-24 px-8 md:px-24 bg-[#050505]\" data-kid=\"97\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"98\">\n            <div class=\"flex flex-col md:flex-row gap-16 items-start\" data-kid=\"99\">\n                <div class=\"w-full md:w-1/3 md:sticky md:top-32\" data-kid=\"100\">\n                    <div class=\"inline-block px-3 py-1 bg-[#ff0000] text-white text-[10px] font-bold uppercase tracking-[0.2em] mb-6\" data-kid=\"101\">Repair Catalog</div>\n                    <h2 class=\"text-6xl font-black uppercase tracking-tighter leading-none mb-8\" data-kid=\"102\">Additional <br data-kid=\"103\">Support</h2>\n                    <p class=\"text-[#ffffff] text-sm leading-relaxed border-l border-[#ffffff]/20 pl-6 py-2 mb-12\" data-kid=\"104\">Systemic mechanical remediation for high-performance two-wheeler platforms.</p>\n                    <div class=\"relative group overflow-hidden\" data-kid=\"105\">\n                        <div class=\"absolute inset-0 bg-[#ff0000]/20 opacity-0 group-hover:opacity-100 transition-opacity z-10 pointer-events-none\" data-kid=\"106\"></div>\n                        <img src=\"https://images.unsplash.com/photo-1558981403-c5f9899a28bc?auto=format&w=800&q=80&fit=crop\" alt=\"Motorcycle Engine\" class=\"w-full grayscale brightness-75 contrast-125 border border-[#1f1f1f] transform transition-transform duration-700 group-hover:scale-110\" loading=\"lazy\" decoding=\"async\" data-kid=\"107\">\n                    </div>\n                </div>\n                \n                <div class=\"w-full md:w-2/3\" data-kid=\"108\">\n                    <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-px bg-[#1f1f1f] border border-[#1f1f1f]\" data-kid=\"109\">\n                        \n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between industrial-corner relative\" data-kid=\"110\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"111\">Auto Detailing</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"112\">05</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"113\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"114\">Electrical Repair</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"115\">06</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"116\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"117\">Engine Repair</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"118\">07</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"119\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"120\">General Inspection</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"121\">08</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"122\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"123\">Major Service</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"124\">09</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"125\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"126\">Minor Service</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"127\">10</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"128\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"129\">Oil Change</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"130\">11</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"131\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"132\">Pre-Purchase</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"133\">12</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"134\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"135\">Rear Shocks</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"136\">13</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"137\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"138\">Scooters Maint.</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"139\">14</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"140\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"141\">Suspension</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"142\">15</span>\n                        </div>\n                        <div class=\"group bg-[#000000] p-10 hover:bg-[#0a0a0a] transition-all flex items-center justify-between relative\" data-kid=\"143\">\n                            <span class=\"text-xl font-black uppercase tracking-tight text-white group-hover:text-[#ff0000] transition-colors\" data-kid=\"144\">Tyres</span>\n                            <span class=\"text-[#ff0000] font-mono text-lg font-black\" data-kid=\"145\">16</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-8 md:px-24 relative overflow-hidden border-b border-[#1f1f1f]\" data-kid=\"146\">\n        <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-px h-32 bg-[#ff0000]\" data-kid=\"147\"></div>\n        \n        <div class=\"flex flex-col lg:flex-row lg:items-end justify-between mb-24 gap-8\" data-kid=\"148\">\n            <div class=\"max-w-3xl\" data-kid=\"149\">\n                <span class=\"text-[#ff0000] font-mono text-xl font-bold tracking-[0.5em] uppercase mb-6 block\" data-kid=\"150\">03 // INVENTORY_ASSETS</span>\n                <h2 class=\"text-8xl lg:text-9xl font-black uppercase tracking-[-0.08em] leading-[0.75]\" data-kid=\"151\">Genuine <br data-kid=\"152\">Spares Matrix</h2>\n            </div>\n            <p class=\"text-[#ffffff] text-sm uppercase tracking-[0.3em] font-black max-w-xs border-l-2 border-[#ff0000] pl-6 py-4\" data-kid=\"153\">Direct retail integration for BS6 specialist components and performance lubrication.</p>\n        </div>\n\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-[#1f1f1f] border border-[#1f1f1f]\" data-kid=\"154\">\n            <div class=\"lg:col-span-2 p-16 bg-[#0a0a0a] group hover:bg-[#000000] transition-all relative overflow-hidden flex flex-col items-center justify-center text-center\" data-kid=\"155\">\n                <div class=\"absolute top-0 right-0 p-6 font-mono text-sm opacity-20 group-hover:opacity-100 group-hover:text-[#ff0000]\" data-kid=\"156\">ASSET_001</div>\n                <h3 class=\"text-5xl font-black uppercase tracking-tighter text-white mb-6\" data-kid=\"157\">Exide <br data-kid=\"158\"><span class=\"text-[#ff0000]\" data-kid=\"159\">Energy</span> Core</h3>\n                <p class=\"text-[#999999] text-[10px] font-bold uppercase tracking-[0.4em]\" data-kid=\"160\">High-Amperage OEM Certified Units</p>\n            </div>\n            <div class=\"p-10 bg-[#0a0a0a] group hover:bg-[#ff0000] transition-all text-center flex flex-col items-center justify-center gap-6\" data-kid=\"161\">\n                <span class=\"text-[#999999] group-hover:text-white/50 font-mono text-xs\" data-kid=\"162\">INV-01</span>\n                <span class=\"text-sm font-black uppercase tracking-[0.2em] group-hover:text-white\" data-kid=\"163\">Tyres & <br data-kid=\"164\">Tubes</span>\n            </div>\n            <div class=\"p-10 bg-[#0a0a0a] group hover:bg-[#ff0000] transition-all text-center flex flex-col items-center justify-center gap-6\" data-kid=\"165\">\n                <span class=\"text-[#999999] group-hover:text-white/50 font-mono text-xs\" data-kid=\"166\">INV-02</span>\n                <span class=\"text-sm font-black uppercase tracking-[0.2em] group-hover:text-white\" data-kid=\"167\">Studs <br data-kid=\"168\">Helmets</span>\n            </div>\n            <div class=\"p-10 bg-[#0a0a0a] group hover:bg-[#ff0000] transition-all text-center flex flex-col items-center justify-center gap-6\" data-kid=\"169\">\n                <span class=\"text-[#999999] group-hover:text-white/50 font-mono text-xs\" data-kid=\"170\">INV-03</span>\n                <span class=\"text-sm font-black uppercase tracking-[0.2em] group-hover:text-white\" data-kid=\"171\">Castrol <br data-kid=\"172\">Lubricants</span>\n            </div>\n            <div class=\"p-10 bg-[#0a0a0a] group hover:bg-[#ff0000] transition-all text-center flex flex-col items-center justify-center gap-6\" data-kid=\"173\">\n                <span class=\"text-[#999999] group-hover:text-white/50 font-mono text-xs\" data-kid=\"174\">INV-04</span>\n                <span class=\"text-sm font-black uppercase tracking-[0.2em] group-hover:text-white\" data-kid=\"175\">BS6 <br data-kid=\"176\">Specials</span>\n            </div>\n            <div class=\"p-10 bg-[#0a0a0a] group hover:bg-[#ff0000] transition-all text-center flex flex-col items-center justify-center gap-6\" data-kid=\"177\">\n                <span class=\"text-[#999999] group-hover:text-white/50 font-mono text-xs\" data-kid=\"178\">INV-05</span>\n                <span class=\"text-sm font-black uppercase tracking-[0.2em] group-hover:text-white\" data-kid=\"179\">Seat <br data-kid=\"180\">Covers</span>\n            </div>\n            <div class=\"p-10 bg-[#0a0a0a] group hover:bg-[#ff0000] transition-all text-center flex flex-col items-center justify-center gap-6\" data-kid=\"181\">\n                <span class=\"text-[#999999] group-hover:text-white/50 font-mono text-xs\" data-kid=\"182\">INV-06</span>\n                <span class=\"text-sm font-black uppercase tracking-[0.2em] group-hover:text-white\" data-kid=\"183\">Mobile <br data-kid=\"184\">Holders</span>\n            </div>\n            <div class=\"p-10 bg-[#0a0a0a] group hover:bg-[#ff0000] transition-all text-center flex flex-col items-center justify-center gap-6\" data-kid=\"185\">\n                <span class=\"text-[#999999] group-hover:text-white/50 font-mono text-xs\" data-kid=\"186\">INV-07</span>\n                <span class=\"text-sm font-black uppercase tracking-[0.2em] group-hover:text-white\" data-kid=\"187\">Retail <br data-kid=\"188\">Components</span>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-[#0a0a0a] border-t border-[#1f1f1f] pt-24 pb-12 px-8 md:px-24\" data-kid=\"189\">\n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-24\" data-kid=\"190\">\n            <div class=\"col-span-1 lg:col-span-1\" data-kid=\"191\">\n                <div class=\"flex items-center gap-3 mb-8\" data-kid=\"192\">\n                    <div class=\"w-8 h-8 bg-[#ff0000] flex items-center justify-center font-bold italic text-white rounded-xs\" data-kid=\"193\">K</div>\n                    <span class=\"font-bold tracking-tighter text-xl uppercase\" data-kid=\"194\">Krishna <span class=\"text-[#ff0000]\" data-kid=\"195\">Automobile</span></span>\n                </div>\n                <p class=\"text-[#999999] text-sm leading-relaxed mb-8 uppercase tracking-tighter\" data-kid=\"196\">\n                    Mira Road East's most trusted repair shop since 2009. Precision servicing for all major brands.\n                </p>\n                <div class=\"flex gap-4\" data-kid=\"197\">\n                    <a href=\"#\" class=\"w-10 h-10 border border-[#1f1f1f] flex items-center justify-center rounded-full hover:border-[#ff0000] transition-colors\" data-kid=\"198\"><i class=\"fa-brands fa-whatsapp\" data-kid=\"199\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 border border-[#1f1f1f] flex items-center justify-center rounded-full hover:border-[#ff0000] transition-colors\" data-kid=\"200\"><i class=\"fa-brands fa-instagram\" data-kid=\"201\"></i></a>\n                </div>\n            </div>\n\n            <div data-kid=\"202\">\n                <h4 class=\"text-sm font-bold uppercase tracking-[0.2em] mb-8 text-white\" data-kid=\"203\">Contact</h4>\n                <div class=\"space-y-4 text-sm text-[#999999]\" data-kid=\"204\">\n                    <p class=\"hover:text-white transition-colors\" data-kid=\"205\">093222 45569</p>\n                    <p class=\"hover:text-white transition-colors\" data-kid=\"206\">090827 44210</p>\n                    <p class=\"leading-relaxed\" data-kid=\"207\">Shop No.11, Gaurav sankalp chintan 11, hatkesh, Mira Road East, 401107</p>\n                </div>\n            </div>\n\n            <div data-kid=\"208\">\n                <h4 class=\"text-sm font-bold uppercase tracking-[0.2em] mb-8 text-white\" data-kid=\"209\">Operation</h4>\n                <div class=\"space-y-4 text-sm text-[#999999]\" data-kid=\"210\">\n                    <div class=\"flex justify-between border-b border-[#1f1f1f] pb-2\" data-kid=\"211\">\n                        <span data-kid=\"212\">MON-SUN</span>\n                        <span class=\"text-white\" data-kid=\"213\">9:00 AM - 9:30 PM</span>\n                    </div>\n                    <p class=\"text-[10px] uppercase font-bold text-[#ff0000] pt-4\" data-kid=\"214\">No Appointments Required — Walk-in!</p>\n                </div>\n            </div>\n\n            <div data-kid=\"215\">\n                <h4 class=\"text-sm font-bold uppercase tracking-[0.2em] mb-8 text-white\" data-kid=\"216\">Legal</h4>\n                <div class=\"space-y-4 text-sm text-[#999999] uppercase tracking-widest text-[10px]\" data-kid=\"217\">\n                    <a href=\"#\" class=\"block hover:text-white\" data-kid=\"218\">Insurance Claims</a>\n                    <a href=\"#\" class=\"block hover:text-white\" data-kid=\"219\">Free Legal Advice</a>\n                    <a href=\"#\" class=\"block hover:text-white\" data-kid=\"220\">Privacy Policy</a>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"flex flex-col md:flex-row justify-between items-center pt-8 border-t border-[#1f1f1f] text-[10px] text-[#999999] uppercase tracking-[0.2em]\" data-kid=\"221\">\n            <p data-kid=\"222\">© 2024 KRISHNA AUTOMOBILE. ALL RIGHTS RESERVED.</p>\n            <p data-kid=\"223\">DESIGNED FOR TECHNICAL EXCELLENCE</p>\n        </div>\n    </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"224\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"225\"></script>\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" data-kid=\"226\">\n\n<script data-kid=\"227\">\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initial load animations\n    window.addEventListener('load', () => {\n        gsap.from('header h1', {\n            y: 100,\n            opacity: 0,\n            duration: 1.2,\n            ease: \"power4.out\",\n            stagger: 0.2\n        });\n\n        gsap.from('.service-card-anim', {\n            scrollTrigger: {\n                trigger: '.service-card-anim',\n                start: \"top 80%\",\n            },\n            y: 50,\n            opacity: 0,\n            duration: 0.8,\n            stagger: 0.1,\n            ease: \"power2.out\"\n        });\n\n        // Sticky scrolling effects\n        gsap.to('.grid-pattern', {\n            scrollTrigger: {\n                trigger: 'body',\n                start: 'top top',\n                end: 'bottom bottom',\n                scrub: true\n            },\n            backgroundPosition: '0px 1000px'\n        });\n    });\n</script>\n",
