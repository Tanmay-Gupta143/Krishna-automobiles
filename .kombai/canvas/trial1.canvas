      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');\n\n  :root {\n    --background: #000000;\n    --surface: #0a0a0a;\n    --primary: #ffffff;\n    --secondary: #999999;\n    --accent: #ff0000;\n    --border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    background-color: var(--background);\n    color: var(--primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .grid-bg {\n    background-image: linear-gradient(var(--border) 1px, transparent 1px),\n      linear-gradient(90deg, var(--border) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .text-stroke {\n    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.3);\n    color: transparent;\n    letter-spacing: -0.04em;\n  }\n\n  .marquee-content {\n    animation: marquee 30s linear infinite;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .tech-line {\n    background: repeating-linear-gradient(90deg, var(--border), var(--border) 1px, transparent 1px, transparent 10px);\n  }\n\n  .lenis.lenis-smooth {\n    scroll-behavior: auto !important;\n  }\n</style>\n\n<div class=\"relative min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <div class=\"fixed inset-0 grid-bg pointer-events-none opacity-20\" data-kid=\"2\"></div>\n\n  \n  <nav class=\"sticky top-0 z-50 w-full border-b border-[var(--border)] bg-black/80 backdrop-blur-md\" data-kid=\"3\">\n    <div class=\"max-w-[1440px] mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"4\">\n      <div class=\"flex items-center gap-3\" data-kid=\"5\">\n        <div class=\"w-8 h-8 bg-[var(--accent)] rounded-full flex items-center justify-center\" data-kid=\"6\">\n          <span class=\"text-black font-bold text-xs\" data-kid=\"7\">K</span>\n        </div>\n        <span class=\"font-bold tracking-tighter text-xl uppercase\" data-kid=\"8\">Krishna Automobile</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8\" data-kid=\"9\">\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-[0.2em] text-[var(--secondary)] hover:text-white transition-colors\" data-kid=\"10\">Home</a>\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-[0.2em] text-[var(--secondary)] hover:text-white transition-colors\" data-kid=\"11\">Services</a>\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-[0.2em] text-[var(--secondary)] hover:text-white transition-colors\" data-kid=\"12\">Insurance</a>\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-[0.2em] text-white\" data-kid=\"13\">About Us</a>\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-[0.2em] text-[var(--secondary)] hover:text-white transition-colors\" data-kid=\"14\">Contact</a>\n      </div>\n      <button class=\"rounded-full px-6 py-2 border border-white text-xs font-mono uppercase tracking-widest hover:bg-white hover:text-black transition-all\" data-kid=\"15\">\n        Book Now\n      </button>\n    </div>\n  </nav>\n\n  \n  <section id=\"hero\" class=\"relative pt-40 pb-32 px-6 border-b border-[var(--border)] overflow-hidden\" data-kid=\"16\">\n    <div class=\"absolute top-0 left-0 w-full h-[1px] tech-line opacity-30\" data-kid=\"17\"></div>\n    <div class=\"max-w-[1440px] mx-auto relative z-10\" data-kid=\"18\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16\" data-kid=\"19\">\n        <div class=\"lg:col-span-1 border-r border-[var(--border)] hidden lg:block\" data-kid=\"20\">\n            <span class=\"text-7xl font-bold tracking-tighter opacity-10 sticky top-40 block -rotate-90 origin-left translate-x-14\" data-kid=\"21\">01</span>\n        </div>\n        <div class=\"lg:col-span-11\" data-kid=\"22\">\n          <div class=\"mb-12 flex items-center gap-6\" data-kid=\"23\">\n            <div class=\"flex gap-2\" data-kid=\"24\">\n                <span class=\"px-2 py-0.5 border border-[var(--accent)] text-[10px] font-mono text-[var(--accent)] uppercase tracking-widest\" data-kid=\"25\">Est. 2009</span>\n                <span class=\"px-2 py-0.5 border border-[var(--border)] text-[10px] font-mono text-[var(--secondary)] uppercase tracking-widest\" data-kid=\"26\">Mira Road East</span>\n            </div>\n            <div class=\"h-[1px] grow tech-line opacity-20\" data-kid=\"27\"></div>\n          </div>\n          \n          <h1 class=\"text-[clamp(4rem,12vw,10rem)] font-bold tracking-[-0.07em] leading-[0.8] uppercase mb-20 reveal-title\" data-kid=\"28\">\n            Our 15+ Year<br data-kid=\"29\">\n            <span class=\"text-stroke\" data-kid=\"30\">Legacy</span> In<br data-kid=\"31\">\n            <span class=\"text-[var(--accent)]\" data-kid=\"32\">Mira Road</span> East\n          </h1>\n\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-20\" data-kid=\"33\">\n            <div class=\"max-w-xl\" data-kid=\"34\">\n                <p class=\"text-[var(--secondary)] text-2xl leading-[1.4] mb-8 font-medium\" data-kid=\"35\">\n                  Krishna Automobile is a cornerstone of reliability. Since 2009, we've specialized in the technical heartbeat of Mumbai's riders.\n                </p>\n                <div class=\"flex items-center gap-4\" data-kid=\"36\">\n                  <div class=\"w-12 h-12 border border-[var(--accent)] rounded-full flex items-center justify-center\" data-kid=\"37\">\n                    <div class=\"w-2 h-2 bg-[var(--accent)] rounded-full animate-ping\" data-kid=\"38\"></div>\n                  </div>\n                  <span class=\"text-xs font-mono uppercase tracking-[0.3em] text-[var(--secondary)]\" data-kid=\"39\">System: Operational / 09:00 - 21:30</span>\n                </div>\n            </div>\n            <div class=\"border-l border-[var(--border)] pl-12 hidden md:block\" data-kid=\"40\">\n                <div class=\"space-y-4\" data-kid=\"41\">\n                    <div class=\"flex justify-between border-b border-[var(--border)] py-2\" data-kid=\"42\">\n                        <span class=\"text-[10px] font-mono text-[var(--secondary)] uppercase\" data-kid=\"43\">Founder</span>\n                        <span class=\"text-[10px] font-mono uppercase\" data-kid=\"44\">Krishna Shrestha</span>\n                    </div>\n                    <div class=\"flex justify-between border-b border-[var(--border)] py-2\" data-kid=\"45\">\n                        <span class=\"text-[10px] font-mono text-[var(--secondary)] uppercase\" data-kid=\"46\">Specialization</span>\n                        <span class=\"text-[10px] font-mono uppercase\" data-kid=\"47\">Internal Combustion</span>\n                    </div>\n                    <div class=\"flex justify-between border-b border-[var(--border)] py-2\" data-kid=\"48\">\n                        <span class=\"text-[10px] font-mono text-[var(--secondary)] uppercase\" data-kid=\"49\">Location</span>\n                        <span class=\"text-[10px] font-mono uppercase\" data-kid=\"50\">Hatkesh, Mira Road</span>\n                    </div>\n                </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"py-6 border-b border-[var(--border)] overflow-hidden bg-[var(--surface)]\" data-kid=\"51\">\n    <div class=\"marquee-content flex gap-12 whitespace-nowrap\" data-kid=\"52\">\n      <div class=\"flex items-center gap-12\" data-kid=\"53\">\n        <span class=\"text-sm font-mono uppercase tracking-[0.3em] flex items-center gap-4\" data-kid=\"54\">\n          <span class=\"w-1.5 h-1.5 bg-[var(--accent)] rounded-full\" data-kid=\"55\"></span>\n          Honda Activa Specialist\n        </span>\n        <span class=\"text-sm font-mono uppercase tracking-[0.3em] flex items-center gap-4\" data-kid=\"56\">\n          <span class=\"w-1.5 h-1.5 bg-[var(--accent)] rounded-full\" data-kid=\"57\"></span>\n          Royal Enfield Expert\n        </span>\n        <span class=\"text-sm font-mono uppercase tracking-[0.3em] flex items-center gap-4\" data-kid=\"58\">\n          <span class=\"w-1.5 h-1.5 bg-[var(--accent)] rounded-full\" data-kid=\"59\"></span>\n          Yamaha Performance\n        </span>\n        <span class=\"text-sm font-mono uppercase tracking-[0.3em] flex items-center gap-4\" data-kid=\"60\">\n          <span class=\"w-1.5 h-1.5 bg-[var(--accent)] rounded-full\" data-kid=\"61\"></span>\n          Suzuki & TVS Servicing\n        </span>\n      </div>\n      \n      <div class=\"flex items-center gap-12\" data-kid=\"62\">\n        <span class=\"text-sm font-mono uppercase tracking-[0.3em] flex items-center gap-4\" data-kid=\"63\">\n          <span class=\"w-1.5 h-1.5 bg-[var(--accent)] rounded-full\" data-kid=\"64\"></span>\n          Honda Activa Specialist\n        </span>\n        <span class=\"text-sm font-mono uppercase tracking-[0.3em] flex items-center gap-4\" data-kid=\"65\">\n          <span class=\"w-1.5 h-1.5 bg-[var(--accent)] rounded-full\" data-kid=\"66\"></span>\n          Royal Enfield Expert\n        </span>\n        <span class=\"text-sm font-mono uppercase tracking-[0.3em] flex items-center gap-4\" data-kid=\"67\">\n          <span class=\"w-1.5 h-1.5 bg-[var(--accent)] rounded-full\" data-kid=\"68\"></span>\n          Yamaha Performance\n        </span>\n        <span class=\"text-sm font-mono uppercase tracking-[0.3em] flex items-center gap-4\" data-kid=\"69\">\n          <span class=\"w-1.5 h-1.5 bg-[var(--accent)] rounded-full\" data-kid=\"70\"></span>\n          Suzuki & TVS Servicing\n        </span>\n      </div>\n    </div>\n  </div>\n\n  \n  <section class=\"border-b border-[var(--border)] relative overflow-hidden\" data-kid=\"71\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-2 min-h-screen\" data-kid=\"72\">\n        <div class=\"border-r border-[var(--border)] p-12 lg:p-24 flex flex-col justify-center\" data-kid=\"73\">\n            <span class=\"text-xs font-mono tracking-[0.4em] uppercase text-[var(--accent)] mb-12 block\" data-kid=\"74\">02 History</span>\n            <h2 class=\"text-6xl font-bold tracking-tight uppercase leading-[0.9] mb-12\" data-kid=\"75\">Expertise<br data-kid=\"76\">Refined over<br data-kid=\"77\">Fifteen Years</h2>\n            <div class=\"space-y-8 max-w-lg\" data-kid=\"78\">\n                <p class=\"text-[var(--secondary)] text-xl leading-relaxed\" data-kid=\"79\">\n                  Since 2009, Krishna Automobile has been committed to keeping your vehicle running smoothly and safely. Whether you need regular servicing, pickup issues fixed, brake maintenance, or major repairs, our experienced mechanics provide trusted bike servicing and repair.\n                </p>\n                <div class=\"pt-8 border-t border-[var(--border)]\" data-kid=\"80\">\n                    <div class=\"grid grid-cols-2 gap-8\" data-kid=\"81\">\n                        <div class=\"p-6 border border-[var(--border)] bg-[var(--surface)]\" data-kid=\"82\">\n                            <span class=\"text-4xl font-bold block mb-1 tracking-tighter text-[var(--accent)]\" data-kid=\"83\">15+</span>\n                            <span class=\"text-[10px] font-mono uppercase tracking-widest text-[var(--secondary)]\" data-kid=\"84\">Years Legacy</span>\n                        </div>\n                        <div class=\"p-6 border border-[var(--border)] bg-[var(--surface)]\" data-kid=\"85\">\n                            <span class=\"text-4xl font-bold block mb-1 tracking-tighter\" data-kid=\"86\">10k+</span>\n                            <span class=\"text-[10px] font-mono uppercase tracking-widest text-[var(--secondary)]\" data-kid=\"87\">Vehicle Units</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div class=\"relative bg-[var(--surface)] group overflow-hidden h-[600px] lg:h-auto\" data-kid=\"88\">\n            <div class=\"absolute inset-0 grid-bg opacity-10\" data-kid=\"89\"></div>\n            <img src=\"https://images.unsplash.com/photo-1615906659973-5a315f2e10c1?auto=format&w=1200&q=80&fit=crop\" alt=\"Precision Detail\" class=\"w-full h-full object-cover grayscale opacity-70 reveal-image\" decoding=\"async\" loading=\"lazy\" data-kid=\"90\">\n            <div class=\"absolute top-12 left-12 p-4 border border-white/10 bg-black/40 backdrop-blur-md\" data-kid=\"91\">\n                <span class=\"text-[8px] font-mono uppercase tracking-[0.3em] block mb-2 opacity-50\" data-kid=\"92\">Component_View</span>\n                <span class=\"text-[10px] font-mono uppercase tracking-widest\" data-kid=\"93\">Internal combustion inspection</span>\n            </div>\n        </div>\n    </div>\n  </section>\n\n  \n  <section class=\"border-b border-[var(--border)] bg-black overflow-hidden\" data-kid=\"94\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-12\" data-kid=\"95\">\n        <div class=\"lg:col-span-6 relative aspect-video lg:aspect-auto\" data-kid=\"96\">\n            <img src=\"https://images.unsplash.com/photo-1558981403-c5f9899a28bc?auto=format&w=1200&q=80&fit=crop\" alt=\"Workshop Environment\" class=\"w-full h-full object-cover grayscale opacity-60 reveal-image\" decoding=\"async\" loading=\"lazy\" data-kid=\"97\">\n            <div class=\"absolute inset-0 bg-gradient-to-r from-black via-transparent to-transparent\" data-kid=\"98\"></div>\n        </div>\n        <div class=\"lg:col-span-6 p-12 lg:p-24 flex flex-col justify-center border-l border-[var(--border)] relative overflow-hidden\" data-kid=\"99\">\n            <div class=\"absolute top-0 right-0 w-24 h-24 tech-line opacity-10\" data-kid=\"100\"></div>\n            <div class=\"mb-12\" data-kid=\"101\">\n                <div class=\"w-16 h-0.5 bg-[var(--accent)] mb-6\" data-kid=\"102\"></div>\n                <h3 class=\"text-6xl font-bold tracking-tight uppercase leading-[0.85]\" data-kid=\"103\">Inclusivity<br data-kid=\"104\">at our core</h3>\n            </div>\n            <p class=\"text-[var(--secondary)] text-xl leading-relaxed max-w-lg mb-12\" data-kid=\"105\">\n                We operate an inclusive, welcoming shop that proudly welcomes LGBTQ community members. For us, technical excellence goes hand-in-hand with human respect. Everyone is welcome in our workshop.\n            </p>\n            <div class=\"flex flex-wrap gap-4\" data-kid=\"106\">\n                <span class=\"px-6 py-3 border border-[var(--border)] rounded-full text-[10px] font-mono uppercase tracking-widest\" data-kid=\"107\">Safe Space Certified</span>\n                <span class=\"px-6 py-3 border border-[var(--accent)] rounded-full text-[10px] font-mono uppercase tracking-widest text-[var(--accent)]\" data-kid=\"108\">Inclusive Garage</span>\n            </div>\n        </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6 bg-[var(--surface)] border-b border-[var(--border)]\" data-kid=\"109\">\n    <div class=\"max-w-[1440px] mx-auto\" data-kid=\"110\">\n        <div class=\"flex justify-between items-end mb-24 pb-8 border-b border-[var(--border)]\" data-kid=\"111\">\n            <div data-kid=\"112\">\n                <span class=\"text-xs font-mono tracking-[0.4em] uppercase text-[var(--secondary)] block mb-4\" data-kid=\"113\">03 Protocol</span>\n                <h2 class=\"text-5xl font-bold tracking-tight uppercase\" data-kid=\"114\">Technical Workflow</h2>\n            </div>\n            <span class=\"text-xs font-mono uppercase text-white/20 hidden md:block\" data-kid=\"115\">System_Revision: v2.0.9</span>\n        </div>\n\n        <div class=\"space-y-[1px] bg-[var(--border)] border border-[var(--border)]\" data-kid=\"116\">\n            <div class=\"bg-black p-12 lg:px-16 flex flex-col md:flex-row md:items-center gap-12 group hover:bg-[#050505] transition-colors relative\" data-kid=\"117\">\n                <div class=\"absolute left-0 top-0 w-1 h-full bg-[var(--accent)] scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-500\" data-kid=\"118\"></div>\n                <span class=\"text-5xl font-bold opacity-10 font-mono\" data-kid=\"119\">01</span>\n                <div class=\"flex-1\" data-kid=\"120\">\n                    <h3 class=\"text-3xl font-bold uppercase mb-4 tracking-tighter\" data-kid=\"121\">Diagnosis & Scan</h3>\n                    <p class=\"text-[var(--secondary)] max-w-2xl leading-relaxed\" data-kid=\"122\">Every vehicle undergoes a 32-point inspection using modern diagnostic tools to ensure no hidden faults. Complete log reports generated.</p>\n                </div>\n                <div class=\"w-24 h-24 border border-[var(--border)] flex items-center justify-center opacity-20 group-hover:opacity-100 transition-opacity\" data-kid=\"123\">\n                    <span class=\"text-[10px] font-mono\" data-kid=\"124\">SCAN_INIT</span>\n                </div>\n            </div>\n            <div class=\"bg-black p-12 flex flex-col md:flex-row md:items-center gap-12 group hover:bg-[var(--surface)] transition-colors\" data-kid=\"125\">\n                <span class=\"text-5xl font-bold opacity-10 font-mono\" data-kid=\"126\">02</span>\n                <div class=\"flex-1\" data-kid=\"127\">\n                    <h3 class=\"text-3xl font-bold uppercase mb-4\" data-kid=\"128\">Precision Componentry</h3>\n                    <p class=\"text-[var(--secondary)] max-w-2xl\" data-kid=\"129\">We only stock and fit genuine spares, from Exide batteries to Castrol engine oils, ensuring maximum longevity and performance.</p>\n                </div>\n                <div class=\"w-24 h-24 border border-[var(--border)] flex items-center justify-center opacity-20 group-hover:opacity-100 transition-opacity\" data-kid=\"130\">\n                    <span class=\"text-[10px] font-mono\" data-kid=\"131\">GEN_PARTS</span>\n                </div>\n            </div>\n            <div class=\"bg-black p-12 flex flex-col md:flex-row md:items-center gap-12 group hover:bg-[var(--surface)] transition-colors\" data-kid=\"132\">\n                <span class=\"text-5xl font-bold opacity-10 font-mono\" data-kid=\"133\">03</span>\n                <div class=\"flex-1\" data-kid=\"134\">\n                    <h3 class=\"text-3xl font-bold uppercase mb-4\" data-kid=\"135\">Deployment & Delivery</h3>\n                    <p class=\"text-[var(--secondary)] max-w-2xl\" data-kid=\"136\">From complex engine overhauls to detailed washing, our final checks ensure your bike leaves the workshop in showroom condition.</p>\n                </div>\n                <div class=\"w-24 h-24 border border-[var(--border)] flex items-center justify-center opacity-20 group-hover:opacity-100 transition-opacity\" data-kid=\"137\">\n                    <span class=\"text-[10px] font-mono\" data-kid=\"138\">DEPLOY_OK</span>\n                </div>\n            </div>\n        </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"mt-auto border-t border-[var(--border)] py-20 px-6\" data-kid=\"139\">\n    <div class=\"max-w-[1440px] mx-auto\" data-kid=\"140\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-4 gap-12 mb-20\" data-kid=\"141\">\n        <div class=\"lg:col-span-2\" data-kid=\"142\">\n            <div class=\"flex items-center gap-3 mb-8\" data-kid=\"143\">\n                <div class=\"w-10 h-10 bg-[var(--accent)] rounded-full flex items-center justify-center\" data-kid=\"144\">\n                    <span class=\"text-black font-bold text-sm\" data-kid=\"145\">K</span>\n                </div>\n                <span class=\"font-bold tracking-tighter text-2xl uppercase\" data-kid=\"146\">Krishna Automobile</span>\n            </div>\n            <p class=\"text-[var(--secondary)] max-w-sm mb-8\" data-kid=\"147\">\n                Shop No.11, Gaurav sankalp chintan 11, hatkesh, Mira Road East, Thane(Mumbai), Maharashtra, 401107, IN.\n            </p>\n            <div class=\"flex gap-4\" data-kid=\"148\">\n                <a href=\"#\" class=\"w-10 h-10 border border-[var(--border)] rounded-full flex items-center justify-center hover:border-white transition-colors\" data-kid=\"149\">\n                    <i class=\"fab fa-whatsapp\" data-kid=\"150\"></i>\n                </a>\n                <a href=\"#\" class=\"w-10 h-10 border border-[var(--border)] rounded-full flex items-center justify-center hover:border-white transition-colors\" data-kid=\"151\">\n                    <i class=\"fab fa-instagram\" data-kid=\"152\"></i>\n                </a>\n                <a href=\"#\" class=\"w-10 h-10 border border-[var(--border)] rounded-full flex items-center justify-center hover:border-white transition-colors\" data-kid=\"153\">\n                    <i class=\"fab fa-facebook-f\" data-kid=\"154\"></i>\n                </a>\n            </div>\n        </div>\n        <div data-kid=\"155\">\n            <h5 class=\"text-xs font-mono uppercase tracking-widest mb-8 text-white\" data-kid=\"156\">Navigation</h5>\n            <ul class=\"space-y-4\" data-kid=\"157\">\n                <li data-kid=\"158\"><a href=\"#\" class=\"text-[var(--secondary)] hover:text-white text-sm\" data-kid=\"159\">Home</a></li>\n                <li data-kid=\"160\"><a href=\"#\" class=\"text-[var(--secondary)] hover:text-white text-sm\" data-kid=\"161\">Services</a></li>\n                <li data-kid=\"162\"><a href=\"#\" class=\"text-[var(--secondary)] hover:text-white text-sm\" data-kid=\"163\">Insurance</a></li>\n                <li data-kid=\"164\"><a href=\"#\" class=\"text-[var(--secondary)] hover:text-white text-sm\" data-kid=\"165\">About Us</a></li>\n            </ul>\n        </div>\n        <div data-kid=\"166\">\n            <h5 class=\"text-xs font-mono uppercase tracking-widest mb-8 text-white\" data-kid=\"167\">Contact</h5>\n            <ul class=\"space-y-4\" data-kid=\"168\">\n                <li class=\"text-[var(--secondary)] text-sm\" data-kid=\"169\">093222 45569</li>\n                <li class=\"text-[var(--secondary)] text-sm\" data-kid=\"170\">090827 44210</li>\n                <li class=\"text-[var(--secondary)] text-sm\" data-kid=\"171\">9:00 AM – 9:30 PM</li>\n                <li class=\"text-[var(--secondary)] text-sm\" data-kid=\"172\">Open 7 Days a Week</li>\n            </ul>\n        </div>\n      </div>\n      <div class=\"flex flex-col md:flex-row justify-between items-center pt-10 border-t border-[var(--border)]\" data-kid=\"173\">\n        <p class=\"text-[var(--secondary)] text-xs font-mono uppercase tracking-widest mb-4 md:mb-0\" data-kid=\"174\">\n            © 2024 KRISHNA AUTOMOBILE. ALL RIGHTS RESERVED.\n        </p>\n        <div class=\"flex gap-8\" data-kid=\"175\">\n            <a href=\"#\" class=\"text-[var(--secondary)] hover:text-white text-xs font-mono uppercase tracking-widest\" data-kid=\"176\">Privacy Policy</a>\n            <a href=\"#\" class=\"text-[var(--secondary)] hover:text-white text-xs font-mono uppercase tracking-widest\" data-kid=\"177\">Terms of Service</a>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"178\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"179\"></script>\n<script type=\"module\" data-kid=\"180\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // 1. Initialize Lenis\n  const lenis = new Lenis();\n\n  // 2. Sync ScrollTrigger with Lenis\n  lenis.on('scroll', ScrollTrigger.update);\n  \n  // 3. Add Lenis to GSAP Ticker\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  \n  // 4. Disable GSAP lag smoothing for better sync\n  gsap.ticker.lagSmoothing(0);\n\n  // GSAP Animations\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Title Entrance\n  gsap.from('.reveal-title', {\n    y: 120,\n    opacity: 0,\n    duration: 1.5,\n    ease: \"expo.out\",\n    delay: 0.3\n  });\n\n  // Image Entrance Animations\n  gsap.utils.toArray('.reveal-image').forEach(img => {\n    gsap.from(img, {\n        scrollTrigger: {\n            trigger: img,\n            start: \"top 80%\"\n        },\n        scale: 1.2,\n        opacity: 0,\n        duration: 1.5,\n        ease: \"expo.out\"\n    });\n  });\n\n  // Parallax for all images (No CSS Transitions on these!)\n  gsap.utils.toArray('.reveal-image').forEach(img => {\n    gsap.to(img, {\n      scrollTrigger: {\n        trigger: img,\n        start: \"top bottom\",\n        end: \"bottom top\",\n        scrub: true\n      },\n      y: -60,\n      ease: \"none\"\n    });\n  });\n\n  // Section index animation\n  gsap.utils.toArray('section span.opacity-10').forEach(el => {\n    gsap.to(el, {\n        scrollTrigger: {\n            trigger: el,\n            start: \"top bottom\",\n            scrub: 1\n        },\n        y: 100\n    });\n  });\n</script>\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" data-kid=\"181\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"182\">\n",
