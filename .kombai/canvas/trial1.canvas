      "html": "<style data-kombai-theme>:root{--k-color-primary:#ffffff;--k-color-primary-hover:#f0f0f0;--k-color-secondary:#999999;--k-color-bg-page:#000000;--k-color-bg-surface:#0a0a0a;--k-color-bg-surface-hover:#111111;--k-color-text-primary:#ffffff;--k-color-text-secondary:#999999;--k-color-text-muted:#666666;--k-color-border:#1f1f1f;--k-color-border-hover:#333333;--k-color-accent:#ff0000;--k-color-success:#00ff00;--k-color-warning:#ffff00;--k-color-error:#ff0000;--k-font-family-heading:Inter, sans-serif;--k-font-family-body:Inter, sans-serif;--k-font-size-xs:0.75rem;--k-font-size-sm:0.875rem;--k-font-size-base:1rem;--k-font-size-lg:1.125rem;--k-font-size-xl:1.25rem;--k-font-size-2xl:1.5rem;--k-font-size-3xl:1.875rem;--k-font-size-4xl:2.25rem;--k-font-size-5xl:3rem;--k-font-weight-normal:400;--k-font-weight-medium:500;--k-font-weight-semibold:600;--k-font-weight-bold:700;--k-spacing-xs:0.25rem;--k-spacing-sm:0.5rem;--k-spacing-md:1rem;--k-spacing-lg:1.5rem;--k-spacing-xl:2rem;--k-spacing-2xl:3rem;--k-spacing-3xl:4rem;--k-radius-sm:0.125rem;--k-radius-md:0.75rem;--k-radius-lg:1rem;--k-radius-xl:1.5rem;--k-radius-full:9999px;--k-shadow-sm:0 1px 2px 0 rgba(0, 0, 0, 0.05);--k-shadow-md:0 4px 6px -1px rgba(0, 0, 0, 0.1);--k-shadow-lg:0 10px 15px -3px rgba(0, 0, 0, 0.1);--k-border-width-default:1px;--k-border-width-thick:2px;}</style><style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inconsolata:wght@400;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap');\n\n    :root {\n        --k-color-primary: #ffffff;\n        --k-color-secondary: #999999;\n        --k-color-bg-page: #000000;\n        --k-color-bg-surface: #0a0a0a;\n        --k-color-text-primary: #ffffff;\n        --k-color-accent: #ff0000;\n        --k-color-border: #1f1f1f;\n    }\n\n    .font-mono { font-family: 'Inconsolata', monospace; }\n    .font-sans { font-family: 'IBM Plex Sans', sans-serif; }\n\n    .grid-bg {\n        background-image: linear-gradient(rgba(255, 0, 0, 0.05) 1px, transparent 1px),\n                          linear-gradient(90deg, rgba(255, 0, 0, 0.05) 1px, transparent 1px);\n        background-size: 40px 40px;\n    }\n\n    .dashed-border-red {\n        border: 1px dashed rgba(255, 0, 0, 0.6);\n    }\n\n    .terminal-cursor {\n        width: 12px;\n        height: 24px;\n        background-color: var(--k-color-accent);\n        display: inline-block;\n        vertical-align: middle;\n        margin-left: 4px;\n    }\n\n    #project-list .service-item { cursor: none; }\n\n    /* Responsive connecting line for flow */\n    .flow-connector {\n        position: absolute;\n        top: 50%;\n        left: 0;\n        right: 0;\n        height: 2px;\n        background: var(--k-color-accent);\n        z-index: 0;\n        transform-origin: left;\n    }\n\n    @media (max-width: 768px) {\n        .flow-connector { display: none; }\n    }\n</style>\n\n<div class=\"grid-bg min-h-screen font-sans bg-black text-white selection:bg-red-600 selection:text-white\" data-kid=\"1\">\n    \n    <header class=\"fixed top-0 left-0 w-full z-50 border-b border-[var(--k-color-border)] bg-black/80 backdrop-blur-md px-6 py-4 flex justify-between items-center\" data-kid=\"2\">\n        <div class=\"flex items-center gap-4\" data-kid=\"3\">\n            <img src=\"/api/local/images/attachments/images/Screenshot 2026-06-22 173233-2026-06-22_12-03-09.png\" alt=\"Krishna Automobiles Logo\" class=\"h-8 grayscale invert brightness-200\" decoding=\"async\" loading=\"lazy\" data-kid=\"4\">\n            <span class=\"font-mono text-xs text-gray-500 tracking-widest hidden md:block uppercase\" data-kid=\"5\">Workshop Terminal // EST. 1994</span>\n        </div>\n        <nav class=\"font-mono text-xs flex gap-6 md:gap-8\" data-kid=\"6\">\n            <a href=\"#flow-chain\" class=\"hover:text-[var(--k-color-accent)] transition-colors\" data-kid=\"7\">[ PROCESS ]</a>\n            <a href=\"#project-list\" class=\"hover:text-[var(--k-color-accent)] transition-colors\" data-kid=\"8\">[ SERVICES ]</a>\n            <a href=\"#classic-table\" class=\"hover:text-[var(--k-color-accent)] transition-colors\" data-kid=\"9\">[ PRICING ]</a>\n        </nav>\n    </header>\n\n    \n    <section id=\"terminal-cli\" class=\"pt-32 pb-24 px-6 flex flex-col items-center justify-center min-h-[95vh]\" data-kid=\"10\">\n        <div class=\"w-full max-w-5xl border-2 border-[var(--k-color-border)] bg-[var(--k-color-bg-surface)] rounded-md overflow-hidden shadow-[32px_32px_0px_0px_rgba(255,0,0,0.03)]\" data-kid=\"11\">\n            <div class=\"bg-[var(--k-color-border)] px-4 py-3 flex items-center justify-between border-b border-black/40\" data-kid=\"12\">\n                <div class=\"flex gap-2\" data-kid=\"13\">\n                    <div class=\"w-3 h-3 rounded-full bg-[#FF5F56]\" data-kid=\"14\"></div>\n                    <div class=\"w-3 h-3 rounded-full bg-[#FFBD2E]\" data-kid=\"15\"></div>\n                    <div class=\"w-3 h-3 rounded-full bg-[#27C93F]\" data-kid=\"16\"></div>\n                </div>\n                <div class=\"text-gray-500 font-mono text-[10px] uppercase tracking-tighter\" data-kid=\"17\">Root@Krishna-Automobiles:~ diagnostics --force</div>\n                <div class=\"w-12\" data-kid=\"18\"></div>\n            </div>\n            <div class=\"p-8 md:p-12 font-mono\" data-kid=\"19\">\n                <div class=\"text-[var(--k-color-accent)] mb-6 flex items-center gap-2\" data-kid=\"20\">\n                    <span class=\"animate-pulse\" data-kid=\"21\">></span> INITIALIZE SETUP...\n                </div>\n                <div class=\"min-h-[14rem] md:min-h-[18rem]\" data-kid=\"22\">\n                    <h1 id=\"hero-typewriter\" class=\"text-4xl md:text-7xl font-bold uppercase leading-[1.1] tracking-tighter mb-8 max-w-4xl\" data-kid=\"23\"></h1>\n                </div>\n                <div class=\"flex flex-col md:flex-row gap-12 mt-12 items-end justify-between border-t border-white/5 pt-12\" data-kid=\"24\">\n                    <div class=\"max-w-md\" data-kid=\"25\">\n                        <p class=\"text-gray-400 font-sans text-lg leading-relaxed mb-8\" data-kid=\"26\">\n                            Precision-led engineering for high-performance motorcycles. We decode mechanical behavior through advanced data diagnostics.\n                        </p>\n                        <button class=\"bg-[var(--k-color-accent)] text-black px-10 py-5 font-bold uppercase hover:bg-white transition-colors border-b-4 border-r-4 border-black group flex items-center gap-3\" data-kid=\"27\">\n                            <span data-kid=\"28\">[ RUN_SYSTEM_DIAGNOSTICS ]</span>\n                            <span class=\"group-hover:translate-x-1 transition-transform\" data-kid=\"29\">→</span>\n                        </button>\n                    </div>\n                    <div class=\"text-right text-gray-500 text-[10px] uppercase leading-tight font-mono border-l border-white/10 pl-6\" data-kid=\"30\">\n                        System status: <span class=\"text-green-500 font-bold\" data-kid=\"31\">READY</span><br data-kid=\"32\">\n                        Kernal: 2.0.4-KRP-WORKSHOP<br data-kid=\"33\">\n                        Uptime: 24:09:55\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"flow-chain\" class=\"py-32 border-y border-[var(--k-color-border)] bg-black/40 relative\" data-kid=\"34\">\n        <div class=\"container mx-auto px-6\" data-kid=\"35\">\n            <div class=\"flex flex-col md:flex-row justify-between md:items-end mb-20 gap-4\" data-kid=\"36\">\n                <div data-kid=\"37\">\n                    <span class=\"text-[var(--k-color-accent)] font-mono text-sm block mb-2\" data-kid=\"38\">// SEQUENCE_STAGES</span>\n                    <h2 class=\"text-5xl font-bold font-mono uppercase tracking-tighter\" data-kid=\"39\">DIAGNOSTIC_FLOW</h2>\n                </div>\n                <div class=\"text-gray-500 font-mono text-xs uppercase tracking-widest\" data-kid=\"40\">Map Progress // Scroll to Scan</div>\n            </div>\n\n            <div class=\"relative\" data-kid=\"41\">\n                \n                <div class=\"flow-connector\" id=\"flow-line\" data-kid=\"42\"></div>\n\n                <div class=\"flex flex-col md:flex-row gap-6 relative z-10\" data-kid=\"43\">\n                    <div class=\"flow-step flex-1 bg-[var(--k-color-bg-surface)] border-2 border-[var(--k-color-border)] p-8 hover:bg-white/5 transition-colors\" data-kid=\"44\">\n                        <div class=\"font-mono text-[var(--k-color-accent)] text-xs mb-6 font-bold\" data-kid=\"45\">01_BASELINE</div>\n                        <h3 class=\"text-2xl font-bold font-mono uppercase mb-4\" data-kid=\"46\">Baseline</h3>\n                        <p class=\"text-gray-400 text-sm leading-relaxed\" data-kid=\"47\">Raw power measurement on the dyno. We establish your current performance profile and data logs.</p>\n                    </div>\n                    <div class=\"flow-step flex-1 bg-[var(--k-color-bg-surface)] border-2 border-[var(--k-color-border)] p-8 hover:bg-white/5 transition-colors\" data-kid=\"48\">\n                        <div class=\"font-mono text-[var(--k-color-accent)] text-xs mb-6 font-bold\" data-kid=\"49\">02_TEARDOWN</div>\n                        <h3 class=\"text-2xl font-bold font-mono uppercase mb-4\" data-kid=\"50\">Diagnostics</h3>\n                        <p class=\"text-gray-400 text-sm leading-relaxed\" data-kid=\"51\">Complete mechanical audit. Valve clearance checks, health scans, and deep cleaning sequences.</p>\n                    </div>\n                    <div class=\"flow-step flex-1 bg-[var(--k-color-bg-surface)] border-2 border-[var(--k-color-border)] p-8 hover:bg-white/5 transition-colors\" data-kid=\"52\">\n                        <div class=\"font-mono text-[var(--k-color-accent)] text-xs mb-6 font-bold\" data-kid=\"53\">03_BUILD</div>\n                        <h3 class=\"text-2xl font-bold font-mono uppercase mb-4\" data-kid=\"54\">Precision</h3>\n                        <p class=\"text-gray-400 text-sm leading-relaxed\" data-kid=\"55\">System integration of performance modules. Component blueprinting to exact factory race specs.</p>\n                    </div>\n                    <div class=\"flow-step flex-1 bg-[var(--k-color-accent)] border-2 border-black p-8 text-black shadow-[12px_12px_0px_0px_rgba(255,0,0,0.15)]\" data-kid=\"56\">\n                        <div class=\"font-mono text-black/60 text-xs mb-6 font-bold\" data-kid=\"57\">04_RELEASE</div>\n                        <h3 class=\"text-2xl font-bold font-mono uppercase mb-4\" data-kid=\"58\">Final Run</h3>\n                        <p class=\"text-black/80 text-sm leading-relaxed\" data-kid=\"59\">Validation runs, ECU remapping, and final certification. Performance ready for track deployment.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"project-list\" class=\"py-32 bg-black relative\" data-kid=\"60\">\n        <div class=\"container mx-auto px-6\" data-kid=\"61\">\n            <div class=\"mb-16\" data-kid=\"62\">\n                <span class=\"text-[var(--k-color-accent)] font-mono text-sm block mb-2\" data-kid=\"63\">// SYSTEM_MODULES</span>\n                <h2 class=\"text-5xl font-bold font-mono uppercase tracking-tighter\" data-kid=\"64\">CORE_INDEX</h2>\n            </div>\n            \n            <div class=\"border-t border-[var(--k-color-border)]\" data-kid=\"65\">\n                <div class=\"service-item group flex flex-col md:flex-row md:items-center justify-between py-12 border-b border-[var(--k-color-border)] transition-colors\" data-img=\"https://images.unsplash.com/photo-1669136048337-5daa3adef7b2?auto=format&w=800&q=80&fit=crop\" data-kid=\"66\">\n                    <div class=\"flex items-baseline gap-6\" data-kid=\"67\">\n                        <span class=\"text-[var(--k-color-accent)] font-mono text-2xl font-bold\" data-kid=\"68\">01.</span>\n                        <h3 class=\"text-5xl md:text-8xl font-bold font-mono uppercase tracking-tighter group-hover:text-[var(--k-color-accent)] transition-colors\" data-kid=\"69\">Valve Service</h3>\n                    </div>\n                    <div class=\"mt-4 md:mt-0 font-mono text-xs text-gray-500\" data-kid=\"70\">[ SHIM_ADJUSTMENT_v3.4 ]</div>\n                </div>\n                <div class=\"service-item group flex flex-col md:flex-row md:items-center justify-between py-12 border-b border-[var(--k-color-border)] transition-colors\" data-img=\"https://images.unsplash.com/photo-1679007577558-a04f328b7493?auto=format&w=800&q=80&fit=crop\" data-kid=\"71\">\n                    <div class=\"flex items-baseline gap-6\" data-kid=\"72\">\n                        <span class=\"text-[var(--k-color-accent)] font-mono text-2xl font-bold\" data-kid=\"73\">02.</span>\n                        <h3 class=\"text-5xl md:text-8xl font-bold font-mono uppercase tracking-tighter group-hover:text-[var(--k-color-accent)] transition-colors\" data-kid=\"74\">Fork Overhaul</h3>\n                    </div>\n                    <div class=\"mt-4 md:mt-0 font-mono text-xs text-gray-500\" data-kid=\"75\">[ SUSPENSION_BLUEPRINT ]</div>\n                </div>\n                <div class=\"service-item group flex flex-col md:flex-row md:items-center justify-between py-12 border-b border-[var(--k-color-border)] transition-colors\" data-img=\"https://images.pexels.com/photos/10392250/pexels-photo-10392250.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" data-kid=\"76\">\n                    <div class=\"flex items-baseline gap-6\" data-kid=\"77\">\n                        <span class=\"text-[var(--k-color-accent)] font-mono text-2xl font-bold\" data-kid=\"78\">03.</span>\n                        <h3 class=\"text-5xl md:text-8xl font-bold font-mono uppercase tracking-tighter group-hover:text-[var(--k-color-accent)] transition-colors\" data-kid=\"79\">ECU Mapping</h3>\n                    </div>\n                    <div class=\"mt-4 md:mt-0 font-mono text-xs text-gray-500\" data-kid=\"80\">[ DYNO_FUEL_TUNE ]</div>\n                </div>\n                <div class=\"service-item group flex flex-col md:flex-row md:items-center justify-between py-12 border-b border-[var(--k-color-border)] transition-colors\" data-img=\"https://images.unsplash.com/photo-1694437629385-4aa792773590?auto=format&w=800&q=80&fit=crop\" data-kid=\"81\">\n                    <div class=\"flex items-baseline gap-6\" data-kid=\"82\">\n                        <span class=\"text-[var(--k-color-accent)] font-mono text-2xl font-bold\" data-kid=\"83\">04.</span>\n                        <h3 class=\"text-5xl md:text-8xl font-bold font-mono uppercase tracking-tighter group-hover:text-[var(--k-color-accent)] transition-colors\" data-kid=\"84\">Chassis Build</h3>\n                    </div>\n                    <div class=\"mt-4 md:mt-0 font-mono text-xs text-gray-500\" data-kid=\"85\">[ GEOMETRY_CALIBRATION ]</div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div id=\"cursor-img-container\" class=\"fixed pointer-events-none w-80 h-96 z-50 opacity-0 scale-90 overflow-hidden border-2 border-[var(--k-color-accent)] grayscale invert brightness-110\" data-kid=\"86\">\n            <img id=\"reveal-img\" src alt=\"Service Schematic\" class=\"w-full h-full object-cover\" data-kid=\"87\">\n        </div>\n    </section>\n\n    \n    <section id=\"classic-table\" class=\"py-32 bg-[var(--k-color-bg-surface)]\" data-kid=\"88\">\n        <div class=\"container mx-auto px-6\" data-kid=\"89\">\n            <div class=\"mb-16 max-w-2xl\" data-kid=\"90\">\n                <span class=\"text-[var(--k-color-accent)] font-mono text-sm block mb-2\" data-kid=\"91\">// COSTING_LEDGER</span>\n                <h2 class=\"text-5xl font-bold font-mono uppercase tracking-tighter mb-4\" data-kid=\"92\">PRICING_ESTIMATES</h2>\n                <p class=\"text-gray-400 font-sans\" data-kid=\"93\">Brutally honest billing protocol. No hidden modules. Estimates based on precision man-hours and premium hardware.</p>\n            </div>\n\n            <div class=\"overflow-x-auto border-2 border-dashed border-red-600/40 bg-black/20\" data-kid=\"94\">\n                <table class=\"w-full text-left font-mono border-collapse min-w-[800px]\" data-kid=\"95\">\n                    <thead class=\"bg-red-600/10 text-[10px] uppercase tracking-[0.2em] text-red-500 border-b border-red-600/40\" data-kid=\"96\">\n                        <tr data-kid=\"97\">\n                            <th class=\"p-6 border-r border-red-600/20\" data-kid=\"98\">UNIT_ID</th>\n                            <th class=\"p-6 border-r border-red-600/20\" data-kid=\"99\">SERVICE_MODULE</th>\n                            <th class=\"p-6 border-r border-red-600/20\" data-kid=\"100\">LABOR_BASE</th>\n                            <th class=\"p-6 border-r border-red-600/20\" data-kid=\"101\">PARTS_EST</th>\n                            <th class=\"p-6\" data-kid=\"102\">T_AROUND</th>\n                        </tr>\n                    </thead>\n                    <tbody class=\"text-sm\" data-kid=\"103\">\n                        <tr class=\"pricing-row border-b border-dashed border-red-600/20 hover:bg-red-600/5 transition-colors\" data-kid=\"104\">\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"105\">SRV-01</td>\n                            <td class=\"p-6 border-r border-red-600/20 font-bold\" data-kid=\"106\">DIAGNOSTIC SCAN</td>\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"107\">₹ 4,500</td>\n                            <td class=\"p-6 border-r border-red-600/20 text-gray-600\" data-kid=\"108\">N/A</td>\n                            <td class=\"p-6\" data-kid=\"109\">12H</td>\n                        </tr>\n                        <tr class=\"pricing-row border-b border-dashed border-red-600/20 hover:bg-red-600/5 transition-colors\" data-kid=\"110\">\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"111\">SRV-42</td>\n                            <td class=\"p-6 border-r border-red-600/20 font-bold\" data-kid=\"112\">ENGINE REBUILD</td>\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"113\">₹ 45,000</td>\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"114\">₹ 80K+</td>\n                            <td class=\"p-6 text-red-500 font-bold\" data-kid=\"115\">21 DAYS</td>\n                        </tr>\n                        <tr class=\"pricing-row border-b border-dashed border-red-600/20 hover:bg-red-600/5 transition-colors\" data-kid=\"116\">\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"117\">SRV-105</td>\n                            <td class=\"p-6 border-r border-red-600/20 font-bold\" data-kid=\"118\">DYNO MAPPING</td>\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"119\">₹ 18,000</td>\n                            <td class=\"p-6 border-r border-red-600/20 text-gray-600\" data-kid=\"120\">N/A</td>\n                            <td class=\"p-6\" data-kid=\"121\">4H</td>\n                        </tr>\n                        <tr class=\"pricing-row border-b border-dashed border-red-600/20 hover:bg-red-600/5 transition-colors\" data-kid=\"122\">\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"123\">SRV-SUS</td>\n                            <td class=\"p-6 border-r border-red-600/20 font-bold\" data-kid=\"124\">SUSPENSION TUNE</td>\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"125\">₹ 12,500</td>\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"126\">₹ 15,000</td>\n                            <td class=\"p-6\" data-kid=\"127\">48H</td>\n                        </tr>\n                        <tr class=\"pricing-row opacity-30\" data-kid=\"128\">\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"129\">SRV-XXX</td>\n                            <td class=\"p-6 border-r border-red-600/20 font-bold italic\" data-kid=\"130\">CUSTOM FAB</td>\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"131\">QUOTE</td>\n                            <td class=\"p-6 border-r border-red-600/20\" data-kid=\"132\">QUOTE</td>\n                            <td class=\"p-6\" data-kid=\"133\">VARIES</td>\n                        </tr>\n                    </tbody>\n                </table>\n            </div>\n            \n            <div class=\"mt-12 flex flex-col md:flex-row justify-between items-center gap-8 border-t border-[var(--k-color-border)] pt-12\" data-kid=\"134\">\n                <div class=\"font-mono text-[10px] text-gray-500 uppercase tracking-widest\" data-kid=\"135\">\n                    Invoice ref: 2024.06.22-LOGS<br data-kid=\"136\">\n                    Authenticity: Verified by Workshop Terminal\n                </div>\n                <button class=\"bg-[var(--k-color-accent)] text-black px-12 py-5 font-bold uppercase hover:bg-white transition-colors flex items-center gap-4 shadow-[10px_10px_0px_0px_rgba(255,255,255,0.05)] active:translate-y-1 active:shadow-none\" data-kid=\"137\">\n                    <span data-kid=\"138\">[ GENERATE_QUOTATION_REQUEST ]</span>\n                    <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"currentColor\" data-kid=\"139\"><path d=\"M10 0l-1.4 1.4 7.6 7.6H0v2h16.2l-7.6 7.6L10 20l10-10L10 0z\" data-kid=\"140\"></path></svg>\n                </button>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-24 px-6 border-t border-[var(--k-color-border)] bg-black/80\" data-kid=\"141\">\n        <div class=\"container mx-auto grid grid-cols-1 md:grid-cols-3 gap-16\" data-kid=\"142\">\n            <div data-kid=\"143\">\n                <img src=\"/api/local/images/attachments/images/Screenshot 2026-06-22 173233-2026-06-22_12-03-09.png\" alt=\"Krishna Automobiles Logo\" class=\"h-12 grayscale invert brightness-200 mb-8\" decoding=\"async\" loading=\"lazy\" data-kid=\"144\">\n                <p class=\"text-gray-500 text-xs font-mono uppercase leading-loose\" data-kid=\"145\">\n                    Terminal Address: 402/B Performance Industrial Alley.<br data-kid=\"146\">\n                    Global Support: +91 99000 88XXX<br data-kid=\"147\">\n                    Ops: 09:00 - 20:00 MON-SAT\n                </p>\n            </div>\n            <div class=\"font-mono uppercase text-xs space-y-5\" data-kid=\"148\">\n                <div class=\"text-gray-600 tracking-[0.3em] mb-4\" data-kid=\"149\">// NAVIGATION</div>\n                <a href=\"#\" class=\"block text-gray-400 hover:text-[var(--k-color-accent)] transition-colors tracking-widest\" data-kid=\"150\">[ ABOUT_MODULE ]</a>\n                <a href=\"#\" class=\"block text-gray-400 hover:text-[var(--k-color-accent)] transition-colors tracking-widest\" data-kid=\"151\">[ RECRUIT_LOGS ]</a>\n                <a href=\"#\" class=\"block text-gray-400 hover:text-[var(--k-color-accent)] transition-colors tracking-widest\" data-kid=\"152\">[ SECURITY_PROT ]</a>\n                <a href=\"#\" class=\"block text-gray-400 hover:text-[var(--k-color-accent)] transition-colors tracking-widest\" data-kid=\"153\">[ TERMS_OF_EXEC ]</a>\n            </div>\n            <div class=\"font-mono uppercase text-xs space-y-5\" data-kid=\"154\">\n                <div class=\"text-gray-600 tracking-[0.3em] mb-4\" data-kid=\"155\">// DATA_STREAMS</div>\n                <a href=\"#\" class=\"block text-gray-400 hover:text-[var(--k-color-accent)] transition-colors tracking-widest\" data-kid=\"156\">INSTAGRAM_DIAG</a>\n                <a href=\"#\" class=\"block text-gray-400 hover:text-[var(--k-color-accent)] transition-colors tracking-widest\" data-kid=\"157\">YOUTUBE_REELS_RAW</a>\n                <a href=\"#\" class=\"block text-gray-400 hover:text-[var(--k-color-accent)] transition-colors tracking-widest\" data-kid=\"158\">X_TERMINAL_FEED</a>\n            </div>\n        </div>\n        <div class=\"container mx-auto mt-24 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 font-mono text-[9px] text-gray-600 uppercase tracking-[0.2em]\" data-kid=\"159\">\n            <span data-kid=\"160\">&copy; 2024 KRISHNA AUTOMOBILES PERF_UNIT // ALL_BITS_RESERVED</span>\n            <span data-kid=\"161\">SYSTEM_V2.0.4 // DESIGNED_FOR_SPEED</span>\n        </div>\n    </footer>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"162\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"163\"></script>\n<script type=\"module\" data-kid=\"164\">\n    import { animate, scroll, motionValue, styleEffect } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n    import { animate as animeAnimate } from 'https://esm.sh/animejs@4';\n\n    gsap.registerPlugin(ScrollTrigger);\n\n    // 1. Anime.js Typewriter Effect\n    const heroTitle = document.getElementById('hero-typewriter');\n    const fullText = \"Performance Engineering Terminal\";\n    let charIndex = 0;\n    \n    const typeChar = () => {\n        if (charIndex < fullText.length) {\n            if (fullText.substring(charIndex, charIndex+2) === \"<b\") {\n                heroTitle.innerHTML += \"<br>\";\n                charIndex += 4;\n            } else {\n                heroTitle.innerHTML += fullText.charAt(charIndex);\n                charIndex++;\n            }\n            setTimeout(typeChar, 30);\n        } else {\n            heroTitle.innerHTML += '<span class=\"terminal-cursor\"></span>';\n            animeAnimate('.terminal-cursor', {\n                opacity: [0, 1],\n                duration: 400,\n                loop: true,\n                direction: 'alternate',\n                easing: 'steps(2)'\n            });\n        }\n    };\n    setTimeout(typeChar, 500);\n\n    // 2. Scroll-linked flow line\n    gsap.from(\"#flow-line\", {\n        scrollTrigger: {\n            trigger: \"#flow-chain\",\n            start: \"top 70%\",\n            end: \"bottom 30%\",\n            scrub: 1\n        },\n        scaleX: 0,\n        ease: \"none\"\n    });\n\n    // 3. Anime.js Pointer Follow for Index\n    const cursorContainer = document.getElementById('cursor-img-container');\n    const revealImg = document.getElementById('reveal-img');\n    \n    window.addEventListener('pointermove', (e) => {\n        animeAnimate(cursorContainer, {\n            translateX: e.clientX,\n            translateY: e.clientY,\n            duration: 0,\n            easing: 'linear'\n        });\n    });\n\n    document.querySelectorAll('.service-item').forEach(item => {\n        item.addEventListener('mouseenter', () => {\n            const src = item.getAttribute('data-img');\n            revealImg.src = src;\n            animeAnimate(cursorContainer, {\n                opacity: 1,\n                scale: 1,\n                rotate: '2deg',\n                duration: 500,\n                easing: 'easeOutElastic(1, .8)'\n            });\n        });\n        item.addEventListener('mouseleave', () => {\n            animeAnimate(cursorContainer, {\n                opacity: 0,\n                scale: 0.8,\n                rotate: '0deg',\n                duration: 300,\n                easing: 'easeInQuad'\n            });\n        });\n    });\n\n    // 4. GSAP Entrance Animations\n    gsap.from(\".flow-step\", {\n        scrollTrigger: {\n            trigger: \"#flow-chain\",\n            start: \"top 80%\",\n        },\n        y: 60,\n        opacity: 0,\n        stagger: 0.15,\n        duration: 1.2,\n        ease: \"power4.out\"\n    });\n\n    gsap.from(\".pricing-row\", {\n        scrollTrigger: {\n            trigger: \"#classic-table\",\n            start: \"top 85%\",\n        },\n        x: -40,\n        opacity: 0,\n        stagger: 0.08,\n        duration: 1,\n        ease: \"power3.out\"\n    });\n\n    // 5. Parallax for grid background\n    scroll(animate(\".grid-bg\", { backgroundPositionY: [\"0px\", \"400px\"] }, { ease: \"linear\" }));\n</script>\n>>>>>>> REPLACE\n",
