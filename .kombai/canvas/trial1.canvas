      "html": "<style data-kombai-theme>:root{--k-color-primary:#ffffff;--k-color-primary-hover:#f0f0f0;--k-color-secondary:#999999;--k-color-bg-page:#000000;--k-color-bg-surface:#0a0a0a;--k-color-bg-surface-hover:#111111;--k-color-text-primary:#ffffff;--k-color-text-secondary:#999999;--k-color-text-muted:#666666;--k-color-border:#1f1f1f;--k-color-border-hover:#333333;--k-color-accent:#ff0000;--k-color-success:#00ff00;--k-color-warning:#ffff00;--k-color-error:#ff0000;--k-font-family-heading:Inter, sans-serif;--k-font-family-body:Inter, sans-serif;--k-font-size-xs:0.75rem;--k-font-size-sm:0.875rem;--k-font-size-base:1rem;--k-font-size-lg:1.125rem;--k-font-size-xl:1.25rem;--k-font-size-2xl:1.5rem;--k-font-size-3xl:1.875rem;--k-font-size-4xl:2.25rem;--k-font-size-5xl:3rem;--k-font-weight-normal:400;--k-font-weight-medium:500;--k-font-weight-semibold:600;--k-font-weight-bold:700;--k-spacing-xs:0.25rem;--k-spacing-sm:0.5rem;--k-spacing-md:1rem;--k-spacing-lg:1.5rem;--k-spacing-xl:2rem;--k-spacing-2xl:3rem;--k-spacing-3xl:4rem;--k-radius-sm:0.125rem;--k-radius-md:0.75rem;--k-radius-lg:1rem;--k-radius-xl:1.5rem;--k-radius-full:9999px;--k-shadow-sm:0 1px 2px 0 rgba(0, 0, 0, 0.05);--k-shadow-md:0 4px 6px -1px rgba(0, 0, 0, 0.1);--k-shadow-lg:0 10px 15px -3px rgba(0, 0, 0, 0.1);--k-border-width-default:1px;--k-border-width-thick:2px;}</style>\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;500;600;700&display=swap');\n\n    :root {\n        --color-onyx: #111111;\n        --color-blazing: #FF3800;\n        --color-smoke: #F5F5F5;\n    }\n\n    body {\n        background-color: var(--k-color-bg-page);\n        color: var(--k-color-text-primary);\n        font-family: 'Space Grotesk', sans-serif;\n        overflow-x: clip;\n    }\n\n    .font-anton { font-family: 'Anton', sans-serif; }\n    .font-space { font-family: 'Space Grotesk', sans-serif; }\n\n    /* Custom Patterns */\n    .diagonal-split-left {\n        clip-path: polygon(0 0, 95% 0, 75% 100%, 0 100%);\n    }\n\n    .diagonal-split-right {\n        clip-path: polygon(25% 0, 100% 0, 100% 100%, 5% 100%);\n    }\n\n    .scanline {\n        background: linear-gradient(to bottom, rgba(255,255,255,0) 50%, rgba(0,0,0,0.1) 50%), linear-gradient(to right, rgba(255,0,0,0.02), rgba(0,255,0,0.02), rgba(0,0,255,0.02));\n        background-size: 100% 2px, 3px 100%;\n        pointer-events: none;\n    }\n\n    .brutalist-border {\n        border: 4px solid var(--color-onyx);\n        box-shadow: 8px 8px 0px var(--color-blazing);\n    }\n\n    .neon-glow {\n        border: 1.5px solid var(--color-blazing);\n        box-shadow: 0 0 12px rgba(255, 56, 0, 0.2), 0 0 36px rgba(255, 56, 0, 0.06);\n    }\n\n    /* Marquee */\n    .marquee-container {\n        transform: rotate(-3deg) translateY(50px);\n    }\n\n    .marquee-content {\n        display: flex;\n        white-space: nowrap;\n        animation: marquee var(--speed, 20s) linear infinite;\n    }\n\n    @keyframes marquee {\n        0% { transform: translateX(0); }\n        100% { transform: translateX(-50%); }\n    }\n\n    /* Hide scrollbar for Lenis */\n    html.lenis {\n        height: auto;\n    }\n    .lenis-smooth {\n        scroll-behavior: auto;\n    }\n    .lenis-smooth [data-lenis-prevent] {\n        overscroll-behavior: contain;\n    }\n    .lenis-stopped {\n        overflow: hidden;\n    }\n</style>\n\n\n<section id=\"hero\" class=\"relative w-full h-screen overflow-hidden bg-black\" data-kid=\"1\">\n    <nav class=\"absolute top-0 left-0 w-full z-50 p-8 md:p-12 flex justify-between items-center pointer-events-none\" data-kid=\"2\">\n        <img src=\"data://attachments/images/Screenshot 2026-06-22 173233-2026-06-22_12-03-09.png\" alt=\"Krishna Automobiles Logo\" class=\"h-10 md:h-24 invert brightness-200 pointer-events-auto\" decoding=\"async\" loading=\"lazy\" data-kid=\"3\">\n        <div class=\"hidden md:flex gap-12 text-white font-bold tracking-[0.4em] text-xs uppercase pointer-events-auto\" data-kid=\"4\">\n            <a href=\"#tech\" class=\"hover:text-[var(--color-blazing)] transition-colors\" data-kid=\"5\">Tech</a>\n            <a href=\"#metrics\" class=\"hover:text-[var(--color-blazing)] transition-colors\" data-kid=\"6\">Metrics</a>\n            <a href=\"#proof\" class=\"hover:text-[var(--color-blazing)] transition-colors\" data-kid=\"7\">Proof</a>\n        </div>\n    </nav>\n\n    <div class=\"relative w-full h-full flex flex-col md:flex-row\" data-kid=\"8\">\n        <div class=\"absolute inset-0 scanline z-30 pointer-events-none\" data-kid=\"9\"></div>\n        \n        <div class=\"w-full md:w-3/5 h-full bg-[var(--color-onyx)] flex flex-col justify-center px-8 md:pl-24 md:pr-48 z-20 diagonal-split-left\" data-kid=\"10\">\n            <h1 class=\"font-anton text-[clamp(4rem,10vw,10rem)] text-white leading-[0.85] mb-8 uppercase tracking-tighter hero-text\" data-kid=\"11\">\n                SHAVE<br data-kid=\"12\"><span class=\"text-[var(--color-blazing)]\" data-kid=\"13\">SECONDS.</span>\n            </h1>\n            <p class=\"text-white/60 max-w-lg text-lg md:text-xl mb-12 leading-relaxed hero-sub\" data-kid=\"14\">\n                Engineering precision for the apex. We don't just tune bikes; we weaponize them for the track.\n            </p>\n            <div class=\"hero-cta-wrap\" data-kid=\"15\">\n                <button class=\"group relative inline-flex items-center justify-center px-12 py-5 font-anton text-2xl tracking-widest uppercase bg-[var(--color-blazing)] text-white overflow-hidden transition-all hover:pr-16\" data-kid=\"16\">\n                    <span class=\"relative z-10\" data-kid=\"17\">Enter Pit Lane</span>\n                    <i class=\"ti ti-arrow-right absolute right-6 opacity-0 group-hover:opacity-100 transition-all\" data-kid=\"18\"></i>\n                </button>\n            </div>\n        </div>\n\n        \n        <div class=\"absolute inset-0 md:left-1/2 w-full md:w-3/5 h-full z-10 hero-video-container diagonal-split-right overflow-hidden\" data-kid=\"19\">\n            <video src=\"https://videos.pexels.com/video-files/30384343/13021438_640_360_60fps.mp4\" poster=\"https://images.pexels.com/videos/30384343/pexels-photo-30384343.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover scale-110\" data-kid=\"20\">\n            </video>\n            <div class=\"absolute inset-0 bg-black/20\" data-kid=\"21\"></div>\n        </div>\n    </div>\n</section>\n\n\n<section id=\"tech\" class=\"relative bg-black py-40 overflow-hidden\" data-kid=\"22\">\n    <div class=\"max-w-7xl mx-auto px-8 relative\" data-kid=\"23\">\n        <div class=\"absolute left-1/2 top-0 bottom-0 w-px bg-white/10 -translate-x-1/2 hidden md:block\" data-kid=\"24\"></div>\n        \n        <div class=\"space-y-48\" data-kid=\"25\">\n            \n            <div class=\"tech-item relative flex flex-col md:flex-row items-center justify-center\" data-kid=\"26\">\n                <div class=\"md:w-1/2 md:pr-32 text-center md:text-right mb-12 md:mb-0 tech-content-left\" data-kid=\"27\">\n                    <div class=\"flex flex-col md:items-end mb-4\" data-kid=\"28\">\n                        <span class=\"bg-[var(--color-blazing)] text-white font-anton text-xl px-4 py-1 uppercase tracking-widest\" data-kid=\"29\">Phase 01</span>\n                        <div class=\"h-1 w-24 bg-white mt-1\" data-kid=\"30\"></div>\n                    </div>\n                    <h3 class=\"font-anton text-5xl md:text-9xl text-white uppercase mb-6 leading-[0.85]\" data-kid=\"31\">Reactive<br data-kid=\"32\">Deceleration</h3>\n                    <p class=\"text-white/50 text-xl font-light leading-relaxed max-w-sm md:ml-auto\" data-kid=\"33\">\n                        We deploy ceramic-matrix Brembo integrations. Millimeter-perfect hydraulic response for late-braking maneuvers that redefine the apex.\n                    </p>\n                </div>\n                <div class=\"absolute left-1/2 -translate-x-1/2 z-10 bg-black p-4 hidden md:block\" data-kid=\"34\">\n                    <i class=\"ti ti-hexagon-filled text-[var(--color-blazing)] text-4xl\" data-kid=\"35\"></i>\n                </div>\n                <div class=\"md:w-1/2 md:pl-32 tech-image-right\" data-kid=\"36\">\n                    <div class=\"relative group cursor-crosshair\" data-kid=\"37\">\n                        <div class=\"absolute -inset-4 border border-[var(--color-blazing)]/30 scale-95 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-500\" data-kid=\"38\"></div>\n                        <div class=\"aspect-[4/5] w-full max-w-md overflow-hidden bg-zinc-900 rounded-xs\" data-kid=\"39\">\n                            <img src=\"https://images.unsplash.com/photo-1762012507780-060fe0bcc783?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n                        </div>\n                        <div class=\"absolute bottom-6 left-6 text-white font-anton text-sm tracking-widest bg-black/80 px-4 py-2 uppercase\" data-kid=\"41\">Calibrated Performance</div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"tech-item relative flex flex-col md:flex-row-reverse items-center justify-center\" data-kid=\"42\">\n                <div class=\"md:w-1/2 md:pl-32 text-center md:text-left mb-12 md:mb-0 tech-content-right\" data-kid=\"43\">\n                    <div class=\"flex flex-col md:items-start mb-4\" data-kid=\"44\">\n                        <span class=\"bg-[var(--color-blazing)] text-white font-anton text-xl px-4 py-1 uppercase tracking-widest\" data-kid=\"45\">Phase 02</span>\n                        <div class=\"h-1 w-24 bg-white mt-1\" data-kid=\"46\"></div>\n                    </div>\n                    <h3 class=\"font-anton text-5xl md:text-9xl text-white uppercase mb-6 leading-[0.85]\" data-kid=\"47\">Aero<br data-kid=\"48\">Optimization</h3>\n                    <p class=\"text-white/50 text-xl font-light leading-relaxed max-w-md\" data-kid=\"49\">\n                        Wind-tunnel validated carbon structures. Integrated winglets providing 15kg of vertical load at 200km/h, ensuring the front wheel stays pinned.\n                    </p>\n                </div>\n                <div class=\"absolute left-1/2 -translate-x-1/2 z-10 bg-black p-4 hidden md:block\" data-kid=\"50\">\n                    <i class=\"ti ti-hexagon-filled text-[var(--color-blazing)] text-4xl\" data-kid=\"51\"></i>\n                </div>\n                <div class=\"md:w-1/2 md:pr-32 tech-image-left\" data-kid=\"52\">\n                    <div class=\"relative group cursor-crosshair\" data-kid=\"53\">\n                        <div class=\"absolute -inset-4 border border-[var(--color-blazing)]/30 scale-95 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-500\" data-kid=\"54\"></div>\n                        <div class=\"aspect-[4/5] w-full max-w-md overflow-hidden bg-zinc-900 rounded-xs ml-auto\" data-kid=\"55\">\n                            <img src=\"https://images.unsplash.com/photo-1758563920442-280b4e7afe7a?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"56\">\n                        </div>\n                        <div class=\"absolute bottom-6 right-6 text-white font-anton text-sm tracking-widest bg-black/80 px-4 py-2 uppercase\" data-kid=\"57\">Carbon Structural Integrity</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<section id=\"metrics\" class=\"bg-[var(--color-onyx)] py-40 border-y border-white/5 overflow-hidden\" data-kid=\"58\">\n    <div class=\"max-w-7xl mx-auto px-8\" data-kid=\"59\">\n        <div class=\"flex flex-col md:flex-row items-center justify-center mb-24 gap-16 md:gap-32 text-center\" data-kid=\"60\">\n            <div class=\"max-w-xl\" data-kid=\"61\">\n                <h2 class=\"font-anton text-6xl md:text-8xl text-white uppercase leading-none mb-6\" data-kid=\"62\">By the Numbers</h2>\n                <p class=\"text-white/40 text-xl font-light mx-auto\" data-kid=\"63\">Data-driven performance tuning. We measure success in milliseconds shaved and horsepower gained.</p>\n            </div>\n            <div class=\"flex flex-col items-center md:items-end border-l-4 border-[var(--color-blazing)] pl-8\" data-kid=\"64\">\n                <div class=\"font-anton text-[var(--color-blazing)] text-8xl md:text-9xl leading-none\" data-kid=\"65\">0.01</div>\n                <div class=\"font-bold text-white tracking-[0.4em] uppercase text-[10px] mt-2\" data-kid=\"66\">Critical Margin (sec)</div>\n            </div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-24\" data-kid=\"67\">\n            \n            <div class=\"gauge-card flex flex-col items-center\" data-kid=\"68\">\n                <div class=\"relative w-72 h-36\" data-kid=\"69\">\n                    <svg class=\"w-full h-full\" viewBox=\"0 0 100 50\" data-kid=\"70\">\n                        <path d=\"M 10 50 A 40 40 0 0 1 90 50\" fill=\"none\" stroke=\"#222\" stroke-width=\"6\" stroke-linecap=\"round\" data-kid=\"71\"></path>\n                        <path class=\"gauge-path\" data-value=\"85\" d=\"M 10 50 A 40 40 0 0 1 90 50\" fill=\"none\" stroke=\"var(--color-blazing)\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-dasharray=\"125.66\" stroke-dashoffset=\"125.66\" data-kid=\"72\"></path>\n                    </svg>\n                    <div class=\"absolute bottom-[-10px] inset-x-0 text-center flex items-baseline justify-center gap-1\" data-kid=\"73\">\n                        <span class=\"font-anton text-7xl text-white tracking-tighter counter leading-none\" data-target=\"85\" data-kid=\"74\">0</span>\n                        <span class=\"font-anton text-3xl text-[var(--color-blazing)] leading-none uppercase translate-y-[-5px]\" data-kid=\"75\">%</span>\n                    </div>\n                </div>\n                <h4 class=\"mt-8 text-white font-anton text-xl tracking-widest uppercase\" data-kid=\"76\">Average HP Gain</h4>\n                <p class=\"text-white/30 text-sm mt-2 uppercase tracking-widest\" data-kid=\"77\">Stage 3 ECU Flash</p>\n            </div>\n\n            \n            <div class=\"gauge-card flex flex-col items-center\" data-kid=\"78\">\n                <div class=\"relative w-72 h-36\" data-kid=\"79\">\n                    <svg class=\"w-full h-full\" viewBox=\"0 0 100 50\" data-kid=\"80\">\n                        <path d=\"M 10 50 A 40 40 0 0 1 90 50\" fill=\"none\" stroke=\"#222\" stroke-width=\"6\" stroke-linecap=\"round\" data-kid=\"81\"></path>\n                        <path class=\"gauge-path\" data-value=\"99\" d=\"M 10 50 A 40 40 0 0 1 90 50\" fill=\"none\" stroke=\"var(--color-blazing)\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-dasharray=\"125.66\" stroke-dashoffset=\"125.66\" data-kid=\"82\"></path>\n                    </svg>\n                    <div class=\"absolute bottom-[-10px] inset-x-0 text-center flex items-baseline justify-center gap-1\" data-kid=\"83\">\n                        <span class=\"font-anton text-7xl text-white tracking-tighter counter leading-none\" data-target=\"99\" data-kid=\"84\">0</span>\n                        <span class=\"font-anton text-3xl text-[var(--color-blazing)] leading-none uppercase translate-y-[-5px]\" data-kid=\"85\">.8%</span>\n                    </div>\n                </div>\n                <h4 class=\"mt-8 text-white font-anton text-xl tracking-widest uppercase\" data-kid=\"86\">Suspension Precision</h4>\n                <p class=\"text-white/30 text-sm mt-2 uppercase tracking-widest\" data-kid=\"87\">Laser Alignment</p>\n            </div>\n\n            \n            <div class=\"gauge-card flex flex-col items-center\" data-kid=\"88\">\n                <div class=\"relative w-72 h-36\" data-kid=\"89\">\n                    <svg class=\"w-full h-full\" viewBox=\"0 0 100 50\" data-kid=\"90\">\n                        <path d=\"M 10 50 A 40 40 0 0 1 90 50\" fill=\"none\" stroke=\"#222\" stroke-width=\"6\" stroke-linecap=\"round\" data-kid=\"91\"></path>\n                        <path class=\"gauge-path\" data-value=\"70\" d=\"M 10 50 A 40 40 0 0 1 90 50\" fill=\"none\" stroke=\"var(--color-blazing)\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-dasharray=\"125.66\" stroke-dashoffset=\"125.66\" data-kid=\"92\"></path>\n                    </svg>\n                    <div class=\"absolute bottom-[-10px] inset-x-0 text-center flex items-baseline justify-center gap-1\" data-kid=\"93\">\n                        <span class=\"font-anton text-7xl text-white tracking-tighter counter leading-none\" data-target=\"24\" data-kid=\"94\">0</span>\n                        <span class=\"font-anton text-3xl text-[var(--color-blazing)] leading-none uppercase translate-y-[-5px]\" data-kid=\"95\">H</span>\n                    </div>\n                </div>\n                <h4 class=\"mt-8 text-white font-anton text-xl tracking-widest uppercase\" data-kid=\"96\">Pit Response</h4>\n                <p class=\"text-white/30 text-sm mt-2 uppercase tracking-widest\" data-kid=\"97\">Average Turnaround</p>\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<section id=\"proof\" class=\"relative bg-black py-40 overflow-hidden\" data-kid=\"98\">\n    \n    <div class=\"marquee-container bg-[var(--color-blazing)] py-6 z-20 relative overflow-hidden\" data-kid=\"99\">\n        <div class=\"marquee-content\" data-kid=\"100\">\n            <div class=\"flex items-center gap-12 px-6\" data-kid=\"101\">\n                <span class=\"font-anton text-6xl text-white uppercase italic tracking-tighter\" data-kid=\"102\">Track Proven</span>\n                <i class=\"ti ti-triangle-filled text-black text-3xl\" data-kid=\"103\"></i>\n                <span class=\"font-anton text-6xl text-white uppercase italic tracking-tighter\" data-kid=\"104\">Race Ready</span>\n                <i class=\"ti ti-triangle-filled text-black text-3xl\" data-kid=\"105\"></i>\n                <span class=\"font-anton text-6xl text-white uppercase italic tracking-tighter\" data-kid=\"106\">Apex Predator</span>\n                <i class=\"ti ti-triangle-filled text-black text-3xl\" data-kid=\"107\"></i>\n            </div>\n            <div class=\"flex items-center gap-12 px-6\" data-kid=\"108\">\n                <span class=\"font-anton text-6xl text-white uppercase italic tracking-tighter\" data-kid=\"109\">Track Proven</span>\n                <i class=\"ti ti-triangle-filled text-black text-3xl\" data-kid=\"110\"></i>\n                <span class=\"font-anton text-6xl text-white uppercase italic tracking-tighter\" data-kid=\"111\">Race Ready</span>\n                <i class=\"ti ti-triangle-filled text-black text-3xl\" data-kid=\"112\"></i>\n                <span class=\"font-anton text-6xl text-white uppercase italic tracking-tighter\" data-kid=\"113\">Apex Predator</span>\n                <i class=\"ti ti-triangle-filled text-black text-3xl\" data-kid=\"114\"></i>\n            </div>\n        </div>\n    </div>\n\n    \n    <div class=\"max-w-7xl mx-auto px-8 mt-40\" data-kid=\"115\">\n        <div class=\"columns-1 sm:columns-2 lg:columns-4 gap-6 space-y-6\" data-kid=\"116\">\n            <div class=\"break-inside-avoid relative group overflow-hidden bg-zinc-900\" data-kid=\"117\">\n                <img src=\"https://images.pexels.com/photos/32346814/pexels-photo-32346814.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Bike 1\" class=\"w-full grayscale group-hover:grayscale-0 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"118\">\n                <div class=\"absolute bottom-4 left-4 bg-black/60 px-3 py-1 text-[10px] text-white font-bold uppercase tracking-widest\" data-kid=\"119\">Sepang Circuit '24</div>\n            </div>\n            <div class=\"break-inside-avoid relative group overflow-hidden bg-zinc-900\" data-kid=\"120\">\n                <img src=\"https://images.pexels.com/photos/28844912/pexels-photo-28844912.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Bike 2\" class=\"w-full grayscale group-hover:grayscale-0 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"121\">\n            </div>\n            <div class=\"break-inside-avoid relative group overflow-hidden bg-zinc-900\" data-kid=\"122\">\n                <img src=\"https://images.pexels.com/photos/28844913/pexels-photo-28844913.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Bike 3\" class=\"w-full grayscale group-hover:grayscale-0 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"123\">\n            </div>\n            <div class=\"break-inside-avoid relative group overflow-hidden bg-zinc-900\" data-kid=\"124\">\n                <img src=\"https://images.pexels.com/photos/32346787/pexels-photo-32346787.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Bike 4\" class=\"w-full grayscale group-hover:grayscale-0 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"125\">\n            </div>\n            <div class=\"break-inside-avoid relative group overflow-hidden bg-zinc-900\" data-kid=\"126\">\n                <img src=\"https://images.pexels.com/photos/10673663/pexels-photo-10673663.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Bike 5\" class=\"w-full grayscale group-hover:grayscale-0 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"127\">\n            </div>\n            <div class=\"break-inside-avoid relative group overflow-hidden bg-zinc-900\" data-kid=\"128\">\n                <img src=\"https://images.pexels.com/photos/30196355/pexels-photo-30196355.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Bike 6\" class=\"w-full grayscale group-hover:grayscale-0 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"129\">\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<section id=\"services\" class=\"bg-[var(--color-onyx)] py-40 border-t border-white/5\" data-kid=\"130\">\n    <div class=\"max-w-7xl mx-auto px-8\" data-kid=\"131\">\n        <div class=\"mb-20\" data-kid=\"132\">\n            <h2 class=\"font-anton text-5xl md:text-7xl text-white uppercase leading-tight mb-4\" data-kid=\"133\">Pit Configuration</h2>\n            <div class=\"flex items-center gap-4\" data-kid=\"134\">\n                <div class=\"w-12 h-1 bg-[var(--color-blazing)]\" data-kid=\"135\"></div>\n                <span class=\"text-white/40 uppercase tracking-[0.4em] text-xs font-bold\" data-kid=\"136\">Select Your Deployment Package</span>\n            </div>\n        </div>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-6 md:grid-rows-2 gap-8 h-auto\" data-kid=\"137\">\n            \n            <div class=\"md:col-span-3 md:row-span-2 bg-black p-12 brutalist-border flex flex-col justify-between relative overflow-hidden group\" data-kid=\"138\">\n                <div class=\"absolute -top-20 -right-20 w-64 h-64 bg-[var(--color-blazing)]/5 rounded-full blur-3xl group-hover:bg-[var(--color-blazing)]/10 transition-all duration-700\" data-kid=\"139\"></div>\n                <div data-kid=\"140\">\n                    <div class=\"flex items-center gap-4 mb-8\" data-kid=\"141\">\n                        <i class=\"ti ti-settings-automation text-[var(--color-blazing)] text-3xl\" data-kid=\"142\"></i>\n                        <span class=\"text-white font-bold tracking-[0.3em] uppercase text-xs\" data-kid=\"143\">Mission Critical</span>\n                    </div>\n                    <h3 class=\"font-anton text-7xl md:text-8xl text-white uppercase leading-[0.85] mb-8\" data-kid=\"144\">Full Race<br data-kid=\"145\"><span class=\"text-[var(--color-blazing)]\" data-kid=\"146\">Deployment</span></h3>\n                    <div class=\"space-y-6\" data-kid=\"147\">\n                        <div class=\"flex gap-4 items-start\" data-kid=\"148\">\n                            <div class=\"w-2 h-2 rounded-full bg-[var(--color-blazing)] mt-2\" data-kid=\"149\"></div>\n                            <p class=\"text-white/70 text-lg italic font-light leading-snug\" data-kid=\"150\">Comprehensive blueprinting and internal engine re-machining.</p>\n                        </div>\n                        <div class=\"flex gap-4 items-start\" data-kid=\"151\">\n                            <div class=\"w-2 h-2 rounded-full bg-[var(--color-blazing)] mt-2\" data-kid=\"152\"></div>\n                            <p class=\"text-white/70 text-lg italic font-light leading-snug\" data-kid=\"153\">Structural carbon fairing integration and winglet installation.</p>\n                        </div>\n                        <div class=\"flex gap-4 items-start\" data-kid=\"154\">\n                            <div class=\"w-2 h-2 rounded-full bg-[var(--color-blazing)] mt-2\" data-kid=\"155\"></div>\n                            <p class=\"text-white/70 text-lg italic font-light leading-snug\" data-kid=\"156\">Suspension geometry optimization for specific track profiles.</p>\n                        </div>\n                    </div>\n                </div>\n                <button class=\"mt-12 bg-[var(--color-blazing)] text-white font-anton text-2xl py-6 uppercase tracking-widest hover:bg-white hover:text-black transition-all flex items-center justify-center gap-4\" data-kid=\"157\">\n                    Initialize Build <i class=\"ti ti-bolt text-2xl\" data-kid=\"158\"></i>\n                </button>\n            </div>\n\n            \n            <div class=\"md:col-span-3 bg-[var(--k-color-bg-surface-hover)] p-10 flex flex-col md:flex-row justify-between items-center group border border-white/5 hover:border-[var(--color-blazing)]/30 transition-all\" data-kid=\"159\">\n                <div class=\"text-center md:text-left\" data-kid=\"160\">\n                    <h4 class=\"font-anton text-5xl text-white uppercase mb-2\" data-kid=\"161\">Master ECU Flash</h4>\n                    <p class=\"text-white/40 text-lg max-w-xs\" data-kid=\"162\">Custom fuel mapping, ignition timing, and rev-limit extension.</p>\n                </div>\n                <div class=\"mt-8 md:mt-0 flex flex-col items-center md:items-end\" data-kid=\"163\">\n                    <span class=\"font-anton text-4xl text-white mb-4\" data-kid=\"164\">$899.00</span>\n                    <button class=\"bg-white text-black px-6 py-3 font-bold uppercase text-xs tracking-widest hover:bg-[var(--color-blazing)] hover:text-white transition-all\" data-kid=\"165\">Select</button>\n                </div>\n            </div>\n\n            \n            <div class=\"md:col-span-1.5 bg-[var(--k-color-bg-surface)] p-8 flex flex-col justify-between border border-white/5 hover:bg-[var(--k-color-bg-surface-hover)] transition-all\" data-kid=\"166\">\n                <div data-kid=\"167\">\n                    <i class=\"ti ti-analyze text-[var(--color-blazing)] text-3xl mb-4 block\" data-kid=\"168\"></i>\n                    <h4 class=\"font-anton text-2xl text-white uppercase mb-2\" data-kid=\"169\">Track Dial</h4>\n                    <p class=\"text-white/40 text-sm\" data-kid=\"170\">Rider-specific sag and damping presets.</p>\n                </div>\n                <span class=\"font-anton text-xl text-white mt-6\" data-kid=\"171\">$159</span>\n            </div>\n\n            \n            <div class=\"md:col-span-1.5 bg-[var(--k-color-bg-surface)] p-8 flex flex-col justify-between border border-white/5 hover:bg-[var(--k-color-bg-surface-hover)] transition-all\" data-kid=\"172\">\n                <div data-kid=\"173\">\n                    <i class=\"ti ti-droplet-filled text-[var(--color-blazing)] text-3xl mb-4 block\" data-kid=\"174\"></i>\n                    <h4 class=\"font-anton text-2xl text-white uppercase mb-2\" data-kid=\"175\">Fluid Purge</h4>\n                    <p class=\"text-white/40 text-sm\" data-kid=\"176\">Full synthetic race-grade renewal.</p>\n                </div>\n                <span class=\"font-anton text-xl text-white mt-6\" data-kid=\"177\">$249</span>\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<section class=\"relative bg-black h-screen overflow-hidden flex items-end\" data-kid=\"178\">\n    \n    <div class=\"absolute inset-0 z-0\" data-kid=\"179\">\n        <img src=\"https://images.unsplash.com/photo-1758448721161-7b3df5ec04b3?auto=format&w=1600&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-30\" decoding=\"async\" loading=\"lazy\" data-kid=\"180\">\n        <div class=\"absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent\" data-kid=\"181\"></div>\n    </div>\n\n    \n    <div class=\"w-full p-8 md:p-12 z-10 relative\" data-kid=\"182\">\n        <div class=\"max-w-5xl mx-auto bg-black/80 backdrop-blur-xl rounded-full p-4 md:p-6 neon-glow flex flex-col md:flex-row items-center justify-between gap-6\" data-kid=\"183\">\n            <div class=\"flex items-center gap-6 px-4\" data-kid=\"184\">\n                <img src=\"data://attachments/images/Screenshot 2026-06-22 173233-2026-06-22_12-03-09.png\" class=\"h-14 invert brightness-150\" alt=\"Footer Logo\" decoding=\"async\" loading=\"lazy\" data-kid=\"185\">\n                <div class=\"h-12 w-px bg-white/20 hidden md:block\" data-kid=\"186\"></div>\n                <div class=\"hidden md:block\" data-kid=\"187\">\n                    <p class=\"text-white font-bold text-xs uppercase tracking-widest\" data-kid=\"188\">Krishna Automobiles</p>\n                    <p class=\"text-white/40 text-[10px] uppercase\" data-kid=\"189\">Bangalore, India</p>\n                </div>\n            </div>\n            \n            <div class=\"flex gap-10 text-white/60 font-bold uppercase tracking-widest text-[10px]\" data-kid=\"190\">\n                <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"191\">Privacy</a>\n                <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"192\">Terms</a>\n                <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"193\">Support</a>\n            </div>\n\n            <button class=\"bg-[var(--color-blazing)] text-white px-10 py-4 rounded-full font-anton text-lg tracking-widest uppercase hover:bg-white hover:text-black transition-all\" data-kid=\"194\">\n                Schedule Drop-off\n            </button>\n        </div>\n        <p class=\"text-center text-white/20 text-[10px] uppercase tracking-[0.5em] mt-12 mb-4\" data-kid=\"195\">© 2026 Apex Predator Garage. All Rights Reserved.</p>\n    </div>\n</section>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"196\">\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"197\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"198\"></script>\n<script data-kid=\"199\">gsap.registerPlugin(ScrollTrigger);</script>\n<script type=\"module\" data-kid=\"200\">\n    import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n    import Lenis from \"https://esm.sh/lenis@1\"\n    import Snap from \"https://esm.sh/lenis@1/snap\"\n\n    // Initialize Lenis\n    const lenis = new Lenis({\n        duration: 1.2,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t))\n    });\n\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    // Velocity Driven Marquee\n    const marquee = document.querySelector('.marquee-content');\n    lenis.on('scroll', ({ velocity }) => {\n        const speed = 1 + Math.abs(velocity) * 0.15;\n        marquee.parentElement.style.setProperty('--speed', `${20 / speed}s`);\n    });\n\n    // Hero Animations\n    const heroTl = gsap.timeline();\n    heroTl.from('.hero-text', {\n        y: 100,\n        opacity: 0,\n        duration: 1,\n        ease: 'power4.out',\n        stagger: 0.2\n    })\n    .from('.hero-sub', {\n        y: 30,\n        opacity: 0,\n        duration: 0.8,\n        ease: 'power3.out'\n    }, '-=0.5')\n    .from('.hero-cta-wrap', {\n        scale: 0.9,\n        opacity: 0,\n        duration: 0.8,\n        ease: 'back.out(1.7)'\n    }, '-=0.5')\n    .from('.hero-video-container', {\n        clipPath: 'inset(0 0 0 100%)',\n        duration: 1.5,\n        ease: 'power4.inOut'\n    }, 0);\n\n    // Tech Ladder Animations\n    gsap.utils.toArray('.tech-item').forEach((item, i) => {\n        const content = item.querySelector('.tech-content-left, .tech-content-right');\n        const image = item.querySelector('.tech-image-left, .tech-image-right');\n        \n        gsap.from(content, {\n            scrollTrigger: {\n                trigger: item,\n                start: 'top 80%',\n            },\n            x: i % 2 === 0 ? -100 : 100,\n            opacity: 0,\n            duration: 1.2,\n            ease: 'power3.out'\n        });\n\n        gsap.from(image, {\n            scrollTrigger: {\n                trigger: item,\n                start: 'top 80%',\n            },\n            x: i % 2 === 0 ? 100 : -100,\n            opacity: 0,\n            duration: 1.2,\n            ease: 'power3.out'\n        });\n    });\n\n    // Metrics Gauges Animation\n    gsap.utils.toArray('.gauge-card').forEach((card) => {\n        const path = card.querySelector('.gauge-path');\n        const counter = card.querySelector('.counter');\n        const value = parseFloat(path.dataset.value);\n        const targetValue = parseFloat(counter.dataset.target);\n        \n        const circumference = 125.66; // approx 2 * PI * 40 / 2 (for semi-circle)\n        \n        ScrollTrigger.create({\n            trigger: card,\n            start: 'top 90%',\n            onEnter: () => {\n                // Animate path\n                gsap.to(path, {\n                    strokeDashoffset: circumference * (1 - value / 100),\n                    duration: 2,\n                    ease: 'power4.out'\n                });\n\n                // Animate counter\n                let obj = { val: 0 };\n                gsap.to(obj, {\n                    val: targetValue,\n                    duration: 2,\n                    ease: 'power4.out',\n                    onUpdate: () => {\n                        counter.textContent = Math.round(obj.val);\n                    }\n                });\n            }\n        });\n    });\n\n    // Masonry Batch Animation\n    ScrollTrigger.batch('#proof .break-inside-avoid', {\n        start: 'top 85%',\n        onEnter: (batch) => gsap.from(batch, {\n            opacity: 0,\n            y: 50,\n            stagger: 0.1,\n            duration: 0.8,\n            ease: 'power3.out'\n        }),\n        once: true\n    });\n\n</script>\n\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"201\">\n",
