      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Instrument+Sans:wght@800;900&family=JetBrains+Mono:wght@700&display=swap');\n\n  :root {\n    --color-canvas: #000000;\n    --color-surface: #080808;\n    --color-accent-red: #DC143C;\n    --color-border-dark: #1A1A1A;\n    --color-secondary-gray: #777777;\n    --color-white: #FFFFFF;\n    --color-alabaster: #D1D1D1;\n  }\n\n  body {\n    background-color: var(--color-canvas);\n    color: var(--color-white);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .font-instrument { font-family: 'Instrument Sans', sans-serif; }\n  .font-inter { font-family: 'Inter', sans-serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .text-stroke-white {\n    -webkit-text-stroke: 1.2px rgba(255, 255, 255, 0.4);\n    color: transparent;\n  }\n\n  .grid-pattern {\n    background-image: linear-gradient(var(--color-border-dark) 1px, transparent 1px),\n                      linear-gradient(90deg, var(--color-border-dark) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .lenis.lenis-smooth {\n    scroll-behavior: auto !important;\n  }\n\n  /* Custom component styles */\n  .technical-border {\n    border: 1px solid var(--color-border-dark);\n  }\n\n  .hover-brutalist:hover {\n    box-shadow: 12px 12px 0 var(--color-accent-red);\n    transform: translate(-4px, -4px);\n  }\n\n  .workflow-step:hover .step-line {\n    height: 100%;\n  }\n\n  /* Marquee Animation */\n  .marquee-track {\n    display: flex;\n    width: max-content;\n    animation: marquee-scroll 40s linear infinite;\n  }\n\n  @keyframes marquee-scroll {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n</style>\n<div class=\"relative min-h-screen flex flex-col\" data-kid=\"1\">\n\n<nav class=\"fixed top-6 left-1/2 -translate-x-1/2 z-50 bg-black/60 backdrop-blur-xl border border-white/10 rounded-full px-8 py-3 flex items-center gap-12\" data-kid=\"1-1\">\n<div class=\"flex items-center gap-3\" data-kid=\"1-1-1\">\n<div class=\"w-6 h-6 bg-[var(--color-accent-red)] rounded-full flex items-center justify-center\" data-kid=\"1-1-1-1\">\n<span class=\"text-black font-black text-[10px]\" data-kid=\"1-1-1-1-1\">K</span>\n</div>\n<span class=\"font-instrument font-black tracking-tighter text-sm uppercase\" data-kid=\"1-1-1-2\">Krishna</span>\n</div>\n<div class=\"flex items-center gap-8\" data-kid=\"1-1-2\">\n<a class=\"font-mono text-[10px] uppercase tracking-widest text-[var(--color-secondary-gray)] hover:text-white transition-colors\" data-kid=\"1-1-2-1\" href=\"#\">Home</a>\n<a class=\"font-mono text-[10px] uppercase tracking-widest text-[var(--color-secondary-gray)] hover:text-white transition-colors\" data-kid=\"1-1-2-2\" href=\"#\">Services</a>\n<a class=\"font-mono text-[10px] uppercase tracking-widest text-white\" data-kid=\"1-1-2-3\" href=\"#\">About</a>\n<a class=\"font-mono text-[10px] uppercase tracking-widest text-[var(--color-secondary-gray)] hover:text-white transition-colors\" data-kid=\"1-1-2-4\" href=\"#\">Contact</a>\n</div>\n<button class=\"bg-white text-black font-mono text-[10px] uppercase tracking-widest px-5 py-2 rounded-full hover:bg-[var(--color-accent-red)] hover:text-white transition-all\" data-kid=\"1-1-3\">\n      Book Protocol\n    </button>\n</nav>\n\n<section class=\"h-screen flex flex-col justify-end relative px-6 lg:px-20 pb-20 pt-24 overflow-hidden border-b border-[var(--color-border-dark)]\" data-kid=\"1-2\">\n<div class=\"absolute inset-0 grid-pattern opacity-20 pointer-events-none\" data-kid=\"1-2-1\"></div>\n\n<div class=\"absolute top-1/2 left-0 w-full -translate-y-1/2 overflow-hidden pointer-events-none opacity-[0.03] select-none\" data-kid=\"1-2-2\">\n<span class=\"font-instrument text-[22vw] leading-none whitespace-nowrap uppercase tracking-tighter\" data-kid=\"1-2-2-1\">SURGICAL PRECISION</span>\n</div>\n<div class=\"max-w-[1440px] mx-auto w-full relative z-10 reveal-parent\" data-kid=\"1-2-3\">\n<div class=\"flex items-center gap-4 mb-8 reveal-up\" data-kid=\"1-2-3-1\">\n<span class=\"font-mono text-[var(--color-accent-red)] text-[10px] tracking-[0.4em] uppercase\" data-kid=\"1-2-3-1-1\">SYSTEM ACTIVE</span>\n<div class=\"h-[1px] bg-[var(--color-border-dark)] grow\" data-kid=\"1-2-3-1-2\"></div>\n<span class=\"font-mono text-[var(--color-secondary-gray)] text-[10px] tracking-[0.4em] uppercase\" data-kid=\"1-2-3-1-3\">MIRA ROAD EAST / 2009-2024</span>\n</div>\n<h1 class=\"font-instrument text-[clamp(4rem,10vw,8.5rem)] font-black leading-[0.85] tracking-[-0.07em] uppercase mb-12 reveal-up\" data-kid=\"1-2-3-2\">\n<span class=\"block\" data-kid=\"1-2-3-2-1\">FIFTEEN YEARS</span>\n<span class=\"text-stroke-white block\" data-kid=\"1-2-3-2-2\">OF SURGICAL</span>\n<span class=\"text-[var(--color-accent-red)] block\" data-kid=\"1-2-3-2-3\">ENGINEERING.</span>\n</h1>\n<div class=\"grid grid-cols-12 gap-8 items-end reveal-up\" data-kid=\"1-2-3-3\">\n<div class=\"col-span-12 lg:col-span-8 border-l-2 border-[var(--color-accent-red)] pl-8\" data-kid=\"1-2-3-3-1\">\n<p class=\"font-inter text-xl lg:text-2xl font-medium leading-[1.4] text-[var(--color-alabaster)] max-w-2xl\" data-kid=\"1-2-3-3-1-1\">\n            Krishna Automobile is a cornerstone of reliability. Since 2009, we've specialized in the technical heartbeat of Mumbai's riders.\n          </p>\n</div>\n<div class=\"col-span-12 lg:col-span-4 flex justify-start lg:justify-end gap-12\" data-kid=\"1-2-3-3-2\">\n<div class=\"text-left lg:text-right\" data-kid=\"1-2-3-3-2-1\">\n<span class=\"font-instrument text-6xl lg:text-7xl font-black block tracking-tighter text-[var(--color-accent-red)]\" data-kid=\"1-2-3-3-2-1-1\">15+</span>\n<span class=\"font-mono text-[9px] uppercase tracking-[0.2em] text-[var(--color-secondary-gray)]\" data-kid=\"1-2-3-3-2-1-2\">Years Legacy</span>\n</div>\n<div class=\"text-left lg:text-right\" data-kid=\"1-2-3-3-2-2\">\n<span class=\"font-instrument text-6xl lg:text-7xl font-black block tracking-tighter\" data-kid=\"1-2-3-3-2-2-1\">10K+</span>\n<span class=\"font-mono text-[9px] uppercase tracking-[0.2em] text-[var(--color-secondary-gray)]\" data-kid=\"1-2-3-3-2-2-2\">Units Repaired</span>\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<div class=\"py-10 border-b border-[var(--color-border-dark)] bg-[var(--color-surface)] overflow-hidden\" data-kid=\"1-3\">\n<div class=\"marquee-track\" data-kid=\"1-3-1\">\n<div class=\"flex items-center gap-20 px-10\" data-kid=\"1-3-1-1\">\n<span class=\"font-instrument text-2xl font-black uppercase tracking-tighter flex items-center gap-4\" data-kid=\"1-3-1-1-1\">\n<span class=\"w-3 h-3 bg-[var(--color-accent-red)] rotate-45\" data-kid=\"1-3-1-1-1-1\"></span>\n          Honda Activa Specialist\n        </span>\n<span class=\"font-instrument text-2xl font-black uppercase tracking-tighter flex items-center gap-4\" data-kid=\"1-3-1-1-2\">\n<span class=\"w-3 h-3 bg-[var(--color-accent-red)] rotate-45\" data-kid=\"1-3-1-1-2-1\"></span>\n          Royal Enfield Expert\n        </span>\n<span class=\"font-instrument text-2xl font-black uppercase tracking-tighter flex items-center gap-4\" data-kid=\"1-3-1-1-3\">\n<span class=\"w-3 h-3 bg-[var(--color-accent-red)] rotate-45\" data-kid=\"1-3-1-1-3-1\"></span>\n          Yamaha Performance\n        </span>\n<span class=\"font-instrument text-2xl font-black uppercase tracking-tighter flex items-center gap-4\" data-kid=\"1-3-1-1-4\">\n<span class=\"w-3 h-3 bg-[var(--color-accent-red)] rotate-45\" data-kid=\"1-3-1-1-4-1\"></span>\n          Suzuki &amp; TVS Servicing\n        </span>\n</div>\n\n<div class=\"flex items-center gap-20 px-10\" data-kid=\"1-3-1-2\">\n<span class=\"font-instrument text-2xl font-black uppercase tracking-tighter flex items-center gap-4\" data-kid=\"1-3-1-2-1\">\n<span class=\"w-3 h-3 bg-[var(--color-accent-red)] rotate-45\" data-kid=\"1-3-1-2-1-1\"></span>\n          Honda Activa Specialist\n        </span>\n<span class=\"font-instrument text-2xl font-black uppercase tracking-tighter flex items-center gap-4\" data-kid=\"1-3-1-2-2\">\n<span class=\"w-3 h-3 bg-[var(--color-accent-red)] rotate-45\" data-kid=\"1-3-1-2-2-1\"></span>\n          Royal Enfield Expert\n        </span>\n<span class=\"font-instrument text-2xl font-black uppercase tracking-tighter flex items-center gap-4\" data-kid=\"1-3-1-2-3\">\n<span class=\"w-3 h-3 bg-[var(--color-accent-red)] rotate-45\" data-kid=\"1-3-1-2-3-1\"></span>\n          Yamaha Performance\n        </span>\n<span class=\"font-instrument text-2xl font-black uppercase tracking-tighter flex items-center gap-4\" data-kid=\"1-3-1-2-4\">\n<span class=\"w-3 h-3 bg-[var(--color-accent-red)] rotate-45\" data-kid=\"1-3-1-2-4-1\"></span>\n          Suzuki &amp; TVS Servicing\n        </span>\n</div>\n</div>\n</div>\n\n<section class=\"py-40 px-6 lg:px-20 bg-black border-b border-[var(--color-border-dark)] relative overflow-hidden reveal-parent\" data-kid=\"1-4\" data-name=\"technical workflow section\">\n<div class=\"absolute top-0 right-0 w-[500px] h-[500px] bg-[var(--color-accent-red)]/5 blur-[120px] rounded-full pointer-events-none\" data-kid=\"1-4-1\" data-name=\"workflow decorative glow background\"></div>\n<div class=\"max-w-[1440px] mx-auto relative z-10\" data-kid=\"1-4-2\" data-name=\"workflow inner content wrapper\">\n<div class=\"mb-32 flex justify-between items-end reveal-up\" data-kid=\"1-4-2-1\" data-name=\"workflow header container\">\n<div data-kid=\"1-4-2-1-1\" data-name=\"workflow header text group\">\n<span class=\"font-mono text-[var(--color-accent-red)] text-[9px] tracking-[0.5em] uppercase block mb-6\" data-kid=\"1-4-2-1-1-1\" data-name=\"workflow section label\">ENGINEERING_LIFECYCLE</span>\n<h2 class=\"font-instrument text-6xl lg:text-7xl font-black uppercase tracking-tighter leading-[0.9]\" data-kid=\"1-4-2-1-1-2\" data-name=\"workflow section title\">TECHNICAL<br data-kid=\"1-4-2-1-1-2-1\" data-name=\"workflow section title line break\">WORKFLOW</h2>\n</div>\n<div class=\"hidden lg:block text-right\" data-kid=\"1-4-2-1-2\" data-name=\"workflow metadata group\">\n<span class=\"font-mono text-[9px] text-[var(--color-secondary-gray)] uppercase tracking-widest block mb-2\" data-kid=\"1-4-2-1-2-1\" data-name=\"workflow revision log text\">Revision_Log // 2024</span>\n<span class=\"font-mono text-xs text-white uppercase tracking-widest\" data-kid=\"1-4-2-1-2-2\" data-name=\"workflow protocol version text\">Protocol v2.4.9</span>\n</div>\n</div>\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-y-24 reveal-up\" data-kid=\"1-4-2-2\" data-name=\"workflow steps container\">\n\n<div class=\"lg:col-span-5 workflow-step group relative border-t border-[var(--color-border-dark)] pt-12\" data-kid=\"1-4-2-2-1\" data-name=\"workflow step 1 card\">\n<div class=\"absolute -top-[1px] left-0 w-0 h-[1px] bg-[var(--color-accent-red)] group-hover:w-full transition-all duration-700\" data-kid=\"1-4-2-2-1-1\" data-name=\"workflow step 1 progress line\"></div>\n<span class=\"font-instrument text-6xl font-black text-white/10 mb-8 block\" data-kid=\"1-4-2-2-1-2\" data-name=\"workflow step 1 number\">01</span>\n<h3 class=\"font-instrument text-3xl font-black uppercase tracking-tighter mb-6\" data-kid=\"1-4-2-2-1-3\" data-name=\"workflow step 1 title\">DIAGNOSIS &amp; SCAN</h3>\n<p class=\"font-inter text-lg text-[var(--color-secondary-gray)] leading-relaxed mb-10\" data-kid=\"1-4-2-2-1-4\" data-name=\"workflow step 1 description\">\n            Every vehicle undergoes a 32-point inspection using modern diagnostic tools. Complete digital log reports generated for absolute transparency.\n          </p>\n<div class=\"w-24 h-24 technical-border flex items-center justify-center font-mono text-[9px] text-white/20 group-hover:text-[var(--color-accent-red)] group-hover:border-[var(--color-accent-red)] transition-all\" data-kid=\"1-4-2-2-1-5\" data-name=\"workflow step 1 action label\">SCAN_INIT</div>\n</div>\n<div class=\"lg:col-span-2 flex justify-center items-center\" data-kid=\"1-4-2-2-2\" data-name=\"workflow central divider container\">\n<div class=\"w-[1px] h-full bg-[var(--color-border-dark)] hidden lg:block\" data-kid=\"1-4-2-2-2-1\" data-name=\"workflow central divider line\"></div>\n</div>\n\n<div class=\"lg:col-span-5 workflow-step group relative border-t border-[var(--color-border-dark)] pt-12 lg:mt-32\" data-kid=\"1-4-2-2-3\" data-name=\"workflow step 2 card\">\n<div class=\"absolute -top-[1px] left-0 w-0 h-[1px] bg-[var(--color-accent-red)] group-hover:w-full transition-all duration-700\" data-kid=\"1-4-2-2-3-1\" data-name=\"workflow step 2 progress line\"></div>\n<span class=\"font-instrument text-6xl font-black text-white/10 mb-8 block\" data-kid=\"1-4-2-2-3-2\" data-name=\"workflow step 2 number\">02</span>\n<h3 class=\"font-instrument text-3xl font-black uppercase tracking-tighter mb-6\" data-kid=\"1-4-2-2-3-3\" data-name=\"workflow step 2 title\">COMPONENTRY</h3>\n<p class=\"font-inter text-lg text-[var(--color-secondary-gray)] leading-relaxed mb-10\" data-kid=\"1-4-2-2-3-4\" data-name=\"workflow step 2 description\">\n            We only stock and fit genuine spares. From Exide batteries to Castrol engine oils, every component is sourced for surgical fitment.\n          </p>\n<div class=\"w-24 h-24 technical-border flex items-center justify-center font-mono text-[9px] text-white/20 group-hover:text-[var(--color-accent-red)] group-hover:border-[var(--color-accent-red)] transition-all\" data-kid=\"1-4-2-2-3-5\" data-name=\"workflow step 2 action label\">GEN_PARTS</div>\n</div>\n<div class=\"lg:col-span-12 h-24\" data-kid=\"1-4-2-2-4\" data-name=\"workflow spacer\"></div>\n\n<div class=\"lg:col-start-4 lg:col-span-6 workflow-step group relative border-t border-[var(--color-border-dark)] pt-12\" data-kid=\"1-4-2-2-5\" data-name=\"workflow step 3 card\">\n<div class=\"absolute -top-[1px] left-0 w-0 h-[1px] bg-[var(--color-accent-red)] group-hover:w-full transition-all duration-700\" data-kid=\"1-4-2-2-5-1\" data-name=\"workflow step 3 progress line\"></div>\n<div class=\"flex flex-col md:flex-row gap-12 items-start\" data-kid=\"1-4-2-2-5-2\" data-name=\"workflow step 3 content wrapper\">\n<span class=\"font-instrument text-6xl font-black text-white/10\" data-kid=\"1-4-2-2-5-2-1\" data-name=\"workflow step 3 number\">03</span>\n<div data-kid=\"1-4-2-2-5-2-2\" data-name=\"workflow step 3 text column\">\n<h3 class=\"font-instrument text-3xl font-black uppercase tracking-tighter mb-6\" data-kid=\"1-4-2-2-5-2-2-1\" data-name=\"workflow step 3 title\">DEPLOYMENT</h3>\n<p class=\"font-inter text-lg text-[var(--color-secondary-gray)] leading-relaxed mb-10\" data-kid=\"1-4-2-2-5-2-2-2\" data-name=\"workflow step 3 description\">\n                        From complex engine overhauls to precision washing, our final checks ensure your vehicle leaves the workshop in showroom condition.\n                    </p>\n<div class=\"w-24 h-24 technical-border flex items-center justify-center font-mono text-[9px] text-white/20 group-hover:text-[var(--color-accent-red)] group-hover:border-[var(--color-accent-red)] transition-all\" data-kid=\"1-4-2-2-5-2-2-3\" data-name=\"workflow step 3 action label\">DEPLOY_OK</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<section class=\"bg-black border-b border-[var(--color-border-dark)]\" data-kid=\"1-5\">\n<div class=\"grid grid-cols-1 lg:grid-cols-2\" data-kid=\"1-5-1\">\n\n<div class=\"relative min-h-[700px] overflow-hidden group\" data-kid=\"1-5-1-1\">\n<img alt=\"Inclusive Workshop\" class=\"w-full h-full object-cover grayscale opacity-60 group-hover:scale-105 transition-transform duration-1000 parallax-img\" data-kid=\"1-5-1-1-1\" src=\"https://images.unsplash.com/photo-1558981403-c5f9899a28bc?auto=format&amp;w=1400&amp;q=80&amp;fit=crop\">\n<div class=\"absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent\" data-kid=\"1-5-1-1-2\"></div>\n<div class=\"absolute bottom-12 left-12 flex flex-wrap gap-4\" data-kid=\"1-5-1-1-3\">\n<span class=\"px-8 py-3 border border-white/20 bg-black/40 backdrop-blur-md rounded-full font-mono text-[10px] uppercase tracking-[0.2em]\" data-kid=\"1-5-1-1-3-1\">Safe Space Certified</span>\n<span class=\"px-8 py-3 border border-[var(--color-accent-red)] bg-[var(--color-accent-red)] text-white rounded-full font-mono text-[10px] uppercase tracking-[0.2em]\" data-kid=\"1-5-1-1-3-2\">Inclusive Garage</span>\n</div>\n</div>\n\n<div class=\"p-12 lg:p-24 flex flex-col justify-center border-l border-[var(--color-border-dark)] relative bg-[var(--color-canvas)] reveal-parent\" data-kid=\"1-5-1-2\">\n<div class=\"absolute top-0 right-0 w-32 h-32 opacity-10 pointer-events-none overflow-hidden\" data-kid=\"1-5-1-2-1\">\n<div class=\"absolute top-0 right-0 w-[200%] h-[1px] bg-white rotate-45\" data-kid=\"1-5-1-2-1-1\"></div>\n<div class=\"absolute top-10 right-0 w-[200%] h-[1px] bg-white rotate-45\" data-kid=\"1-5-1-2-1-2\"></div>\n</div>\n<div class=\"mb-16 reveal-up\" data-kid=\"1-5-1-2-2\">\n<span class=\"font-mono text-[var(--color-accent-red)] text-[9px] tracking-[0.5em] uppercase block mb-6\" data-kid=\"1-5-1-2-2-1\" data-name=\"inclusivity section label\">HUMAN_PROTOCOL // SAFE_SPACE</span>\n<h2 class=\"font-instrument text-7xl lg:text-8xl font-black uppercase tracking-tighter leading-[0.82] mb-10\" data-kid=\"1-5-1-2-2-2\">INCLUSIVITY<br data-kid=\"1-5-1-2-2-2-1\"><span class=\"text-stroke-white opacity-40\" data-kid=\"1-5-1-2-2-2-2\">AT OUR</span><br data-kid=\"1-5-1-2-2-2-3\"><span class=\"text-[var(--color-accent-red)]\" data-kid=\"1-5-1-2-2-2-4\">CORE</span></h2>\n<div class=\"w-16 h-[1.5px] bg-[var(--color-accent-red)]\" data-kid=\"1-5-1-2-2-3\" data-name=\"inclusivity title underline\"></div>\n</div>\n<p class=\"font-inter text-xl lg:text-2xl text-[var(--color-secondary-gray)] leading-relaxed max-w-lg mb-16 reveal-up\" data-kid=\"1-5-1-2-3\">\n          We operate an inclusive, welcoming shop that proudly welcomes LGBTQ community members. For us, technical excellence goes hand-in-hand with human respect. Everyone is welcome in our workshop.\n        </p>\n<div class=\"flex items-center gap-8\" data-kid=\"1-5-1-2-4\">\n<div class=\"flex -space-x-6\" data-kid=\"1-5-1-2-4-1\">\n<img alt=\"Community Member\" class=\"w-20 h-20 rounded-full border-4 border-black object-cover\" data-kid=\"1-5-1-2-4-1-1\" src=\"https://i.pravatar.cc/120?u=rider1\">\n<img alt=\"Community Member\" class=\"w-20 h-20 rounded-full border-4 border-black object-cover\" data-kid=\"1-5-1-2-4-1-2\" src=\"https://i.pravatar.cc/120?u=rider2\">\n<img alt=\"Community Member\" class=\"w-20 h-20 rounded-full border-4 border-black object-cover\" data-kid=\"1-5-1-2-4-1-3\" src=\"https://i.pravatar.cc/120?u=rider3\">\n</div>\n<div class=\"flex flex-col\" data-kid=\"1-5-1-2-4-2\">\n<span class=\"font-mono text-xs uppercase tracking-[0.2em] text-white\" data-kid=\"1-5-1-2-4-2-1\">A Trusted Hub</span>\n<span class=\"font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-secondary-gray)]\" data-kid=\"1-5-1-2-4-2-2\">For all Mumbai's Riders</span>\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<section class=\"py-40 px-6 lg:px-20 bg-[var(--color-surface)] border-b border-[var(--color-border-dark)]\" data-kid=\"1-6\">\n<div class=\"max-w-[1440px] mx-auto\" data-kid=\"1-6-1\">\n<div class=\"grid grid-cols-1 md:grid-cols-3 gap-12 items-start\" data-kid=\"1-6-1-1\">\n<div class=\"relative aspect-[4/5] overflow-hidden hover-brutalist transition-all duration-300\" data-kid=\"1-6-1-1-1\">\n<img alt=\"Componentry Detail\" class=\"w-full h-full object-cover grayscale opacity-50 parallax-img\" data-kid=\"1-6-1-1-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1615906659973-5a315f2e10c1?auto=format&amp;w=800&amp;q=80&amp;fit=crop\">\n<div class=\"absolute top-8 left-8 p-4 border border-white/10 bg-black/40 backdrop-blur-md\" data-kid=\"1-6-1-1-1-2\">\n<span class=\"font-mono text-[9px] uppercase tracking-widest block opacity-50\" data-kid=\"1-6-1-1-1-2-1\">VIEW_01</span>\n<span class=\"font-mono text-[10px] uppercase tracking-widest\" data-kid=\"1-6-1-1-1-2-2\">Combustion_Assembly</span>\n</div>\n</div>\n<div class=\"relative aspect-[4/5] overflow-hidden hover-brutalist transition-all duration-300 md:mt-32\" data-kid=\"1-6-1-1-2\">\n<img alt=\"Tooling Detail\" class=\"w-full h-full object-cover grayscale opacity-50 parallax-img\" data-kid=\"1-6-1-1-2-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1599819811279-d5ad9cccf838?auto=format&amp;w=800&amp;q=80&amp;fit=crop\">\n<div class=\"absolute top-8 left-8 p-4 border border-white/10 bg-black/40 backdrop-blur-md\" data-kid=\"1-6-1-1-2-2\">\n<span class=\"font-mono text-[9px] uppercase tracking-widest block opacity-50\" data-kid=\"1-6-1-1-2-2-1\">VIEW_02</span>\n<span class=\"font-mono text-[10px] uppercase tracking-widest\" data-kid=\"1-6-1-1-2-2-2\">Precision_Tooling</span>\n</div>\n</div>\n<div class=\"relative aspect-[4/5] overflow-hidden hover-brutalist transition-all duration-300 md:mt-16\" data-kid=\"1-6-1-1-3\">\n<img alt=\"Workshop Environment\" class=\"w-full h-full object-cover grayscale opacity-50 parallax-img\" data-kid=\"1-6-1-1-3-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1558981285-6f0c94958bb6?auto=format&amp;w=800&amp;q=80&amp;fit=crop\">\n<div class=\"absolute top-8 left-8 p-4 border border-white/10 bg-black/40 backdrop-blur-md\" data-kid=\"1-6-1-1-3-2\">\n<span class=\"font-mono text-[9px] uppercase tracking-widest block opacity-50\" data-kid=\"1-6-1-1-3-2-1\">VIEW_03</span>\n<span class=\"font-mono text-[10px] uppercase tracking-widest\" data-kid=\"1-6-1-1-3-2-2\">Workshop_Bay</span>\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<footer class=\"bg-black pt-32 pb-12 px-6 lg:px-20 border-t border-[var(--color-border-dark)]\" data-kid=\"1-7\">\n<div class=\"max-w-[1440px] mx-auto\" data-kid=\"1-7-1\">\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 mb-24\" data-kid=\"1-7-1-1\">\n<div class=\"lg:col-span-5\" data-kid=\"1-7-1-1-1\">\n<div class=\"flex items-center gap-4 mb-10\" data-kid=\"1-7-1-1-1-1\">\n<div class=\"w-10 h-10 bg-[var(--color-accent-red)] rounded-full flex items-center justify-center\" data-kid=\"1-7-1-1-1-1-1\">\n<span class=\"text-black font-black text-sm\" data-kid=\"1-7-1-1-1-1-1-1\">K</span>\n</div>\n<span class=\"font-instrument font-black tracking-tighter text-3xl uppercase\" data-kid=\"1-7-1-1-1-1-2\">Krishna Automobile</span>\n</div>\n<p class=\"font-inter text-xl text-[var(--color-secondary-gray)] mb-12 max-w-md\" data-kid=\"1-7-1-1-1-2\">\n            The mechanical heartbeat of Mira Road East. Expert bike servicing and repair since 2009.\n          </p>\n<div class=\"flex gap-6\" data-kid=\"1-7-1-1-1-3\">\n<a class=\"w-12 h-12 technical-border rounded-full flex items-center justify-center hover:bg-white hover:text-black transition-all\" data-kid=\"1-7-1-1-1-3-1\" href=\"#\">\n<i class=\"fab fa-instagram\" data-kid=\"1-7-1-1-1-3-1-1\"></i>\n</a>\n<a class=\"w-12 h-12 technical-border rounded-full flex items-center justify-center hover:bg-white hover:text-black transition-all\" data-kid=\"1-7-1-1-1-3-2\" href=\"#\">\n<i class=\"fab fa-whatsapp\" data-kid=\"1-7-1-1-1-3-2-1\"></i>\n</a>\n<a class=\"w-12 h-12 technical-border rounded-full flex items-center justify-center hover:bg-white hover:text-black transition-all\" data-kid=\"1-7-1-1-1-3-3\" href=\"#\">\n<i class=\"fab fa-facebook-f\" data-kid=\"1-7-1-1-1-3-3-1\"></i>\n</a>\n</div>\n</div>\n<div class=\"lg:col-span-2\" data-kid=\"1-7-1-1-2\">\n<h5 class=\"font-mono text-xs uppercase tracking-[0.3em] text-white mb-10\" data-kid=\"1-7-1-1-2-1\">Protocols</h5>\n<ul class=\"space-y-6\" data-kid=\"1-7-1-1-2-2\">\n<li data-kid=\"1-7-1-1-2-2-1\"><a class=\"font-mono text-[11px] uppercase tracking-widest text-[var(--color-secondary-gray)] hover:text-[var(--color-accent-red)] transition-colors\" data-kid=\"1-7-1-1-2-2-1-1\" href=\"#\">Home</a></li>\n<li data-kid=\"1-7-1-1-2-2-2\"><a class=\"font-mono text-[11px] uppercase tracking-widest text-[var(--color-secondary-gray)] hover:text-[var(--color-accent-red)] transition-colors\" data-kid=\"1-7-1-1-2-2-2-1\" href=\"#\">Services</a></li>\n<li data-kid=\"1-7-1-1-2-2-3\"><a class=\"font-mono text-[11px] uppercase tracking-widest text-white\" data-kid=\"1-7-1-1-2-2-3-1\" href=\"#\">About</a></li>\n<li data-kid=\"1-7-1-1-2-2-4\"><a class=\"font-mono text-[11px] uppercase tracking-widest text-[var(--color-secondary-gray)] hover:text-[var(--color-accent-red)] transition-colors\" data-kid=\"1-7-1-1-2-2-4-1\" href=\"#\">Contact</a></li>\n</ul>\n</div>\n<div class=\"lg:col-span-3\" data-kid=\"1-7-1-1-3\">\n<h5 class=\"font-mono text-xs uppercase tracking-[0.3em] text-white mb-10\" data-kid=\"1-7-1-1-3-1\">Coordinates</h5>\n<p class=\"font-mono text-[11px] uppercase tracking-widest text-[var(--color-secondary-gray)] leading-loose\" data-kid=\"1-7-1-1-3-2\">\n                Shop No.11, Gaurav Sankalp,<br data-kid=\"1-7-1-1-3-2-1\">\n                Hatkesh, Mira Road East,<br data-kid=\"1-7-1-1-3-2-2\">\n                Thane, Maharashtra 401107\n            </p>\n</div>\n<div class=\"lg:col-span-2\" data-kid=\"1-7-1-1-4\">\n<h5 class=\"font-mono text-xs uppercase tracking-[0.3em] text-white mb-10\" data-kid=\"1-7-1-1-4-1\">System_Status</h5>\n<p class=\"font-mono text-[11px] uppercase tracking-widest text-[var(--color-secondary-gray)]\" data-kid=\"1-7-1-1-4-2\">\n                MON-SUN // 09:00 - 21:30<br data-kid=\"1-7-1-1-4-2-1\">\n                OPEN 7 DAYS A WEEK\n            </p>\n</div>\n</div>\n<div class=\"flex flex-col md:flex-row justify-between items-center pt-12 border-t border-[var(--color-border-dark)] gap-8\" data-kid=\"1-7-1-2\">\n<p class=\"font-mono text-[9px] uppercase tracking-[0.4em] text-[var(--color-secondary-gray)]\" data-kid=\"1-7-1-2-1\">\n            © 2024 KRISHNA AUTOMOBILE // ALL PROTOCOLS RESERVED.\n        </p>\n<div class=\"flex gap-12\" data-kid=\"1-7-1-2-2\">\n<a class=\"font-mono text-[9px] uppercase tracking-[0.4em] text-[var(--color-secondary-gray)] hover:text-white transition-colors\" data-kid=\"1-7-1-2-2-1\" href=\"#\">Privacy_Policy</a>\n<a class=\"font-mono text-[9px] uppercase tracking-[0.4em] text-[var(--color-secondary-gray)] hover:text-white transition-colors\" data-kid=\"1-7-1-2-2-2\" href=\"#\">Terms_of_Service</a>\n</div>\n</div>\n</div>\n</footer>\n</div>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"4\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"5\"></script>\n<link data-kid=\"2\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" rel=\"stylesheet\">\n<link data-kid=\"3\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" rel=\"stylesheet\">\n<script type=\"module\" data-kid=\"6\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // Initialize Lenis\n  const lenis = new Lenis();\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // GSAP Animations\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Entrance reveals - Fixed trigger logic\n  gsap.utils.toArray('.reveal-parent').forEach(parent => {\n    gsap.from(parent.querySelectorAll('.reveal-up'), {\n      y: 60,\n      opacity: 0,\n      duration: 1.2,\n      stagger: 0.2,\n      ease: \"expo.out\",\n      scrollTrigger: {\n        trigger: parent,\n        start: 'top 85%',\n        toggleActions: \"play none none none\"\n      }\n    });\n  });\n\n  // Parallax for images\n  gsap.utils.toArray('.parallax-img').forEach(img => {\n    gsap.to(img, {\n      y: -80,\n      ease: \"none\",\n      scrollTrigger: {\n        trigger: img,\n        start: \"top bottom\",\n        end: \"bottom top\",\n        scrub: true\n      }\n    });\n  });\n\n  // Section Index watermarks movement\n  gsap.utils.toArray('.select-none span').forEach(el => {\n    gsap.to(el, {\n      x: -200,\n      ease: \"none\",\n      scrollTrigger: {\n        trigger: el,\n        start: \"top bottom\",\n        end: \"bottom top\",\n        scrub: 1\n      }\n    });\n  });\n\n</script>\n",
