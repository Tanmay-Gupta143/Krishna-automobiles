te top-0 left-0 w-full h-[2px] bg-[var(--accent-red)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left\" data-kid=\"7-1-2-2-1\" data-name=\"hover decorator line\"></div>\n<span class=\"font-mono text-[10px] text-[var(--accent-red)] mb-6 block\" data-kid=\"7-1-2-2-2\" data-name=\"step label\">ENTRY_02</span>\n<h5 class=\"font-instrument font-black text-2xl uppercase tracking-tighter mb-4 leading-tight group-hover:text-[var(--accent-red)] transition-colors\" data-kid=\"7-1-2-2-3\" data-name=\"step title\">Legal<br data-kid=\"7-1-2-2-3-1\" data-name=\"step title line break\">Empanelment</h5>\n<p class=\"text-xs font-mono text-[var(--secondary-gray)] leading-relaxed uppercase\" data-kid=\"7-1-2-2-4\" data-name=\"step description\">Direct access to motor vehicle law experts for complex liability cases.</p>\n</div>\n<div class=\"p-10 border-r border-b border-[var(--border-dark)] hover:bg-[var(--surface)] transition-all group relative overflow-hidden\" data-kid=\"7-1-2-3\" data-name=\"process step three\">\n<div class=\"absolute top-0 left-0 w-full h-[2px] bg-[var(--accent-red)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left\" data-kid=\"7-1-2-3-1\" data-name=\"hover decorator line\"></div>\n<span class=\"font-mono text-[10px] text-[var(--accent-red)] mb-6 block\" data-kid=\"7-1-2-3-2\" data-name=\"step label\">ENTRY_03</span>\n<h5 class=\"font-instrument font-black text-2xl uppercase tracking-tighter mb-4 leading-tight group-hover:text-[var(--accent-red)] transition-colors\" data-kid=\"7-1-2-3-3\" data-name=\"step title\">Audit &amp;<br data-kid=\"7-1-2-3-3-1\" data-name=\"step title line break\">Compliance</h5>\n<p class=\"text-xs font-mono text-[var(--secondary-gray)] leading-relaxed uppercase\" data-kid=\"7-1-2-3-4\" data-name=\"step description\">Internal verification of all claim documents before insurance submission.</p>\n</div>\n<div class=\"p-10 border-r border-b border-[var(--border-dark)] hover:bg-[var(--surface)] transition-all group relative overflow-hidden\" data-kid=\"7-1-2-4\" data-name=\"process step four\">\n<div class=\"absolute top-0 left-0 w-full h-[2px] bg-[var(--accent-red)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left\" data-kid=\"7-1-2-4-1\" data-name=\"hover decorator line\"></div>\n<span class=\"font-mono text-[10px] text-[var(--accent-red)] mb-6 block\" data-kid=\"7-1-2-4-2\" data-name=\"step label\">ENTRY_04</span>\n<h5 class=\"font-instrument font-black text-2xl uppercase tracking-tighter mb-4 leading-tight group-hover:text-[var(--accent-red)] transition-colors\" data-kid=\"7-1-2-4-3\" data-name=\"step title\">Settlement<br data-kid=\"7-1-2-4-3-1\" data-name=\"step title line break\">Finalization</h5>\n<p class=\"text-xs font-mono text-[var(--secondary-gray)] leading-relaxed uppercase\" data-kid=\"7-1-2-4-4\" data-name=\"step description\">Expedited payout management and vehicle delivery post-repair approval.</p>\n</div>\n</div>\n</div>\n</section>\n\n<div class=\"py-12 border-b border-[var(--border-dark)] overflow-hidden bg-[var(--surface)]\" data-kid=\"8\" data-name=\"marquee section\">\n<div class=\"animate-marquee whitespace-nowrap\" data-kid=\"8-1\" data-name=\"marquee content container\">\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--secondary-gray)]\" data-kid=\"8-1-1\" data-name=\"marquee item\">Direct Claims Hub</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--accent-red)]\" data-kid=\"8-1-2\" data-name=\"marquee separator\">•</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--secondary-gray)]\" data-kid=\"8-1-3\" data-name=\"marquee item\">RTO Consultation</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--accent-red)]\" data-kid=\"8-1-4\" data-name=\"marquee separator\">•</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--secondary-gray)]\" data-kid=\"8-1-5\" data-name=\"marquee item\">Technical Paper Trail</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--accent-red)]\" data-kid=\"8-1-6\" data-name=\"marquee separator\">•</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--secondary-gray)]\" data-kid=\"8-1-7\" data-name=\"marquee item\">Legal Advisory</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--accent-red)]\" data-kid=\"8-1-8\" data-name=\"marquee separator\">•</span>\n\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--secondary-gray)]\" data-kid=\"8-1-9\" data-name=\"marquee item\">Direct Claims Hub</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--accent-red)]\" data-kid=\"8-1-10\" data-name=\"marquee separator\">•</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--secondary-gray)]\" data-kid=\"8-1-11\" data-name=\"marquee item\">RTO Consultation</span>\n<span class=\"text-3xl font-instrument font-black uppercase tracking-tighter mx-12 text-[var(--accent-red)]\" data-kid=\"8-1-12\" data-name=\"marquee separator\">•</span>\n</div>\n</div>\n\n<footer class=\"pt-40 pb-20 px-12 bg-black border-t border-[var(--border-dark)] relative\" data-kid=\"9\" data-name=\"footer container\">\n<div class=\"max-w-7xl mx-auto\" data-kid=\"9-1\" data-name=\"footer content wrapper\">\n<div class=\"grid grid-cols-12 gap-16 mb-40\" data-kid=\"9-1-1\" data-name=\"footer top grid\">\n<div class=\"col-span-12 lg:col-span-6\" data-kid=\"9-1-1-1\" data-name=\"brand info column\">\n<h2 class=\"font-instrument text-8xl font-black uppercase tracking-tighter leading-[0.85] mb-12\" data-kid=\"9-1-1-1-1\" data-name=\"footer brand headline\">Krishna<br data-kid=\"9-1-1-1-1-1\" data-name=\"brand name line break\"><span class=\"text-[var(--accent-red)]\" data-kid=\"9-1-1-1-1-2\" data-name=\"footer brand category\">Automobile</span></h2>\n<p class=\"text-xl text-[var(--secondary-gray)] font-medium max-w-md leading-relaxed\" data-kid=\"9-1-1-1-2\" data-name=\"footer description\">\n          Trusted mechanical engineering and legal consulting in Mumbai since 2009. Precision-driven services for the modern rider.\n        </p>\n</div>\n<div class=\"col-span-12 lg:col-span-6 grid grid-cols-1 sm:grid-cols-3 gap-12\" data-kid=\"9-1-1-2\" data-name=\"footer links and contacts grid\">\n<div data-kid=\"9-1-1-2-1\" data-name=\"navigation group\">\n<h4 class=\"font-mono text-[10px] font-bold text-[var(--accent-red)] uppercase tracking-[0.3em] mb-8\" data-kid=\"9-1-1-2-1-1\" data-name=\"navigation title\">Navigation</h4>\n<ul class=\"space-y-4\" data-kid=\"9-1-1-2-1-2\" data-name=\"navigation link list\">\n<li data-kid=\"9-1-1-2-1-2-1\" data-name=\"link item wrapper\"><a class=\"font-mono text-xs font-bold uppercase hover:text-[var(--accent-red)] transition-colors\" data-kid=\"9-1-1-2-1-2-1-1\" data-name=\"navigation link\" href=\"#\">Inventory</a></li>\n<li data-kid=\"9-1-1-2-1-2-2\" data-name=\"link item wrapper\"><a class=\"font-mono text-xs font-bold uppercase hover:text-[var(--accent-red)] transition-colors\" data-kid=\"9-1-1-2-1-2-2-1\" data-name=\"navigation link\" href=\"#\">Workshop</a></li>\n<li data-kid=\"9-1-1-2-1-2-3\" data-name=\"link item wrapper\"><a class=\"font-mono text-xs font-bold uppercase hover:text-[var(--accent-red)] transition-colors\" data-kid=\"9-1-1-2-1-2-3-1\" data-name=\"navigation link\" href=\"#\">Legal Hub</a></li>\n<li data-kid=\"9-1-1-2-1-2-4\" data-name=\"link item wrapper\"><a class=\"font-mono text-xs font-bold uppercase hover:text-[var(--accent-red)] transition-colors\" data-kid=\"9-1-1-2-1-2-4-1\" data-name=\"navigation link\" href=\"#\">About Us</a></li>\n</ul>\n</div>\n<div data-kid=\"9-1-1-2-2\" data-name=\"contacts group\">\n<h4 class=\"font-mono text-[10px] font-bold text-[var(--accent-red)] uppercase tracking-[0.3em] mb-8\" data-kid=\"9-1-1-2-2-1\" data-name=\"contacts title\">Contacts</h4>\n<ul class=\"space-y-4\" data-kid=\"9-1-1-2-2-2\" data-name=\"contact detail list\">\n<li class=\"font-mono text-xs font-bold uppercase\" data-kid=\"9-1-1-2-2-2-1\" data-name=\"phone number one\">093222 45569</li>\n<li class=\"font-mono text-xs font-bold uppercase\" data-kid=\"9-1-1-2-2-2-2\" data-name=\"phone number two\">090827 44210</li>\n<li class=\"font-mono text-[10px] font-bold text-[var(--secondary-gray)] leading-relaxed uppercase\" data-kid=\"9-1-1-2-2-2-3\" data-name=\"address\">Hatkesh, Mira Road East, Thane 401107</li>\n</ul>\n</div>\n<div class=\"col-span-2 md:col-span-1\" data-kid=\"9-1-1-2-3\" data-name=\"availability group\">\n<h4 class=\"font-mono text-[10px] font-bold text-[var(--accent-red)] uppercase tracking-[0.3em] mb-8\" data-kid=\"9-1-1-2-3-1\" data-name=\"availability title\">Availability</h4>\n<div class=\"p-6 border border-[var(--border-dark)] bg-[var(--surface)]\" data-kid=\"9-1-1-2-3-2\" data-name=\"hours card\">\n<p class=\"font-mono text-[10px] font-bold uppercase mb-2\" data-kid=\"9-1-1-2-3-2-1\" data-name=\"days text\">MON - SUN</p>\n<p class=\"font-instrument font-black text-xl uppercase tracking-tighter\" data-kid=\"9-1-1-2-3-2-2\" data-name=\"time text\">9AM — 9PM</p>\n<span class=\"inline-block mt-4 bg-[var(--accent-red)] text-white font-mono text-[8px] font-bold px-2 py-1 uppercase tracking-widest\" data-kid=\"9-1-1-2-3-2-3\" data-name=\"always open badge\">Always Open</span>\n</div>\n</div>\n</div>\n</div>\n<div class=\"flex flex-col md:flex-row justify-between items-center pt-12 border-t border-[var(--border-dark)] gap-8\" data-kid=\"9-1-2\" data-name=\"footer bottom bar\">\n<div class=\"flex items-center gap-4\" data-kid=\"9-1-2-1\" data-name=\"copyright container\">\n<div class=\"w-4 h-4 bg-[var(--accent-red)]\" data-kid=\"9-1-2-1-1\" data-name=\"copyright icon\"></div>\n<span class=\"font-mono text-[10px] text-[var(--secondary-gray)] uppercase tracking-widest\" data-kid=\"9-1-2-1-2\" data-name=\"copyright text\">© 2024 Krishna Automobile / Mumbai Hub</span>\n</div>\n<div class=\"flex gap-12 font-mono text-[10px] font-bold text-[var(--secondary-gray)] uppercase\" data-kid=\"9-1-2-2\" data-name=\"footer meta links container\">\n<a class=\"hover:text-[var(--accent-red)] transition-colors\" data-kid=\"9-1-2-2-1\" data-name=\"privacy policy link\" href=\"#\">Privacy Protocol</a>\n<a class=\"hover:text-[var(--accent-red)] transition-colors\" data-kid=\"9-1-2-2-2\" data-name=\"terms of operation link\" href=\"#\">Terms of Operation</a>\n</div>\n</div>\n</div>\n</footer>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"11\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"12\"></script>\n<script type=\"module\" data-kid=\"13\">\n  import Lenis from \"https://esm.sh/lenis@1\";\n  \n  // Smooth Scroll\n  const lenis = new Lenis();\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Scroll Progress Bar\n  gsap.to(\"#progress-bar\", {\n    width: \"100%\",\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \"body\",\n      start: \"top top\",\n      end: \"bottom bottom\",\n      scrub: 0.3\n    }\n  });\n\n  // Hero Entrance\n  const heroTl = gsap.timeline();\n  heroTl.from(\".translate-y-reveal\", {\n    y: 50,\n    opacity: 0,\n    duration: 1,\n    ease: \"power4.out\"\n  })\n  .from(\".staggered-reveal\", {\n    y: 100,\n    opacity: 0,\n    duration: 1.5,\n    stagger: 0.2,\n    ease: \"expo.out\"\n  }, \"-=0.5\");\n\n  // Scroll Reveals\n  gsap.utils.toArray(\".scroll-reveal\").forEach(el => {\n    gsap.from(el, {\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 85%\",\n        toggleActions: \"play none none reverse\"\n      },\n      y: 60,\n      opacity: 0,\n      duration: 1.2,\n      ease: \"power3.out\"\n    });\n  });\n\n  // Parallax Watermarks\n  gsap.to(\".font-instrument.text-[300px]\", {\n    x: -100,\n    scrollTrigger: {\n      trigger: \"section\",\n      start: \"top top\",\n      end: \"bottom top\",\n      scrub: 1\n    }\n  });\n</script>\n",
