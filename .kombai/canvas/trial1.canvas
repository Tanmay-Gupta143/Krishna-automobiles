      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');\n\n  :root {\n    --color-background: #000000;\n    --color-surface: #0a0a0a;\n    --color-primary: #ffffff;\n    --color-secondary: #999999;\n    --color-accent: #ff0000;\n    --color-border: #1f1f1f;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--color-background);\n    color: var(--color-primary);\n    font-family: 'Inter', sans-serif;\n  }\n\n  .brutalist-grid {\n    background-image: \n      linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .scanline {\n    width: 100%;\n    height: 100px;\n    z-index: 100;\n    background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(255, 0, 0, 0.03) 50%, rgba(0, 0, 0, 0) 100%);\n    opacity: 0.1;\n    position: fixed;\n    bottom: 100%;\n    pointer-events: none;\n    animation: scanline 8s linear infinite;\n  }\n\n  @keyframes scanline {\n    0% { bottom: 100%; }\n    100% { bottom: -100px; }\n  }\n\n  .text-tight {\n    letter-spacing: -0.04em;\n  }\n\n  .label-text {\n    letter-spacing: 0.2em;\n    font-size: 11px;\n  }\n\n  /* Custom Scrollbar for the technical feel */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #000;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #1f1f1f;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: #ff0000;\n  }\n\n  .glow-red {\n    box-shadow: 0 0 20px rgba(255, 0, 0, 0.15);\n  }\n\n  .line-extend {\n    width: 100vw;\n    margin-left: calc(50% - 50vw);\n  }\n</style>\n\n<div class=\"min-h-screen bg-black overflow-x-clip brutalist-grid selection:bg-red-600 selection:text-white relative\" data-kid=\"1\">\n  <div class=\"scanline\" data-kid=\"2\"></div>\n  \n  \n  <nav class=\"border-b border-white/10 py-6 px-10 flex justify-between items-center sticky top-0 bg-black/80 backdrop-blur-md z-50\" data-kid=\"3\">\n    <div class=\"flex items-center gap-2\" data-kid=\"4\">\n      <div class=\"w-8 h-8 bg-white flex items-center justify-center rounded-sm\" data-kid=\"5\">\n        <span class=\"text-black font-bold text-xs\" data-kid=\"6\">KA</span>\n      </div>\n      <span class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"7\">Krishna Automobile</span>\n    </div>\n    <div class=\"flex gap-8 text-[11px] uppercase tracking-widest font-semibold text-gray-400\" data-kid=\"8\">\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"9\">Home</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"10\">Services</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"11\">Insurance</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"12\">About</a>\n      <a href=\"#\" class=\"text-white border-b border-red-600 pb-1\" data-kid=\"13\">Contact</a>\n    </div>\n  </nav>\n\n  <main class=\"max-w-7xl mx-auto px-6 py-24 relative\" data-kid=\"14\">\n    \n    \n    <header class=\"mb-24 relative\" data-kid=\"15\">\n      <div class=\"flex items-center gap-6 mb-12\" data-kid=\"16\">\n        <span class=\"text-6xl font-bold tracking-tighter text-white/20\" data-kid=\"17\">05</span>\n        <div class=\"h-[1px] flex-grow bg-white/10\" data-kid=\"18\"></div>\n        <div class=\"flex items-center gap-3\" data-kid=\"19\">\n          <span class=\"w-2 h-2 bg-red-600 rounded-full animate-ping\" data-kid=\"20\"></span>\n          <span class=\"label-text font-bold uppercase text-red-600\" data-kid=\"21\">Secure Channel Active</span>\n        </div>\n      </div>\n      \n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-end\" data-kid=\"22\">\n        <div class=\"lg:col-span-8\" data-kid=\"23\">\n          <h1 class=\"text-[100px] md:text-[160px] font-bold leading-[0.8] text-tight uppercase animate-entrance-text\" data-kid=\"24\">\n            Reach<br data-kid=\"25\"><span class=\"text-red-600 italic\" data-kid=\"26\">Out.</span>\n          </h1>\n        </div>\n        <div class=\"lg:col-span-4 pb-6\" data-kid=\"27\">\n          <p class=\"text-white max-w-sm text-sm leading-relaxed border-l border-red-600 pl-6\" data-kid=\"28\">\n            We operate an inclusive, professional workshop in Mira Road East. Open 7 days a week for all your two-wheeler needs.\n          </p>\n        </div>\n      </div>\n    </header>\n\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 relative\" data-kid=\"29\">\n      \n      \n      <div class=\"lg:col-span-5 space-y-16\" data-kid=\"30\">\n        \n        \n        <section class=\"group\" data-kid=\"31\">\n          <p class=\"label-text text-gray-500 mb-6 font-bold uppercase\" data-kid=\"32\">Workstation Location</p>\n          <div class=\"flex gap-6 items-start\" data-kid=\"33\">\n            <div class=\"w-10 h-10 border border-white/10 rounded-full flex items-center justify-center shrink-0 group-hover:border-red-600 transition-colors\" data-kid=\"34\">\n              <svg class=\"w-4 h-4 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"35\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z\" data-kid=\"36\"></path><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 11a3 3 0 11-6 0 3 3 0 016 0z\" data-kid=\"37\"></path></svg>\n            </div>\n            <div data-kid=\"38\">\n              <p class=\"text-2xl font-medium leading-snug\" data-kid=\"39\">\n                Shop No.11, Gaurav sankalp chintan 11, hatkesh, Mira Road East, Thane, Maharashtra 401107, IN.\n              </p>\n            </div>\n          </div>\n        </section>\n\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"40\">\n          <section class=\"group\" data-kid=\"41\">\n            <p class=\"label-text text-gray-500 mb-6 font-bold uppercase\" data-kid=\"42\">Direct Comms</p>\n            <div class=\"space-y-4\" data-kid=\"43\">\n              <div class=\"flex items-center gap-3\" data-kid=\"44\">\n                <span class=\"text-red-600 font-mono text-xs\" data-kid=\"45\">P:</span>\n                <p class=\"text-xl font-bold tracking-tight\" data-kid=\"46\">093222 45569</p>\n              </div>\n              <div class=\"flex items-center gap-3\" data-kid=\"47\">\n                <span class=\"text-gray-500 font-mono text-xs\" data-kid=\"48\">S:</span>\n                <p class=\"text-xl font-bold tracking-tight\" data-kid=\"49\">090827 44210</p>\n              </div>\n            </div>\n          </section>\n\n          <section data-kid=\"50\">\n            <p class=\"label-text text-gray-500 mb-6 font-bold uppercase\" data-kid=\"51\">Uptime</p>\n            <div class=\"space-y-2\" data-kid=\"52\">\n              <p class=\"text-xl font-bold\" data-kid=\"53\">Mon - Sun</p>\n              <p class=\"text-xl font-bold text-red-600\" data-kid=\"54\">9:00 AM – 9:30 PM</p>\n            </div>\n          </section>\n        </div>\n\n        \n        <section class=\"p-8 bg-[#0a0a0a] border border-white/10 rounded-xl relative overflow-hidden group\" data-kid=\"55\">\n          <div class=\"absolute -right-4 -bottom-4 opacity-10 group-hover:opacity-20 transition-opacity text-red-600\" data-kid=\"56\">\n            <svg class=\"w-24 h-24\" fill=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"57\"><path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z\" data-kid=\"58\"></path></svg>\n          </div>\n          <p class=\"label-text text-red-600 mb-4 font-bold uppercase\" data-kid=\"59\">Financial Protocol</p>\n          <p class=\"text-xl font-bold mb-4 tracking-tight\" data-kid=\"60\">Payment Methods Notice</p>\n          <div class=\"space-y-4 mb-8\" data-kid=\"61\">\n            <p class=\"text-gray-400 text-sm leading-relaxed\" data-kid=\"62\">\n              To maintain low service costs, we utilize direct settlement protocols.\n            </p>\n            <div class=\"flex gap-2\" data-kid=\"63\">\n              <span class=\"px-3 py-1 bg-white/5 border border-white/10 rounded text-[10px] font-bold text-white uppercase tracking-widest\" data-kid=\"64\">Cash Accepted</span>\n              <span class=\"px-3 py-1 bg-white/5 border border-white/10 rounded text-[10px] font-bold text-white uppercase tracking-widest\" data-kid=\"65\">Tez / GPay</span>\n            </div>\n          </div>\n          <div class=\"bg-red-600/10 p-5 border-l-4 border-red-600 text-xs font-mono text-red-400 flex items-start gap-3\" data-kid=\"66\">\n             <svg class=\"w-4 h-4 shrink-0 mt-0.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"67\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" data-kid=\"68\"></path></svg>\n             <span class=\"font-bold tracking-tight\" data-kid=\"69\">NOTICE: CREDIT AND DEBIT CARDS ARE STRICTLY NOT ACCEPTED.</span>\n          </div>\n        </section>\n\n      </div>\n\n      \n      <div class=\"lg:col-span-7\" data-kid=\"70\">\n        <div id=\"form-container\" class=\"bg-[#0a0a0a] border border-white/10 p-8 md:p-12 rounded-2xl relative shadow-2xl\" data-kid=\"71\">\n          \n          <div class=\"flex justify-between items-start mb-12\" data-kid=\"72\">\n            <div data-kid=\"73\">\n              <h2 class=\"text-4xl font-bold text-tight uppercase italic mb-2\" data-kid=\"74\">Contact Form</h2>\n              <p class=\"text-xs text-gray-400 font-mono uppercase tracking-widest\" data-kid=\"75\">Digital Dispatch System</p>\n            </div>\n            <div class=\"hidden md:block\" data-kid=\"76\">\n              <div class=\"w-12 h-12 flex items-center justify-center border border-red-600/30 rounded-lg\" data-kid=\"77\">\n                <svg class=\"w-6 h-6 text-red-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"78\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\" data-kid=\"79\"></path></svg>\n              </div>\n            </div>\n          </div>\n\n          <form action=\"https://api.web3forms.com/submit\" method=\"POST\" class=\"space-y-8\" data-kid=\"80\">\n            \n            <input type=\"hidden\" name=\"access_key\" value=\"YOUR_ACCESS_KEY_HERE\" data-kid=\"81\">\n            \n            <input type=\"checkbox\" name=\"botcheck\" class=\"hidden\" style=\"display: none;\" data-kid=\"82\">\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"83\">\n              \n              <div class=\"space-y-2 group\" data-kid=\"84\">\n                <label for=\"name\" class=\"label-text font-bold uppercase text-gray-400 group-focus-within:text-red-600\" data-kid=\"85\">Full Name</label>\n                <input type=\"text\" name=\"name\" id=\"name\" required class=\"w-full bg-black border-b border-white/30 focus:border-red-600 py-4 text-white outline-hidden transition-all placeholder:text-gray-400\" placeholder=\"e.g. Rahul Sharma\" data-kid=\"86\">\n              </div>\n\n              \n              <div class=\"space-y-2 group\" data-kid=\"87\">\n                <label for=\"phone\" class=\"label-text font-bold uppercase text-gray-400 group-focus-within:text-red-600\" data-kid=\"88\">Phone Number</label>\n                <input type=\"tel\" name=\"phone\" id=\"phone\" required class=\"w-full bg-black border-b border-white/30 focus:border-red-600 py-4 text-white outline-hidden transition-all placeholder:text-gray-400\" placeholder=\"+91 00000 00000\" data-kid=\"89\">\n              </div>\n            </div>\n\n            \n            <div class=\"space-y-2 group\" data-kid=\"90\">\n              <label for=\"vehicle\" class=\"label-text font-bold uppercase text-gray-400 group-focus-within:text-red-600\" data-kid=\"91\">Vehicle Model</label>\n              <input type=\"text\" name=\"vehicle\" id=\"vehicle\" required class=\"w-full bg-black border-b border-white/30 focus:border-red-600 py-4 text-white outline-hidden transition-all placeholder:text-gray-400\" placeholder=\"e.g. Honda Activa 6G\" data-kid=\"92\">\n            </div>\n\n            \n            <div class=\"space-y-2 group\" data-kid=\"93\">\n              <label for=\"message\" class=\"label-text font-bold uppercase text-gray-400 group-focus-within:text-red-600\" data-kid=\"94\">Message / Service Needed</label>\n              <textarea name=\"message\" id=\"message\" rows=\"5\" class=\"w-full bg-black border border-white/20 rounded-xl p-4 focus:border-red-600 text-white outline-hidden transition-all placeholder:text-gray-400 resize-none\" placeholder=\"Tell us about the issue or service you need...\" data-kid=\"95\"></textarea>\n            </div>\n\n            \n            <div class=\"pt-6\" data-kid=\"96\">\n              <button type=\"submit\" class=\"group relative w-full bg-white text-black font-bold py-6 rounded-full overflow-hidden transition-all hover:bg-red-600 hover:text-white\" data-kid=\"97\">\n                <span class=\"relative z-10 uppercase tracking-widest flex items-center justify-center gap-3\" data-kid=\"98\">\n                  Submit Request\n                  <svg class=\"w-5 h-5 group-hover:translate-x-2 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"99\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\" data-kid=\"100\"></path></svg>\n                </span>\n              </button>\n            </div>\n\n            <p class=\"text-[10px] text-center text-gray-600 font-mono uppercase\" data-kid=\"101\">Encryption: AES-256 Enabled | Status: READY</p>\n          </form>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-20 border-t border-white/10 pt-12 line-extend overflow-hidden\" data-kid=\"102\">\n      <div class=\"flex whitespace-nowrap animate-marquee\" data-kid=\"103\">\n        <div class=\"flex gap-20 items-center px-10\" data-kid=\"104\">\n          <span class=\"text-4xl font-bold uppercase text-white/20 italic\" data-kid=\"105\">Trusted Service</span>\n          <span class=\"w-3 h-3 bg-red-600 rounded-full\" data-kid=\"106\"></span>\n          <span class=\"text-4xl font-bold uppercase text-white/20 italic\" data-kid=\"107\">Genuine Spares</span>\n          <span class=\"w-3 h-3 bg-red-600 rounded-full\" data-kid=\"108\"></span>\n          <span class=\"text-4xl font-bold uppercase text-white/20 italic\" data-kid=\"109\">Mira Road East</span>\n          <span class=\"w-3 h-3 bg-red-600 rounded-full\" data-kid=\"110\"></span>\n          <span class=\"text-4xl font-bold uppercase text-white/20 italic\" data-kid=\"111\">Since 2009</span>\n          <span class=\"w-4 h-4 bg-red-600 rounded-full\" data-kid=\"112\"></span>\n        </div>\n        \n        <div class=\"flex gap-20 items-center px-10\" data-kid=\"113\">\n          <span class=\"text-4xl font-bold uppercase text-white/20 italic\" data-kid=\"114\">Trusted Service</span>\n          <span class=\"w-3 h-3 bg-red-600 rounded-full\" data-kid=\"115\"></span>\n          <span class=\"text-4xl font-bold uppercase text-white/20 italic\" data-kid=\"116\">Genuine Spares</span>\n          <span class=\"w-3 h-3 bg-red-600 rounded-full\" data-kid=\"117\"></span>\n          <span class=\"text-4xl font-bold uppercase text-white/20 italic\" data-kid=\"118\">Mira Road East</span>\n          <span class=\"w-3 h-3 bg-red-600 rounded-full\" data-kid=\"119\"></span>\n          <span class=\"text-4xl font-bold uppercase text-white/20 italic\" data-kid=\"120\">Since 2009</span>\n          <span class=\"w-4 h-4 bg-red-600 rounded-full\" data-kid=\"121\"></span>\n        </div>\n      </div>\n    </div>\n\n  </main>\n\n  \n  <footer class=\"bg-[#050505] border-t border-white/10 py-16 px-10 mt-20\" data-kid=\"122\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12\" data-kid=\"123\">\n      <div class=\"space-y-6\" data-kid=\"124\">\n        <div class=\"flex items-center gap-2\" data-kid=\"125\">\n          <div class=\"w-6 h-6 bg-red-600 rounded-sm\" data-kid=\"126\"></div>\n          <span class=\"font-bold uppercase tracking-widest\" data-kid=\"127\">Krishna Automobile</span>\n        </div>\n        <p class=\"text-sm text-gray-500 max-w-xs\" data-kid=\"128\">\n          Keeping Mira Road moving safely since 2009. Quality parts, expert mechanics, transparent service.\n        </p>\n      </div>\n      <div class=\"grid grid-cols-2 md:grid-cols-3 gap-12\" data-kid=\"129\">\n        <div data-kid=\"130\">\n          <h4 class=\"label-text text-white mb-6 uppercase font-bold\" data-kid=\"131\">Quick Links</h4>\n          <ul class=\"text-sm text-gray-500 space-y-3\" data-kid=\"132\">\n            <li data-kid=\"133\"><a href=\"#\" class=\"hover:text-red-600\" data-kid=\"134\">Home</a></li>\n            <li data-kid=\"135\"><a href=\"#\" class=\"hover:text-red-600\" data-kid=\"136\">Services</a></li>\n            <li data-kid=\"137\"><a href=\"#\" class=\"hover:text-red-600\" data-kid=\"138\">Insurance</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"139\">\n          <h4 class=\"label-text text-white mb-6 uppercase font-bold\" data-kid=\"140\">Socials</h4>\n          <ul class=\"text-sm text-gray-500 space-y-3\" data-kid=\"141\">\n            <li data-kid=\"142\"><a href=\"#\" class=\"hover:text-red-600\" data-kid=\"143\">WhatsApp</a></li>\n            <li data-kid=\"144\"><a href=\"#\" class=\"hover:text-red-600\" data-kid=\"145\">Instagram</a></li>\n            <li data-kid=\"146\"><a href=\"#\" class=\"hover:text-red-600\" data-kid=\"147\">Maps</a></li>\n          </ul>\n        </div>\n        <div class=\"col-span-2 md:col-span-1\" data-kid=\"148\">\n          <h4 class=\"label-text text-white mb-6 uppercase font-bold\" data-kid=\"149\">Legal</h4>\n          <p class=\"text-[10px] text-gray-600 font-mono leading-relaxed\" data-kid=\"150\">\n            SYSTEM_VERSION: 5.4.0<br data-kid=\"151\">\n            LICENSE: GARAGE_OPERATIONAL_IN<br data-kid=\"152\">\n            COORD: 19.2813° N, 72.8711° E\n          </p>\n        </div>\n      </div>\n    </div>\n    <div class=\"max-w-7xl mx-auto border-t border-white/5 mt-16 pt-8 flex justify-between items-center text-[10px] text-gray-700 font-mono uppercase tracking-widest\" data-kid=\"153\">\n      <span data-kid=\"154\">© 2024 KRISHNA AUTOMOBILE</span>\n      <span data-kid=\"155\">BUILT FOR PERFORMANCE</span>\n    </div>\n  </footer>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"156\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"157\"></script>\n<script data-kid=\"158\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Entrance animations\n  window.addEventListener('DOMContentLoaded', () => {\n    gsap.from('.animate-entrance-text', {\n      y: 100,\n      opacity: 0,\n      duration: 1.2,\n      ease: 'power4.out',\n      delay: 0.2\n    });\n\n    gsap.from('#form-container', {\n      x: 50,\n      opacity: 0,\n      duration: 1,\n      ease: 'power3.out',\n      scrollTrigger: {\n        trigger: '#form-container',\n        start: 'top 80%'\n      }\n    });\n\n    // Label reveals\n    gsap.from('.label-text', {\n      opacity: 0,\n      x: -20,\n      duration: 0.8,\n      stagger: 0.1,\n      ease: 'power2.out',\n      scrollTrigger: {\n        trigger: '.label-text',\n        start: 'top 90%'\n      }\n    });\n  });\n</script>\n\n<style data-kid=\"159\">\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-marquee {\n    animation: marquee 30s linear infinite;\n  }\n</style>\n",
