    "var_c9a5ba8eea8a": {
      "type": "variant",
      "label": "Testimonials - Bento Grid",
      "parentId": "var_875d06dcbd37",
      "themeId": null,
      "rect": {
        "x": 15034,
        "y": 253,
        "w": 1280,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Instrument+Sans:wght@400;700;900&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --k-color-accent: #ff0000;\n        --k-color-bg-page: #000000;\n        --k-color-bg-surface: #0a0a0a;\n        --k-color-text-primary: #ffffff;\n    }\n\n    body {\n        background-color: var(--k-color-bg-page);\n        color: var(--k-color-text-primary);\n        font-family: 'Inter', sans-serif;\n        margin: 0;\n        overflow-x: clip;\n    }\n\n    .font-instrument { font-family: 'Instrument Sans', sans-serif; }\n    .bento-grid-container {\n        display: grid;\n        grid-template-columns: repeat(5, 1fr);\n        grid-template-rows: repeat(3, minmax(130px, auto));\n        gap: 1.5rem;\n    }\n\n    .bento-card {\n        background: radial-gradient(circle at top left, rgba(255, 255, 255, 0.02), transparent), var(--k-color-bg-surface);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n        border-radius: 20px 0 20px 0;\n        padding: 2rem;\n        position: relative;\n        will-change: transform, opacity;\n        display: flex;\n        flex-direction: column;\n        justify-content: center;\n        transition: border-color 0.4s ease, box-shadow 0.4s ease; /* Transitions for border/shadow only, no transform */\n    }\n\n    .bento-card-hairline {\n        border: 1px solid rgba(255, 255, 255, 0.12);\n    }\n\n    .giant-cell {\n        grid-column: span 3;\n        grid-row: span 3;\n        display: flex;\n        flex-direction: column;\n        justify-content: center;\n        align-items: center;\n        text-align: center;\n        padding: 3rem;\n    }\n\n    .bento-card:hover {\n        border-color: rgba(255, 0, 0, 0.4);\n        box-shadow: 0 0 25px rgba(255, 0, 0, 0.1);\n    }\n\n    .icon-glow {\n        filter: drop-shadow(0 0 8px rgba(255, 0, 0, 0.4));\n    }\n\n    /* Scroll Trigger Hidden State - Using autoAlpha in GSAP to avoid FOUC while following constraints */\n</style>\n<section class=\"py-24 md:py-48 px-6 md:px-8 bg-black border-b border-white/5\" data-kid=\"1\" data-name=\"street verified section with bottom border\" id=\"street-verified\">\n<div class=\"max-w-7xl mx-auto\" data-kid=\"1-1\" data-name=\"section content container\">\n<div class=\"mb-16 md:mb-24\" data-kid=\"1-1-1\" data-name=\"header text group\">\n<span class=\"text-[var(--k-color-accent)] font-black text-xs md:text-sm uppercase tracking-[0.4em] block mb-4\" data-kid=\"1-1-1-1\" data-name=\"customer proof label\">Customer Proof</span>\n<h2 class=\"text-5xl md:text-[9rem] font-black font-instrument tracking-tighter leading-none mb-6\" data-kid=\"1-1-1-2\" data-name=\"hero headline\">Street Verified.</h2>\n<p class=\"text-white/40 max-w-xl font-bold uppercase text-xs md:text-sm tracking-[0.2em] leading-relaxed\" data-kid=\"1-1-1-3\" data-name=\"description text\">The word on the tarmac in Mira Road. Real reviews from real riders.</p>\n</div>\n<div class=\"bento-grid-container\" data-kid=\"1-1-2\" data-name=\"bento grid container\">\n\n<div class=\"bento-card giant-cell bento-card-hairline testimonial-reveal\" data-kid=\"1-1-2-1\" data-name=\"star rating giant card\" id=\"giant-anchor\">\n<div class=\"absolute top-8 left-8\" data-kid=\"1-1-2-1-1\" data-name=\"google icon container\">\n<i class=\"ti ti-brand-google-filled text-5xl text-[var(--k-color-accent)] opacity-40 icon-glow\" data-kid=\"1-1-2-1-1-1\" data-name=\"google logo icon\"></i>\n</div>\n<h3 class=\"text-[clamp(6rem,12vw,12rem)] font-black font-instrument leading-none tracking-tighter mb-4\" data-kid=\"1-1-2-1-2\" data-name=\"rating value text\">4.8</h3>\n<div class=\"flex gap-2 mb-6\" data-kid=\"1-1-2-1-3\" data-name=\"star rating row\">\n<i class=\"ti ti-star-filled text-3xl md:text-4xl text-[var(--k-color-accent)]\" data-kid=\"1-1-2-1-3-1\" data-name=\"star icon 1\"></i>\n<i class=\"ti ti-star-filled text-3xl md:text-4xl text-[var(--k-color-accent)]\" data-kid=\"1-1-2-1-3-2\" data-name=\"star icon 2\"></i>\n<i class=\"ti ti-star-filled text-3xl md:text-4xl text-[var(--k-color-accent)]\" data-kid=\"1-1-2-1-3-3\" data-name=\"star icon 3\"></i>\n<i class=\"ti ti-star-filled text-3xl md:text-4xl text-[var(--k-color-accent)]\" data-kid=\"1-1-2-1-3-4\" data-name=\"star icon 4\"></i>\n<i class=\"ti ti-star-filled text-3xl md:text-4xl text-[var(--k-color-accent)]\" data-kid=\"1-1-2-1-3-5\" data-name=\"star icon 5\"></i>\n</div>\n<p class=\"text-white/40 font-black uppercase tracking-[0.4em] text-xs md:text-sm\" data-kid=\"1-1-2-1-4\" data-name=\"rating source text\">150+ verified reviews in Mira Road</p>\n</div>\n\n<div class=\"bento-card col-span-2 row-span-1 bento-card-hairline testimonial-reveal\" data-kid=\"1-1-2-2\" data-name=\"ev expert testimonial card\">\n<div class=\"flex justify-between items-center mb-4\" data-kid=\"1-1-2-2-1\" data-name=\"card header\">\n<div class=\"flex items-center gap-2\" data-kid=\"1-1-2-2-1-1\" data-name=\"category badge container\">\n<i class=\"ti ti-plug-connected text-2xl text-[var(--k-color-accent)]\" data-kid=\"1-1-2-2-1-1-1\" data-name=\"electric plug icon\"></i>\n<span class=\"text-[var(--k-color-accent)] text-[10px] font-black uppercase tracking-tighter\" data-kid=\"1-1-2-2-1-1-2\" data-name=\"category label\">EV Repair</span>\n</div>\n<span class=\"text-[10px] font-black text-white/20 uppercase tracking-widest\" data-kid=\"1-1-2-2-1-2\" data-name=\"source label\">Verified Review</span>\n</div>\n<p class=\"text-lg font-bold leading-tight mb-4 text-white/90\" data-kid=\"1-1-2-2-2\" data-name=\"testimonial body text\">\"Best electric scooty service... My ola is repaired Good.\"</p>\n<div class=\"flex items-center gap-3 mt-auto\" data-kid=\"1-1-2-2-3\" data-name=\"card author footer\">\n<div class=\"w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-xs font-black text-[var(--k-color-accent)] shadow-inner\" data-kid=\"1-1-2-2-3-1\" data-name=\"author initials badge\">PJ</div>\n<span class=\"text-xs font-black text-white/50 uppercase tracking-widest\" data-kid=\"1-1-2-2-3-2\" data-name=\"author name\">Paresh Jani</span>\n</div>\n</div>\n\n<div class=\"bento-card col-span-2 row-span-1 bento-card-hairline testimonial-reveal\" data-kid=\"1-1-2-3\" data-name=\"mechanical precision testimonial card\">\n<div class=\"flex justify-between items-center mb-4\" data-kid=\"1-1-2-3-1\" data-name=\"card header\">\n<div class=\"flex items-center gap-2\" data-kid=\"1-1-2-3-1-1\" data-name=\"category badge container\">\n<i class=\"ti ti-tool text-2xl text-[var(--k-color-accent)]\" data-kid=\"1-1-2-3-1-1-1\" data-name=\"tool icon\"></i>\n<span class=\"text-[var(--k-color-accent)] text-[10px] font-black uppercase tracking-tighter\" data-kid=\"1-1-2-3-1-1-2\" data-name=\"category label\">Mechanical</span>\n</div>\n<span class=\"text-[10px] font-black text-white/20 uppercase tracking-widest\" data-kid=\"1-1-2-3-1-2\" data-name=\"card label\">Master Class</span>\n</div>\n<p class=\"text-lg font-bold leading-tight mb-4 text-white/90\" data-kid=\"1-1-2-3-2\" data-name=\"testimonial body text\">\"Excellent garage! Very skilled mechanics. Bike runs smoothly now.\"</p>\n<div class=\"flex items-center gap-3 mt-auto\" data-kid=\"1-1-2-3-3\" data-name=\"card author footer\">\n<div class=\"w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-xs font-black text-[var(--k-color-accent)] shadow-inner\" data-kid=\"1-1-2-3-3-1\" data-name=\"author initials badge\">AS</div>\n<span class=\"text-xs font-black text-white/50 uppercase tracking-widest\" data-kid=\"1-1-2-3-3-2\" data-name=\"author name\">Asif Sayyed</span>\n</div>\n</div>\n\n<div class=\"bento-card col-span-1 row-span-1 bento-card-hairline testimonial-reveal\" data-kid=\"1-1-2-4\" data-name=\"utility info card\">\n<div class=\"flex items-center gap-2 mb-3\" data-kid=\"1-1-2-4-1\" data-name=\"card header\">\n<i class=\"ti ti-charging-pile text-2xl text-[var(--k-color-accent)]\" data-kid=\"1-1-2-4-1-1\" data-name=\"charging pile icon\"></i>\n<span class=\"text-[var(--k-color-accent)] text-[10px] font-black uppercase\" data-kid=\"1-1-2-4-1-2\" data-name=\"utility label\">Utility</span>\n</div>\n<p class=\"text-xs font-bold text-white/80 leading-snug\" data-kid=\"1-1-2-4-2\" data-name=\"info text\">Kam accha hota hai. EV charging station available.</p>\n</div>\n\n<div class=\"bento-card col-span-1 row-span-1 bento-card-hairline testimonial-reveal\" data-kid=\"1-1-2-5\" data-name=\"performance testimonial card\">\n<div class=\"mb-3\" data-kid=\"1-1-2-5-1\" data-name=\"card header\">\n<span class=\"text-[var(--k-color-accent)] text-[10px] font-black uppercase tracking-widest\" data-kid=\"1-1-2-5-1-1\" data-name=\"card badge\">Hunter 350</span>\n</div>\n<p class=\"text-xs font-bold text-white/80 leading-snug mb-3 italic\" data-kid=\"1-1-2-5-2\" data-name=\"testimonial body text\">\"Good service for my Hunter. Tuning is spot on.\"</p>\n<span class=\"text-[10px] font-black text-white/40 uppercase tracking-widest\" data-kid=\"1-1-2-5-3\" data-name=\"author name\">Sahil Raj</span>\n</div>\n</div>\n</div>\n</section>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"3\"></script>\n<script data-kid=\"4\">\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initial state setup for batch reveals\n    gsap.set(\".testimonial-reveal\", { \n        y: 60,\n        opacity: 0,\n        scale: 0.9\n    });\n\n    // Batch Scroll Trigger\n    ScrollTrigger.batch(\".testimonial-reveal\", {\n        start: \"top 90%\",\n        onEnter: (elements) => {\n            gsap.to(elements, {\n                opacity: 1,\n                y: 0,\n                scale: 1,\n                stagger: 0.08,\n                duration: 1,\n                ease: \"expo.out\",\n                overwrite: true\n            });\n        }\n    });\n\n    // Hover-Lift Logic (GSAP driven for layout, CSS for color/glow)\n    const cards = document.querySelectorAll('.bento-card');\n    cards.forEach(card => {\n        card.addEventListener('mouseenter', () => {\n            gsap.to(card, {\n                y: -8,\n                scale: 1.01,\n                duration: 0.4,\n                ease: \"power2.out\",\n                overwrite: true\n            });\n            // Adding a class for CSS-based border/shadow transitions to avoid GSAP conflict with static CSS transitions\n            card.style.borderColor = \"rgba(255, 0, 0, 0.5)\";\n            card.style.boxShadow = \"0 10px 30px rgba(0, 0, 0, 0.5), 0 0 20px rgba(255, 0, 0, 0.1)\";\n        });\n\n        card.addEventListener('mouseleave', () => {\n            gsap.to(card, {\n                y: 0,\n                scale: 1,\n                duration: 0.4,\n                ease: \"power2.out\",\n                overwrite: true\n            });\n            card.style.borderColor = \"rgba(255, 255, 255, 0.12)\";\n            card.style.boxShadow = \"none\";\n        });\n    });\n</script>\n",
