      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&family=Instrument+Sans:wght@800;900&family=JetBrains+Mono:wght@700&display=swap');\n\n  :root {\n    --crimson: #DC143C;\n    --accent-red: #FF0000;\n    --deep-gray: #050505;\n    --surface: #0A0A0A;\n    --canvas: #000000;\n    --alabaster: #E5E4E2;\n    --secondary-gray: #999999;\n    --border-dark: #1F1F1F;\n  }\n\n  body {\n    background-color: var(--canvas);\n    color: white;\n    font-family: 'Inter', sans-serif;\n    overflow-x: clip;\n    margin: 0;\n  }\n\n  .font-display { font-family: 'Instrument Sans', sans-serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .grid-pattern {\n    background-image: linear-gradient(var(--border-dark) 1px, transparent 1px),\n                      linear-gradient(90deg, var(--border-dark) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .heavy-border-bottom { border-bottom: 4px solid var(--border-dark); }\n  .heavy-border-top { border-top: 4px solid var(--border-dark); }\n  .thin-border { border: 1px solid var(--border-dark); }\n\n  .brutalist-shadow:hover {\n    box-shadow: 12px 12px 0 var(--accent-red);\n    transform: translate(-4px, -4px);\n  }\n\n  .nav-dock-blur {\n    background: rgba(0, 0, 0, 0.9);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border-bottom: 1px solid var(--border-dark);\n  }\n\n  .industrial-corner::after {\n    content: '';\n    position: absolute;\n    top: 0;\n    right: 0;\n    width: 10px;\n    height: 10px;\n    border-top: 2px solid var(--accent-red);\n    border-right: 2px solid var(--accent-red);\n  }\n\n  .technical-label {\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n  }\n\n  .ticker-wrap {\n    overflow: hidden;\n    white-space: nowrap;\n    background: var(--surface);\n    border-top: 1px solid var(--border-dark);\n    border-bottom: 1px solid var(--border-dark);\n    padding: 15px 0;\n  }\n\n  .ticker-content {\n    display: inline-block;\n    animation: ticker 60s linear infinite;\n  }\n\n  @keyframes ticker {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .protocol-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    gap: 2px;\n    background-color: var(--border-dark);\n  }\n\n  .protocol-item {\n    background-color: var(--surface);\n    padding: 50px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .protocol-item:hover .hover-bar {\n    width: 100%;\n  }\n\n  .hover-bar {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    height: 4px;\n    width: 0%;\n    background-color: var(--accent-red);\n    transition: width 0.6s cubic-bezier(0.23, 1, 0.32, 1);\n  }\n\n  .spares-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 2px;\n    background-color: var(--border-dark);\n  }\n\n  .spare-card {\n    background-color: var(--surface);\n    padding: 30px;\n    transition: all 0.3s ease;\n    min-height: 180px;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    position: relative;\n  }\n\n  .spare-card:hover {\n    background-color: var(--accent-red);\n  }\n\n  .spare-card:hover * {\n    color: white !important;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 8px; }\n  ::-webkit-scrollbar-track { background: var(--canvas); }\n  ::-webkit-scrollbar-thumb { background: var(--border-dark); }\n  ::-webkit-scrollbar-thumb:hover { background: var(--accent-red); }\n\n  .lenis.lenis-smooth {\n    height: auto;\n  }\n\n  .lenis.lenis-smooth [data-lenis-prevent] {\n    overscroll-behavior: contain;\n  }\n\n  .lenis.lenis-stopped {\n    overflow: hidden;\n  }\n\n  .lenis.lenis-scrolling iframe {\n    pointer-events: none;\n  }\n</style>\n<div class=\"relative min-h-screen\" data-kid=\"1\">\n\n<div class=\"grid-pattern fixed inset-0 opacity-10 pointer-events-none z-0\" data-kid=\"1-1\"></div>\n\n<nav class=\"sticky top-0 z-[100] nav-dock-blur px-10 py-6 border-b border-white/5 flex items-center justify-between\" data-kid=\"1-2\" data-name=\"navigation header\">\n<div class=\"flex items-center gap-3\" data-kid=\"1-2-1\">\n<div class=\"w-8 h-8 bg-[var(--accent-red)] flex items-center justify-center font-bold italic text-white rounded-xs\" data-kid=\"1-2-1-1\">K</div>\n<span class=\"font-bold tracking-tighter text-xl uppercase\" data-kid=\"1-2-1-2\">Krishna <span class=\"text-[var(--accent-red)]\" data-kid=\"1-2-1-2-1\">Automobile</span></span>\n</div>\n<div class=\"hidden md:flex gap-12 items-center text-[10px] font-bold tracking-[0.2em] uppercase\" data-kid=\"1-2-2\">\n<a class=\"text-[var(--secondary-gray)] hover:text-white transition-colors\" data-kid=\"1-2-2-1\" href=\"#\">Home</a>\n<a class=\"text-[var(--accent-red)]\" data-kid=\"1-2-2-2\" href=\"#\">Services</a>\n<a class=\"text-[var(--secondary-gray)] hover:text-white transition-colors\" data-kid=\"1-2-2-3\" href=\"#\">Insurance</a>\n<a class=\"text-[var(--secondary-gray)] hover:text-white transition-colors\" data-kid=\"1-2-2-4\" href=\"#\">About</a>\n<a class=\"text-[var(--secondary-gray)] hover:text-white transition-colors\" data-kid=\"1-2-2-5\" href=\"#\">Contact</a>\n</div>\n<button class=\"bg-white text-black px-6 py-2 rounded-full font-bold text-[10px] uppercase tracking-widest hover:bg-[var(--accent-red)] hover:text-white transition-all cursor-pointer\" data-kid=\"1-2-3\">Quick Call</button>\n</nav>\n\n<header class=\"relative pt-32 pb-40 px-10 md:px-24 overflow-hidden border-b border-[var(--border-dark)]\" data-kid=\"1-3\">\n<div class=\"relative z-10\" data-kid=\"1-3-1\">\n<div class=\"flex items-center gap-4 mb-12 reveal-up\" data-kid=\"1-3-1-1\">\n<span class=\"text-[var(--accent-red)] font-mono text-4xl font-black\" data-kid=\"1-3-1-1-1\">02</span>\n<div class=\"h-px w-24 bg-[var(--accent-red)]\" data-kid=\"1-3-1-1-2\"></div>\