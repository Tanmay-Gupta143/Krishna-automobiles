      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');\n\n  :root {\n    --color-background: #000000;\n    --color-surface: #0a0a0a;\n    --color-primary: #ffffff;\n    --color-secondary: #999999;\n    --color-accent: #ff0000;\n    --color-border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    background-color: var(--color-background);\n    color: var(--color-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n    overflow-x: clip;\n  }\n\n  .grid-bg {\n    background-image: linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .glow-red {\n    box-shadow: 0 0 50px rgba(255, 0, 0, 0.08);\n  }\n\n  .text-72px { font-size: 72px; }\n  .tracking-tight-custom { letter-spacing: -0.04em; }\n  .tracking-label { letter-spacing: 0.1em; }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-marquee {\n    display: flex;\n    animation: marquee 30s linear infinite;\n  }\n</style>\n\n<div class=\"relative min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <nav class=\"sticky top-0 z-50 bg-black/80 backdrop-blur-md border-b border-[var(--color-border)] px-6 md:px-12 py-6 flex justify-between items-center\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3\" data-kid=\"3\">\n      <div class=\"w-8 h-8 bg-[var(--color-accent)] rounded-xs\" data-kid=\"4\"></div>\n      <span class=\"text-xl font-bold tracking-tight-custom uppercase\" data-kid=\"5\">Krishna Automobile</span>\n    </div>\n    <div class=\"hidden lg:flex gap-10 items-center\" data-kid=\"6\">\n      <a href=\"#\" class=\"text-[11px] font-bold tracking-label uppercase text-[var(--color-secondary)] hover:text-white transition-colors\" data-kid=\"7\">Home</a>\n      <a href=\"#\" class=\"text-[11px] font-bold tracking-label uppercase text-[var(--color-secondary)] hover:text-white transition-colors\" data-kid=\"8\">Services</a>\n      <a href=\"#\" class=\"text-[11px] font-bold tracking-label uppercase text-[var(--color-accent)]\" data-kid=\"9\">Insurance & Legal</a>\n      <a href=\"#\" class=\"text-[11px] font-bold tracking-label uppercase text-[var(--color-secondary)] hover:text-white transition-colors\" data-kid=\"10\">About Us</a>\n      <a href=\"#\" class=\"text-[11px] font-bold tracking-label uppercase text-[var(--color-secondary)] hover:text-white transition-colors\" data-kid=\"11\">Contact Us</a>\n    </div>\n    <div class=\"flex gap-4\" data-kid=\"12\">\n      <button class=\"px-6 py-2 rounded-full border border-white text-white text-[10px] font-bold uppercase tracking-label hover:bg-white hover:text-black transition-all\" data-kid=\"13\">\n        Call Now\n      </button>\n    </div>\n  </nav>\n\n  \n  <section class=\"px-6 md:px-12 pt-48 pb-32 border-b border-[var(--color-border)] grid-bg relative overflow-hidden\" data-kid=\"14\">\n    <div class=\"max-w-7xl mx-auto relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12\" data-kid=\"15\">\n      <div class=\"lg:col-span-8\" data-kid=\"16\">\n        <div class=\"flex items-center gap-4 mb-10\" data-kid=\"17\">\n          <span class=\"w-20 h-[1px] bg-[var(--color-accent)]\" data-kid=\"18\"></span>\n          <span class=\"text-[10px] font-bold tracking-[0.3em] uppercase text-[var(--color-accent)]\" data-kid=\"19\">Specialized Support</span>\n        </div>\n        <h1 class=\"text-7xl md:text-9xl font-black tracking-tight-custom uppercase leading-[0.8] mb-12\" data-kid=\"20\">\n          Insurance <br data-kid=\"21\"> & Legal <span class=\"text-transparent [-webkit-text-stroke:2px_rgba(255,255,255,0.8)] block mt-4\" data-kid=\"22\">Consulting</span>\n        </h1>\n      </div>\n      <div class=\"lg:col-span-4 flex items-end\" data-kid=\"23\">\n        <div class=\"p-8 border border-white/10 bg-black/50 backdrop-blur-xl rounded-xl mb-4\" data-kid=\"24\">\n          <p class=\"text-sm text-[var(--color-secondary)] uppercase tracking-[0.15em] leading-relaxed\" data-kid=\"25\">\n            Professional administrative solutions for accidental claims, legal documentation, and road incident guidance.\n          </p>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"absolute right-[15%] top-0 bottom-0 w-[1px] bg-white/10\" data-kid=\"26\"></div>\n  </section>\n\n  \n  <section class=\"px-6 md:px-12 py-40 border-b border-[var(--color-border)] grid-bg bg-[var(--color-background)]\" data-kid=\"27\">\n    <div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-start\" data-kid=\"28\">\n      <div class=\"lg:col-span-5\" data-kid=\"29\">\n        <div class=\"relative mb-20\" data-kid=\"30\">\n          <span class=\"text-9xl md:text-[180px] font-black tracking-tighter text-white/[0.03] absolute -top-16 -left-8 pointer-events-none select-none\" data-kid=\"31\">01</span>\n          <div class=\"relative z-10 flex items-baseline gap-6\" data-kid=\"32\">\n            <span class=\"text-5xl font-bold tracking-tight-custom text-[var(--color-accent)]\" data-kid=\"33\">01</span>\n            <h2 class=\"text-5xl font-black tracking-tight-custom uppercase\" data-kid=\"34\">Insurance<br data-kid=\"35\">Management</h2>\n          </div>\n        </div>\n        <p class=\"text-xl text-[var(--color-secondary)] leading-relaxed mb-12\" data-kid=\"36\">\n          We manage accidental claims and documentation directly at our workshop to keep vehicle repair stress-free. From surveyor coordination to final settlement, our team handles everything in-house.\n        </p>\n        <div class=\"space-y-6\" data-kid=\"37\">\n          <div class=\"flex items-center gap-6 p-6 border border-[var(--color-border)] rounded-xl bg-[var(--color-surface)] group hover:border-[var(--color-accent)]/50 transition-colors\" data-kid=\"38\">\n            <div class=\"w-12 h-12 flex items-center justify-center border border-[var(--color-accent)] rounded-full text-[var(--color-accent)]\" data-kid=\"39\">\n               <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"40\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" data-kid=\"41\"></path></svg>\n            </div>\n            <div data-kid=\"42\">\n              <h4 class=\"font-bold uppercase tracking-wider text-sm mb-1\" data-kid=\"43\">Direct Claims</h4>\n              <p class=\"text-xs text-[var(--color-secondary)] uppercase tracking-label\" data-kid=\"44\">No workshop-to-agent runaround</p>\n            </div>\n          </div>\n          <div class=\"flex items-center gap-6 p-6 border border-[var(--color-border)] rounded-xl bg-[var(--color-surface)] group hover:border-[var(--color-accent)]/50 transition-colors\" data-kid=\"45\">\n            <div class=\"w-12 h-12 flex items-center justify-center border border-[var(--color-accent)] rounded-full text-[var(--color-accent)]\" data-kid=\"46\">\n               <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"47\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" data-kid=\"48\"></path></svg>\n            </div>\n            <div data-kid=\"49\">\n              <h4 class=\"font-bold uppercase tracking-wider text-sm mb-1\" data-kid=\"50\">Document Support</h4>\n              <p class=\"text-xs text-[var(--color-secondary)] uppercase tracking-label\" data-kid=\"51\">Complete paper trail management</p>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"lg:col-span-7\" data-kid=\"52\">\n        <div class=\"relative aspect-square md:aspect-video bg-[#050505] border border-white/10 rounded-2xl overflow-hidden flex items-center justify-center group glow-red\" data-kid=\"53\">\n          <div class=\"absolute inset-0 opacity-10 pointer-events-none grid-bg\" data-kid=\"54\"></div>\n          <div class=\"z-10 text-center p-12\" data-kid=\"55\">\n            <div class=\"inline-block px-8 py-3 border border-[var(--color-accent)] text-[var(--color-accent)] text-[11px] font-black uppercase tracking-[0.3em] rounded-full mb-12 bg-black/80 backdrop-blur shadow-[0_0_40px_rgba(255,0,0,0.2)]\" data-kid=\"56\">Direct Claims Hub</div>\n            <h3 class=\"text-7xl md:text-8xl font-black tracking-tight-custom uppercase text-white leading-none mb-4 group-hover:scale-105 transition-transform duration-700\" data-kid=\"57\">KRISHNA<br data-kid=\"58\">CLAIMS</h3>\n            <p class=\"text-[var(--color-accent)] font-bold tracking-[0.2em] uppercase text-sm\" data-kid=\"59\">Full Administrative Suite</p>\n          </div>\n          \n          <div class=\"absolute top-0 left-0 w-full h-full pointer-events-none border-[1px] border-white/5 m-4 rounded-xl\" data-kid=\"60\"></div>\n          <div class=\"absolute top-12 left-12 w-32 h-32 border-t border-l border-[var(--color-accent)]/50 group-hover:w-40 group-hover:h-40 transition-all duration-700\" data-kid=\"61\"></div>\n          <div class=\"absolute bottom-12 right-12 w-32 h-32 border-b border-r border-[var(--color-accent)]/50 group-hover:w-40 group-hover:h-40 transition-all duration-700\" data-kid=\"62\"></div>\n          <div class=\"absolute top-1/2 left-8 -translate-y-1/2 flex flex-col gap-4 opacity-40\" data-kid=\"63\">\n            <div class=\"w-1 h-1 bg-white rounded-full\" data-kid=\"64\"></div>\n            <div class=\"w-1 h-1 bg-white rounded-full\" data-kid=\"65\"></div>\n            <div class=\"w-1 h-8 bg-[var(--color-accent)]\" data-kid=\"66\"></div>\n            <div class=\"w-1 h-1 bg-white rounded-full\" data-kid=\"67\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-6 md:px-12 py-40 border-b border-[var(--color-border)] grid-bg overflow-hidden relative bg-[#000000]\" data-kid=\"68\">\n    <div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"69\">\n      <div class=\"relative mb-24\" data-kid=\"70\">\n        <span class=\"text-9xl md:text-[180px] font-black tracking-tighter text-white/[0.03] absolute -top-16 -left-8 pointer-events-none select-none\" data-kid=\"71\">02</span>\n        <div class=\"relative z-10 flex items-baseline gap-6\" data-kid=\"72\">\n          <span class=\"text-5xl font-bold tracking-tight-custom text-[var(--color-accent)]\" data-kid=\"73\">02</span>\n          <h2 class=\"text-5xl font-black tracking-tight-custom uppercase\" data-kid=\"74\">Free Legal Advice</h2>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-20\" data-kid=\"75\">\n        <div data-kid=\"76\">\n          <p class=\"text-3xl font-light leading-tight text-white mb-12\" data-kid=\"77\">\n            Complimentary legal guidance related to two-wheeler ownership, road incidents, transport rules, and vehicle verification.\n          </p>\n          <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4\" data-kid=\"78\">\n          <div class=\"p-6 border border-white/5 bg-[var(--color-surface)] hover:border-[var(--color-accent)]/30 transition-colors cursor-default\" data-kid=\"79\">\n            <span class=\"text-[10px] font-black tracking-[0.2em] uppercase text-[var(--color-accent)] block mb-3\" data-kid=\"80\">Consult 01</span>\n            <span class=\"text-base font-bold uppercase tracking-tight\" data-kid=\"81\">Ownership Transfer</span>\n          </div>\n          <div class=\"p-6 border border-white/5 bg-[var(--color-surface)] hover:border-[var(--color-accent)]/30 transition-colors cursor-default\" data-kid=\"82\">\n            <span class=\"text-[10px] font-black tracking-[0.2em] uppercase text-[var(--color-accent)] block mb-3\" data-kid=\"83\">Consult 02</span>\n            <span class=\"text-base font-bold uppercase tracking-tight\" data-kid=\"84\">RTO Rules & Regs</span>\n          </div>\n          <div class=\"p-6 border border-white/5 bg-[var(--color-surface)] hover:border-[var(--color-accent)]/30 transition-colors cursor-default\" data-kid=\"85\">\n            <span class=\"text-[10px] font-black tracking-[0.2em] uppercase text-[var(--color-accent)] block mb-3\" data-kid=\"86\">Consult 03</span>\n            <span class=\"text-base font-bold uppercase tracking-tight\" data-kid=\"87\">Accident Protocol</span>\n          </div>\n          <div class=\"p-6 border border-white/5 bg-[var(--color-surface)] hover:border-[var(--color-accent)]/30 transition-colors cursor-default\" data-kid=\"88\">\n            <span class=\"text-[10px] font-black tracking-[0.2em] uppercase text-[var(--color-accent)] block mb-3\" data-kid=\"89\">Consult 04</span>\n            <span class=\"text-base font-bold uppercase tracking-tight\" data-kid=\"90\">Vehicle Verification</span>\n          </div>\n          </div>\n        </div>\n        <div class=\"flex flex-col justify-center\" data-kid=\"91\">\n          <div class=\"p-12 border border-white/10 bg-[#080808] relative group overflow-hidden rounded-xl transition-all duration-500 hover:border-[var(--color-accent)]/40\" data-kid=\"92\">\n            <div class=\"relative z-10\" data-kid=\"93\">\n              <div class=\"w-16 h-1 bg-[var(--color-accent)] mb-10 group-hover:w-24 transition-all duration-500\" data-kid=\"94\"></div>\n              <h3 class=\"text-4xl font-black uppercase tracking-tight-custom mb-6\" data-kid=\"95\">Expert RTO<br data-kid=\"96\">Consultation</h3>\n              <p class=\"text-[var(--color-secondary)] mb-12 text-lg leading-relaxed\" data-kid=\"97\">\n                Navigating the Motor Vehicles Act doesn't have to be daunting. Our seasoned experts provide clarity on your rights and responsibilities on the road.\n              </p>\n              <button class=\"w-full py-5 bg-white text-black font-bold uppercase tracking-[0.2em] rounded-full hover:bg-[var(--color-accent)] hover:text-white transition-all text-[11px] shadow-2xl\" data-kid=\"98\">\n                Start Consultation\n              </button>\n            </div>\n            \n            <div class=\"absolute -right-12 -bottom-12 text-[160px] font-black text-white/[0.03] tracking-tighter select-none pointer-events-none group-hover:text-white/[0.05] transition-all duration-1000\" data-kid=\"99\">LEGAL</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"py-12 border-b border-[var(--color-border)] overflow-hidden bg-[var(--color-surface)]\" data-kid=\"100\">\n    <div class=\"animate-marquee whitespace-nowrap\" data-kid=\"101\">\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-secondary)]\" data-kid=\"102\">Insurance Claims</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-accent)]\" data-kid=\"103\">•</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-secondary)]\" data-kid=\"104\">RTO Consultation</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-accent)]\" data-kid=\"105\">•</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-secondary)]\" data-kid=\"106\">Accidental Repair</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-accent)]\" data-kid=\"107\">•</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-secondary)]\" data-kid=\"108\">Free Legal Advice</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-accent)]\" data-kid=\"109\">•</span>\n      \n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-secondary)]\" data-kid=\"110\">Insurance Claims</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-accent)]\" data-kid=\"111\">•</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-secondary)]\" data-kid=\"112\">RTO Consultation</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-accent)]\" data-kid=\"113\">•</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-secondary)]\" data-kid=\"114\">Accidental Repair</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-accent)]\" data-kid=\"115\">•</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-secondary)]\" data-kid=\"116\">Free Legal Advice</span>\n      <span class=\"text-2xl font-bold uppercase tracking-label mx-8 text-[var(--color-accent)]\" data-kid=\"117\">•</span>\n    </div>\n  </div>\n\n  \n  <footer class=\"bg-black text-white px-6 md:px-12 pt-32 pb-12 mt-auto border-t border-[var(--color-border)]\" data-kid=\"118\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"119\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 mb-24\" data-kid=\"120\">\n        <div class=\"lg:col-span-5\" data-kid=\"121\">\n          <h2 class=\"text-5xl font-bold tracking-tight-custom uppercase mb-8 leading-[0.9]\" data-kid=\"122\">Krishna<br data-kid=\"123\">Automobile</h2>\n          <p class=\"text-[var(--color-secondary)] max-w-sm mb-12\" data-kid=\"124\">\n            Trusted two-wheeler repair and legal consulting in Mira Road East since 2009. We keep your machine and your paperwork in top condition.\n          </p>\n          <div class=\"flex gap-4\" data-kid=\"125\">\n             <div class=\"w-10 h-10 border border-[var(--color-border)] rounded-full flex items-center justify-center hover:border-[var(--color-accent)] cursor-pointer group transition-all\" data-kid=\"126\">\n                <span class=\"text-[10px] font-bold uppercase group-hover:text-[var(--color-accent)]\" data-kid=\"127\">WA</span>\n             </div>\n             <div class=\"w-10 h-10 border border-[var(--color-border)] rounded-full flex items-center justify-center hover:border-[var(--color-accent)] cursor-pointer group transition-all\" data-kid=\"128\">\n                <span class=\"text-[10px] font-bold uppercase group-hover:text-[var(--color-accent)]\" data-kid=\"129\">IG</span>\n             </div>\n          </div>\n        </div>\n        <div class=\"lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-12\" data-kid=\"130\">\n          <div data-kid=\"131\">\n            <h4 class=\"text-[10px] font-bold tracking-label uppercase text-[var(--color-accent)] mb-8\" data-kid=\"132\">Navigation</h4>\n            <ul class=\"space-y-4 text-xs font-bold uppercase tracking-label text-[var(--color-secondary)]\" data-kid=\"133\">\n              <li data-kid=\"134\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"135\">Home</a></li>\n              <li data-kid=\"136\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"137\">Services</a></li>\n              <li data-kid=\"138\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"139\">Insurance</a></li>\n              <li data-kid=\"140\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"141\">About Us</a></li>\n              <li data-kid=\"142\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"143\">Contact</a></li>\n            </ul>\n          </div>\n          <div data-kid=\"144\">\n            <h4 class=\"text-[10px] font-bold tracking-label uppercase text-[var(--color-accent)] mb-8\" data-kid=\"145\">Contact</h4>\n            <ul class=\"space-y-4 text-xs font-bold uppercase tracking-label text-[var(--color-secondary)]\" data-kid=\"146\">\n              <li class=\"text-white\" data-kid=\"147\">093222 45569</li>\n              <li class=\"text-white\" data-kid=\"148\">090827 44210</li>\n              <li class=\"normal-case leading-relaxed\" data-kid=\"149\">Shop No.11, Gaurav sankalp chintan 11, hatkesh, Mira Road East, Thane, 401107</li>\n            </ul>\n          </div>\n          <div data-kid=\"150\">\n            <h4 class=\"text-[10px] font-bold tracking-label uppercase text-[var(--color-accent)] mb-8\" data-kid=\"151\">Hours</h4>\n            <ul class=\"space-y-4 text-xs font-bold uppercase tracking-label text-[var(--color-secondary)]\" data-kid=\"152\">\n              <li data-kid=\"153\">Mon - Sun</li>\n              <li class=\"text-white\" data-kid=\"154\">9:00 AM – 9:30 PM</li>\n              <li data-kid=\"155\"><span class=\"bg-[var(--color-accent)] text-white px-3 py-1 font-black text-[9px] uppercase tracking-widest inline-block rounded-xs\" data-kid=\"156\">Open Every Day</span></li>\n            </ul>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"pt-12 border-t border-[var(--color-border)] flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"157\">\n        <span class=\"text-[10px] font-bold tracking-label uppercase text-[var(--color-secondary)]\" data-kid=\"158\">© 2024 Krishna Automobile. All rights reserved.</span>\n        <div class=\"flex gap-8\" data-kid=\"159\">\n          <span class=\"text-[10px] font-bold tracking-label uppercase text-[var(--color-secondary)] hover:text-white cursor-pointer transition-colors\" data-kid=\"160\">Privacy Policy</span>\n          <span class=\"text-[10px] font-bold tracking-label uppercase text-[var(--color-secondary)] hover:text-white cursor-pointer transition-colors\" data-kid=\"161\">Terms of Service</span>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"162\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"163\"></script>\n<script data-kid=\"164\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Animations\n  gsap.from(\"h1\", {\n    duration: 1.5,\n    y: 120,\n    opacity: 0,\n    ease: \"expo.out\",\n    stagger: 0.15\n  });\n\n  gsap.utils.toArray(\"section\").forEach(sec => {\n    gsap.from(sec, {\n      scrollTrigger: {\n        trigger: sec,\n        start: \"top 85%\",\n      },\n      duration: 1.2,\n      opacity: 0,\n      y: 60,\n      ease: \"power2.out\"\n    });\n  });\n\n  // Numbers animation\n  gsap.utils.toArray(\".text-5xl.font-bold\").forEach(num => {\n    gsap.from(num, {\n      scrollTrigger: {\n        trigger: num,\n        start: \"top 90%\",\n      },\n      duration: 1,\n      scale: 0.5,\n      opacity: 0,\n      ease: \"back.out(1.7)\"\n    });\n  });\n</script>\n",
