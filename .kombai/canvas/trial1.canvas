      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Instrument+Sans:ital,wght@0,800;0,900;1,800;1,900&family=JetBrains+Mono:wght@400;700&display=swap');\n\n  :root {\n    --color-crimson: #DC143C;\n    --color-accent-red: #FF0000;\n    --color-deep-gray: #050505;\n    --color-surface: #0A0A0A;\n    --color-canvas: #000000;\n    --color-alabaster: #E5E4E2;\n    --color-secondary-gray: #999999;\n    --color-border-dark: #1F1F1F;\n    --color-white: #FFFFFF;\n  }\n\n  .font-instrument { font-family: 'Instrument Sans', sans-serif; }\n  .font-inter { font-family: 'Inter', sans-serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  body {\n    background-color: var(--color-canvas);\n    color: var(--color-white);\n    margin: 0;\n    padding: 0;\n  }\n\n  .brutalist-grid {\n    background-image: \n      linear-gradient(to right, rgba(255, 0, 0, 0.05) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(255, 0, 0, 0.05) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .technical-grid-coord {\n    position: fixed;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 10px;\n    color: rgba(255, 0, 0, 0.15);\n    z-index: 0;\n    pointer-events: none;\n    white-space: nowrap;\n    text-transform: uppercase;\n  }\n\n  .hover-glow:hover {\n    box-shadow: 0 0 50px rgba(255, 0, 0, 0.15);\n  }\n\n  .hover-brutalist:hover {\n    box-shadow: 12px 12px 0 var(--color-accent-red);\n    transform: translate(-4px, -4px);\n  }\n\n  .scanline {\n    width: 100%;\n    height: 100px;\n    z-index: 100;\n    background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(255, 0, 0, 0.03) 50%, rgba(0, 0, 0, 0) 100%);\n    opacity: 0.1;\n    position: fixed;\n    bottom: 100%;\n    pointer-events: none;\n    animation: scanline 8s linear infinite;\n  }\n\n  @keyframes scanline {\n    0% { bottom: 100%; }\n    100% { bottom: -100px; }\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-marquee {\n    animation: marquee 30s linear infinite;\n  }\n</style>\n<div class=\"min-h-screen brutalist-grid selection:bg-red-600 selection:text-white relative overflow-x-clip font-inter\" data-kid=\"1\">\n<div class=\"scanline\" data-kid=\"1-1\"></div>\n<div class=\"technical-grid-coord top-1/4 left-10 transform -rotate-90 origin-left\" data-kid=\"1-2\" data-name=\"left side fixed coordinate display\">COORD_X: 19.2813 // COORD_Y: 72.8711 // PROTOCOL_05</div>\n<div class=\"technical-grid-coord bottom-1/4 right-10 transform rotate-90 origin-right\" data-kid=\"1-3\" data-name=\"right side fixed coordinate display\">SYSTEM_STATUS: ACTIVE // HUB: MIRA_ROAD_EAST // SEC_LVL: 5</div>\n\n<nav class=\"fixed top-0 left-0 right-0 z-[60] p-6 mix-blend-difference\" data-kid=\"1-4\" data-name=\"global navigation dock\">\n<div class=\"max-w-7xl mx-auto flex justify-between items-center bg-black/50 backdrop-blur-xl border border-white/10 px-8 py-4 rounded-full\" data-kid=\"1-4-1\" data-name=\"navigation container\">\n<div class=\"flex items-center gap-3\" data-kid=\"1-4-1-1\" data-name=\"brand logo and name container\">\n<div class=\"w-8 h-8 bg-white flex items-center justify-center rounded-xs\" data-kid=\"1-4-1-1-1\" data-name=\"brand logo icon container\">\n<span class=\"text-black font-instrument font-black text-xs\" data-kid=\"1-4-1-1-1-1\" data-name=\"brand logo text\">KA</span>\n</div>\n<span class=\"font-instrument font-black uppercase tracking-widest text-sm text-white\" data-kid=\"1-4-1-1-2\" data-name=\"brand name text\">Krishna Automobile</span>\n</div>\n<div class=\"hidden md:flex gap-10\" data-kid=\"1-4-1-2\" data-name=\"navigation link items\">\n<a class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-white/60 hover:text-white transition-colors uppercase\" data-kid=\"1-4-1-2-1\" data-name=\"navigation link home\" href=\"#\">Home</a>\n<a class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-white/60 hover:text-white transition-colors uppercase\" data-kid=\"1-4-1-2-2\" data-name=\"navigation link services\" href=\"#\">Services</a>\n<a class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-white/60 hover:text-white transition-colors uppercase\" data-kid=\"1-4-1-2-3\" data-name=\"navigation link insurance\" href=\"#\">Insurance</a>\n<a class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-white border-b-2 border-red-600 pb-1 uppercase\" data-kid=\"1-4-1-2-4\" data-name=\"navigation link contact active\" href=\"#\">Contact</a>\n</div>\n<div class=\"flex items-center gap-4\" data-kid=\"1-4-1-3\" data-name=\"system status indicator\">\n<span class=\"font-mono text-[10px] text-red-400 font-bold hidden lg:block uppercase tracking-widest\" data-kid=\"1-4-1-3-1\" data-name=\"system status text\">Status: Active</span>\n<div class=\"w-2 h-2 bg-red-600 rounded-full animate-pulse\" data-kid=\"1-4-1-3-2\" data-name=\"system status pulse indicator\"></div>\n</div>\n</div>\n</nav>\n<main class=\"relative z-10 pt-40 pb-20 max-w-7xl mx-auto px-6\" data-kid=\"1-5\">\n\n<section class=\"mb-40 section-reveal\" data-kid=\"1-5-1\" data-name=\"hero section\">\n<div class=\"flex items-center gap-6 mb-12\" data-kid=\"1-5-1-1\" data-name=\"hero section header indicator\">\n<div class=\"flex items-center gap-4 font-mono text-[11px] text-red-600 font-bold tracking-[0.2em]\" data-kid=\"1-5-1-1-1\" data-name=\"hero section numbering and protocol\">\n<span data-kid=\"1-5-1-1-1-1\" data-name=\"protocol identifier text\">PRTCL_05</span>\n<div class=\"w-1.5 h-1.5 bg-red-600\" data-kid=\"1-5-1-1-1-2\" data-name=\"protocol separator dot\"></div>\n</div>\n<div class=\"h-[1px] flex-grow bg-white/20\" data-kid=\"1-5-1-1-2\" data-name=\"hero section decorative line\"></div>\n<div class=\"flex items-center gap-2\" data-kid=\"1-5-1-1-3\" data-name=\"communication protocol indicator\">\n<span class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-red-500 uppercase\" data-kid=\"1-5-1-1-3-1\" data-name=\"protocol text\">Secure Communication Active</span>\n</div>\n</div>\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-end\" data-kid=\"1-5-1-2\" data-name=\"hero content grid\">\n<div class=\"lg:col-span-8\" data-kid=\"1-5-1-2-1\" data-name=\"hero headline container\">\n<h1 class=\"text-[100px] md:text-[160px] font-instrument font-black leading-[0.85] tracking-[-0.08em] text-white uppercase animate-text\" data-kid=\"1-5-1-2-1-1\" data-name=\"hero main headline\">\n            REACH<br data-kid=\"1-5-1-2-1-1-1\" data-name=\"hero headline line break\"><span class=\"text-red-600 italic\" data-kid=\"1-5-1-2-1-1-2\" data-name=\"hero headline italic highlight\">OUT.</span>\n</h1>\n</div>\n<div class=\"lg:col-span-4 border-l-2 border-red-600 pl-8 mb-6\" data-kid=\"1-5-1-2-2\" data-name=\"hero description block\">\n<p class=\"font-inter text-xl text-white/70 leading-relaxed font-medium\" data-kid=\"1-5-1-2-2-1\" data-name=\"hero description text\">\n            Deploy your request via the Digital Dispatch System. Our mechanics operate at surgical precision, 7 days a week in Mira Road East.\n          </p>\n</div>\n</div>\n</section>\n\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 relative\" data-kid=\"1-5-2\" data-name=\"operational core layout\">\n\n<div class=\"lg:col-span-5 space-y-20 section-reveal\" data-kid=\"1-5-2-1\" data-name=\"left column location and intel\">\n<section class=\"group\" data-kid=\"1-5-2-1-1\" data-name=\"workstation location section\">\n<h4 class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-gray-500 uppercase mb-8 group-hover:text-red-600 transition-colors\" data-kid=\"1-5-2-1-1-1\" data-name=\"workstation header text\">Workstation Location</h4>\n<div class=\"flex gap-8 items-start\" data-kid=\"1-5-2-1-1-2\" data-name=\"workstation address block\">\n<div class=\"w-12 h-12 border border-white/10 flex items-center justify-center shrink-0 group-hover:border-red-600 transition-colors\" data-kid=\"1-5-2-1-1-2-1\" data-name=\"map pin icon container\">\n<svg class=\"w-5 h-5 text-red-600\" data-kid=\"1-5-2-1-1-2-1-1\" data-name=\"map pin icon\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" data-kid=\"4\"></path><path d=\"M15 11a3 3 0 11-6 0 3 3 0 016 0z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" data-kid=\"5\"></path></svg>\n</div>\n<p class=\"text-2xl font-instrument font-bold text-white leading-snug\" data-kid=\"1-5-2-1-1-2-2\" data-name=\"workstation address text\">\n               Shop No.11, Gaurav sankalp chintan 11, hatkesh, Mira Road East, Thane, Maharashtra 401107, IN.\n             </p>\n</div>\n</section>\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"1-5-2-1-2\" data-name=\"direct contact and uptime grid\">\n<section data-kid=\"1-5-2-1-2-1\" data-name=\"direct communication section\">\n<h4 class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-gray-500 uppercase mb-6\" data-kid=\"1-5-2-1-2-1-1\" data-name=\"direct communication header\">Direct Comms</h4>\n<div class=\"space-y-4\" data-kid=\"1-5-2-1-2-1-2\" data-name=\"phone numbers container\">\n<div class=\"flex items-center gap-3\" data-kid=\"1-5-2-1-2-1-2-1\" data-name=\"primary phone container\">\n<span class=\"font-mono text-xs text-red-600\" data-kid=\"1-5-2-1-2-1-2-1-1\" data-name=\"primary phone label\">PRI:</span>\n<p class=\"text-xl font-instrument font-black text-white\" data-kid=\"1-5-2-1-2-1-2-1-2\" data-name=\"primary phone number\">093222 45569</p>\n</div>\n<div class=\"flex items-center gap-3\" data-kid=\"1-5-2-1-2-1-2-2\" data-name=\"secondary phone container\">\n<span class=\"font-mono text-xs text-gray-500\" data-kid=\"1-5-2-1-2-1-2-2-1\" data-name=\"secondary phone label\">SEC:</span>\n<p class=\"text-xl font-instrument font-black text-white\" data-kid=\"1-5-2-1-2-1-2-2-2\" data-name=\"secondary phone number\">090827 44210</p>\n</div>\n</div>\n</section>\n<section data-kid=\"1-5-2-1-2-2\" data-name=\"uptime section\">\n<h4 class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-gray-500 uppercase mb-6\" data-kid=\"1-5-2-1-2-2-1\" data-name=\"uptime header\">Uptime</h4>\n<div class=\"space-y-2\" data-kid=\"1-5-2-1-2-2-2\" data-name=\"uptime details container\">\n<p class=\"text-xl font-instrument font-black text-white\" data-kid=\"1-5-2-1-2-2-2-1\" data-name=\"uptime days text\">Mon - Sun</p>\n<p class=\"text-xl font-instrument font-black text-red-600\" data-kid=\"1-5-2-1-2-2-2-2\" data-name=\"uptime hours text\">9:00 AM – 9:30 PM</p>\n</div>\n</section>\n</div>\n<section class=\"p-10 bg-[#0A0A0A] border border-white/10 relative overflow-hidden group hover-brutalist transition-all duration-400\" data-kid=\"1-5-2-1-3\" data-name=\"financial protocol notice box\">\n<div class=\"absolute -right-8 -bottom-8 opacity-5 group-hover:opacity-10 transition-opacity text-red-600\" data-kid=\"1-5-2-1-3-1\" data-name=\"decorative background icon container\">\n<svg class=\"w-40 h-40\" data-kid=\"1-5-2-1-3-1-1\" data-name=\"warning icon\" fill=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z\" data-kid=\"6\"></path></svg>\n</div>\n<h4 class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-red-600 uppercase mb-4\" data-kid=\"1-5-2-1-3-2\" data-name=\"financial protocol header\">Financial Protocol</h4>\n<h3 class=\"font-instrument text-2xl font-black text-white mb-4 uppercase italic\" data-kid=\"1-5-2-1-3-3\" data-name=\"settlement notice title\">Settlement Notice</h3>\n<p class=\"text-white/60 text-sm leading-relaxed mb-8 font-medium\" data-kid=\"1-5-2-1-3-4\" data-name=\"settlement notice text\">\n            To ensure maximum mechanical throughput and minimized overhead, we utilize direct settlement protocols.\n          </p>\n<div class=\"flex gap-2 mb-8\" data-kid=\"1-5-2-1-3-5\" data-name=\"payment method tags container\">\n<span class=\"px-4 py-1.5 bg-white/5 border border-white/10 rounded-xs text-[10px] font-mono text-white uppercase tracking-tighter\" data-kid=\"1-5-2-1-3-5-1\" data-name=\"payment tag cash\">CASH_FLOW_ENABLED</span>\n<span class=\"px-4 py-1.5 bg-white/5 border border-white/10 rounded-xs text-[10px] font-mono text-white uppercase tracking-tighter\" data-kid=\"1-5-2-1-3-5-2\" data-name=\"payment tag digital\">DIGITAL_UPI_ENABLED</span>\n</div>\n<div class=\"bg-red-600 border-l-8 border-white p-6 shadow-[8px_8px_0_rgba(220,20,60,0.3)]\" data-kid=\"1-5-2-1-3-6\" data-name=\"prohibited payment warning banner\">\n<div class=\"flex items-start gap-4\" data-kid=\"1-5-2-1-3-6-1\" data-name=\"prohibited payment warning container\">\n<svg class=\"w-6 h-6 text-white shrink-0 mt-0.5\" data-kid=\"1-5-2-1-3-6-1-1\" data-name=\"warning icon\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2.5\" data-kid=\"7\"></path></svg>\n<p class=\"font-mono text-[12px] text-white font-black leading-tight uppercase tracking-widest\" data-kid=\"1-5-2-1-3-6-1-2\" data-name=\"warning text\">CRITICAL NOTICE: DEBIT AND CREDIT CARDS ARE STRICTLY PROHIBITED. CASH OR UPI SETTLEMENT ONLY.</p>\n</div>\n</div>\n</section>\n</div>\n\n<div class=\"lg:col-span-7 section-reveal\" data-kid=\"1-5-2-2\" data-name=\"right column dispatch form section\">\n<div class=\"bg-[#0A0A0A] border border-white/10 p-12 md:p-16 relative shadow-2xl\" data-kid=\"1-5-2-2-1\" data-name=\"contact form container\" id=\"form-container\">\n<div class=\"flex justify-between items-start mb-20\" data-kid=\"1-5-2-2-1-1\" data-name=\"form header area\">\n<div data-kid=\"1-5-2-2-1-1-1\" data-name=\"form header text container\">\n<h2 class=\"font-instrument text-5xl font-black italic uppercase text-white mb-2 leading-none\" data-kid=\"1-5-2-2-1-1-1-1\" data-name=\"form title\">Contact Form</h2>\n<p class=\"font-mono text-xs text-red-600 tracking-[0.2em] uppercase\" data-kid=\"1-5-2-2-1-1-1-2\" data-name=\"form version label\">Digital Dispatch System [V5.4]</p>\n</div>\n<div class=\"hidden sm:block w-16 h-16 border border-white/10 flex items-center justify-center\" data-kid=\"1-5-2-2-1-1-2\" data-name=\"form decorative icon container\">\n<div class=\"w-10 h-10 border border-red-600/30 flex items-center justify-center animate-pulse\" data-kid=\"1-5-2-2-1-1-2-1\" data-name=\"form icon container\">\n<svg class=\"w-6 h-6 text-red-600\" data-kid=\"1-5-2-2-1-1-2-1-1\" data-name=\"form icon\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\"><path d=\"M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" data-kid=\"8\"></path></svg>\n</div>\n</div>\n</div>\n<form action=\"#\" class=\"space-y-12\" data-kid=\"1-5-2-2-1-2\" data-name=\"contact form fields\" method=\"POST\">\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"1-5-2-2-1-2-1\" data-name=\"form input row names\">\n<div class=\"space-y-3 group\" data-kid=\"1-5-2-2-1-2-1-1\" data-name=\"form field group full name\">\n<label class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-gray-400 uppercase group-focus-within:text-red-600 transition-colors\" data-kid=\"1-5-2-2-1-2-1-1-1\" data-name=\"form label full name\">Full Name</label>\n<input class=\"w-full bg-transparent border-b border-white/20 py-4 text-white font-instrument text-xl focus:outline-none focus:border-red-600 transition-colors placeholder:text-white/20\" data-kid=\"1-5-2-2-1-2-1-1-2\" data-name=\"form input full name\" placeholder=\"e.g. Rahul Sharma\" required=\"\" type=\"text\">\n</div>\n<div class=\"space-y-3 group\" data-kid=\"1-5-2-2-1-2-1-2\" data-name=\"form field group phone\">\n<label class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-gray-400 uppercase group-focus-within:text-red-600 transition-colors\" data-kid=\"1-5-2-2-1-2-1-2-1\" data-name=\"form label phone\">Phone Number</label>\n<input class=\"w-full bg-transparent border-b border-white/20 py-4 text-white font-instrument text-xl focus:outline-none focus:border-red-600 transition-colors placeholder:text-white/20\" data-kid=\"1-5-2-2-1-2-1-2-2\" data-name=\"form input phone\" placeholder=\"+91 00000 00000\" required=\"\" type=\"tel\">\n</div>\n</div>\n<div class=\"space-y-3 group\" data-kid=\"1-5-2-2-1-2-2\" data-name=\"form field group vehicle model\">\n<label class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-gray-400 uppercase group-focus-within:text-red-600 transition-colors\" data-kid=\"1-5-2-2-1-2-2-1\" data-name=\"form label vehicle model\">Vehicle Model</label>\n<input class=\"w-full bg-transparent border-b border-white/20 py-4 text-white font-instrument text-xl focus:outline-none focus:border-red-600 transition-colors placeholder:text-white/20\" data-kid=\"1-5-2-2-1-2-2-2\" data-name=\"form input vehicle model\" placeholder=\"e.g. Yamaha FZ-S V4 / Honda Activa 6G\" required=\"\" type=\"text\">\n</div>\n<div class=\"space-y-3 group\" data-kid=\"1-5-2-2-1-2-3\" data-name=\"form field group symptoms\">\n<label class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-gray-400 uppercase group-focus-within:text-red-600 transition-colors\" data-kid=\"1-5-2-2-1-2-3-1\" data-name=\"form label symptoms\">Mechanical Symptoms / Service Required</label>\n<textarea class=\"w-full bg-black border border-white/20 p-6 text-white font-inter text-base focus:outline-none focus:border-red-600 transition-colors resize-none placeholder:text-white/20\" data-kid=\"1-5-2-2-1-2-3-2\" data-name=\"form input symptoms\" placeholder=\"Describe the anomalies or service required for diagnostic preparation...\" rows=\"5\"></textarea>\n</div>\n<div class=\"pt-8\" data-kid=\"1-5-2-2-1-2-4\" data-name=\"form submit action container\">\n<button class=\"w-full bg-white text-black font-inter font-black uppercase tracking-[0.3em] text-sm py-8 rounded-full hover:bg-red-600 hover:text-white transition-all duration-500 transform active:scale-[0.98] cursor-pointer\" data-kid=\"1-5-2-2-1-2-4-1\" data-name=\"submit request button\" type=\"submit\">\n                Execute Request Protocol →\n              </button>\n</div>\n<div class=\"flex flex-col items-center gap-4 text-center\" data-kid=\"1-5-2-2-1-2-5\" data-name=\"form footer information\">\n<span class=\"font-mono text-[10px] text-gray-600 tracking-[0.3em] uppercase\" data-kid=\"1-5-2-2-1-2-5-1\" data-name=\"encryption status text\">End-to-End Encryption Enabled | Mira Road Hub Active</span>\n<div class=\"flex gap-1\" data-kid=\"1-5-2-2-1-2-5-2\" data-name=\"connectivity indicator dots\">\n<div class=\"w-1 h-1 bg-red-600\" data-kid=\"1-5-2-2-1-2-5-2-1\" data-name=\"indicator dot active\"></div>\n<div class=\"w-1 h-1 bg-white/20\" data-kid=\"1-5-2-2-1-2-5-2-2\" data-name=\"indicator dot inactive\"></div>\n<div class=\"w-1 h-1 bg-white/20\" data-kid=\"1-5-2-2-1-2-5-2-3\" data-name=\"indicator dot inactive\"></div>\n<div class=\"w-1 h-1 bg-white/20\" data-kid=\"1-5-2-2-1-2-5-2-4\" data-name=\"indicator dot inactive\"></div>\n</div>\n</div>\n</form>\n</div>\n</div>\n</div>\n\n<div class=\"mt-40 border-y border-white/10 py-16 overflow-hidden bg-black/50\" data-kid=\"1-5-3\" data-name=\"marquee banner\">\n<div class=\"flex whitespace-nowrap animate-marquee\" data-kid=\"1-5-3-1\" data-name=\"marquee content wrapper\">\n<div class=\"flex gap-20 items-center px-10\" data-kid=\"1-5-3-1-1\" data-name=\"marquee segment one\">\n<span class=\"text-6xl font-instrument font-black uppercase text-white/15 italic\" data-kid=\"1-5-3-1-1-1\" data-name=\"marquee text\">Mira Road East</span>\n<div class=\"w-4 h-4 bg-red-600 rotate-45\" data-kid=\"1-5-3-1-1-2\" data-name=\"marquee separator\"></div>\n<span class=\"text-6xl font-instrument font-black uppercase text-white/15 italic\" data-kid=\"1-5-3-1-1-3\" data-name=\"marquee text\">Genuine Spares</span>\n<div class=\"w-4 h-4 bg-red-600 rotate-45\" data-kid=\"1-5-3-1-1-4\" data-name=\"marquee separator\"></div>\n<span class=\"text-6xl font-instrument font-black uppercase text-white/15 italic\" data-kid=\"1-5-3-1-1-5\" data-name=\"marquee text\">Precision Tuning</span>\n<div class=\"w-4 h-4 bg-red-600 rotate-45\" data-kid=\"1-5-3-1-1-6\" data-name=\"marquee separator\"></div>\n<span class=\"text-6xl font-instrument font-black uppercase text-white/15 italic\" data-kid=\"1-5-3-1-1-7\" data-name=\"marquee text\">Est. 2009</span>\n<div class=\"w-4 h-4 bg-red-600 rotate-45\" data-kid=\"1-5-3-1-1-8\" data-name=\"marquee separator\"></div>\n</div>\n<div class=\"flex gap-20 items-center px-10\" data-kid=\"1-5-3-1-2\" data-name=\"marquee segment two\">\n<span class=\"text-6xl font-instrument font-black uppercase text-white/15 italic\" data-kid=\"1-5-3-1-2-1\" data-name=\"marquee text\">Mira Road East</span>\n<div class=\"w-4 h-4 bg-red-600 rotate-45\" data-kid=\"1-5-3-1-2-2\" data-name=\"marquee separator\"></div>\n<span class=\"text-6xl font-instrument font-black uppercase text-white/15 italic\" data-kid=\"1-5-3-1-2-3\" data-name=\"marquee text\">Genuine Spares</span>\n<div class=\"w-4 h-4 bg-red-600 rotate-45\" data-kid=\"1-5-3-1-2-4\" data-name=\"marquee separator\"></div>\n<span class=\"text-6xl font-instrument font-black uppercase text-white/15 italic\" data-kid=\"1-5-3-1-2-5\" data-name=\"marquee text\">Precision Tuning</span>\n<div class=\"w-4 h-4 bg-red-600 rotate-45\" data-kid=\"1-5-3-1-2-6\" data-name=\"marquee separator\"></div>\n<span class=\"text-6xl font-instrument font-black uppercase text-white/15 italic\" data-kid=\"1-5-3-1-2-7\" data-name=\"marquee text\">Est. 2009</span>\n<div class=\"w-4 h-4 bg-red-600 rotate-45\" data-kid=\"1-5-3-1-2-8\" data-name=\"marquee separator\"></div>\n</div>\n</div>\n</div>\n</main>\n\n<footer class=\"bg-[#050505] border-t border-white/10 py-24 px-10 relative z-20\" data-kid=\"1-6\" data-name=\"technical footer\">\n<div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-20\" data-kid=\"1-6-1\" data-name=\"footer top section\">\n<div class=\"space-y-10 max-w-sm\" data-kid=\"1-6-1-1\" data-name=\"footer company information\">\n<div class=\"flex items-center gap-3\" data-kid=\"1-6-1-1-1\" data-name=\"footer logo container\">\n<div class=\"w-8 h-8 bg-red-600 flex items-center justify-center rounded-xs\" data-kid=\"1-6-1-1-1-1\" data-name=\"footer logo symbol container\">\n<span class=\"text-white font-instrument font-black text-xs\" data-kid=\"1-6-1-1-1-1-1\" data-name=\"footer logo text\">KA</span>\n</div>\n<span class=\"font-instrument font-black uppercase tracking-widest text-lg text-white\" data-kid=\"1-6-1-1-1-2\" data-name=\"footer company name\">Krishna Automobile</span>\n</div>\n<p class=\"text-base text-white/40 leading-relaxed font-medium\" data-kid=\"1-6-1-1-2\" data-name=\"footer description text\">\n          The ultimate sanctuary for two-wheelers in Mira Road. We combine brutalist mechanical efficiency with surgical repair standards.\n        </p>\n<div class=\"flex gap-6\" data-kid=\"1-6-1-1-3\" data-name=\"footer social media links\">\n<a class=\"w-10 h-10 border border-white/10 flex items-center justify-center text-white/60 hover:text-red-600 hover:border-red-600 transition-all\" data-kid=\"1-6-1-1-3-1\" data-name=\"whatsapp link\" href=\"#\"><i class=\"fab fa-whatsapp\" data-kid=\"1-6-1-1-3-1-1\" data-name=\"whatsapp icon\"></i></a>\n<a class=\"w-10 h-10 border border-white/10 flex items-center justify-center text-white/60 hover:text-red-600 hover:border-red-600 transition-all\" data-kid=\"1-6-1-1-3-2\" data-name=\"instagram link\" href=\"#\"><i class=\"fab fa-instagram\" data-kid=\"1-6-1-1-3-2-1\" data-name=\"instagram icon\"></i></a>\n<a class=\"w-10 h-10 border border-white/10 flex items-center justify-center text-white/60 hover:text-red-600 hover:border-red-600 transition-all\" data-kid=\"1-6-1-1-3-3\" data-name=\"map link\" href=\"#\"><i class=\"fas fa-map-marker-alt\" data-kid=\"1-6-1-1-3-3-1\" data-name=\"map icon\"></i></a>\n</div>\n</div>\n<div class=\"grid grid-cols-2 lg:grid-cols-3 gap-16 md:gap-24\" data-kid=\"1-6-1-2\" data-name=\"footer navigation and info\">\n<div class=\"space-y-8\" data-kid=\"1-6-1-2-1\" data-name=\"footer links protocol section\">\n<h4 class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-white uppercase\" data-kid=\"1-6-1-2-1-1\" data-name=\"footer header\">Protocols</h4>\n<ul class=\"space-y-4 text-sm font-medium text-white/60\" data-kid=\"1-6-1-2-1-2\" data-name=\"footer link list\">\n<li data-kid=\"1-6-1-2-1-2-1\" data-name=\"footer link item\"><a class=\"hover:text-red-600 transition-colors uppercase tracking-widest\" data-kid=\"1-6-1-2-1-2-1-1\" data-name=\"footer link text\" href=\"#\">Home_Unit</a></li>\n<li data-kid=\"1-6-1-2-1-2-2\" data-name=\"footer link item\"><a class=\"hover:text-red-600 transition-colors uppercase tracking-widest\" data-kid=\"1-6-1-2-1-2-2-1\" data-name=\"footer link text\" href=\"#\">Service_Grid</a></li>\n<li data-kid=\"1-6-1-2-1-2-3\" data-name=\"footer link item\"><a class=\"hover:text-red-600 transition-colors uppercase tracking-widest\" data-kid=\"1-6-1-2-1-2-3-1\" data-name=\"footer link text\" href=\"#\">Insurance_Sync</a></li>\n<li data-kid=\"1-6-1-2-1-2-4\" data-name=\"footer link item\"><a class=\"hover:text-red-600 transition-colors uppercase tracking-widest\" data-kid=\"1-6-1-2-1-2-4-1\" data-name=\"footer link text\" href=\"#\">Contact_Hub</a></li>\n</ul>\n</div>\n<div class=\"space-y-8\" data-kid=\"1-6-1-2-2\" data-name=\"footer coordinates section\">\n<h4 class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-white uppercase\" data-kid=\"1-6-1-2-2-1\" data-name=\"footer header\">Coordinates</h4>\n<div class=\"font-mono text-[10px] text-white/50 space-y-4 leading-relaxed uppercase font-bold\" data-kid=\"1-6-1-2-2-2\" data-name=\"coordinates list\">\n<p data-kid=\"1-6-1-2-2-2-1\" data-name=\"latitude text\">LAT: 19.2813° N</p>\n<p data-kid=\"1-6-1-2-2-2-2\" data-name=\"longitude text\">LON: 72.8711° E</p>\n<p data-kid=\"1-6-1-2-2-2-3\" data-name=\"hub text\">HUB: Mira Road E</p>\n<p data-kid=\"1-6-1-2-2-2-4\" data-name=\"zone text\">ZONE: Thane, MH</p>\n</div>\n</div>\n<div class=\"col-span-2 lg:col-span-1 space-y-8\" data-kid=\"1-6-1-2-3\" data-name=\"footer system info section\">\n<h4 class=\"font-inter text-[11px] font-bold tracking-[0.2em] text-white uppercase\" data-kid=\"1-6-1-2-3-1\" data-name=\"footer header\">System_Info</h4>\n<p class=\"font-mono text-[10px] text-white/40 leading-loose uppercase tracking-widest font-bold\" data-kid=\"1-6-1-2-3-2\" data-name=\"system info text\">\n            OS_VER: 5.4.0-STABLE<br data-kid=\"1-6-1-2-3-2-1\" data-name=\"line break\">\n            SEC_LVL: AES-256<br data-kid=\"1-6-1-2-3-2-2\" data-name=\"line break\">\n            DEPLOY: MARCH-2009<br data-kid=\"1-6-1-2-3-2-3\" data-name=\"line break\">\n            LIC: GARAGE_OPERATIONAL_IN\n          </p>\n</div>\n</div>\n</div>\n<div class=\"max-w-7xl mx-auto border-t border-white/5 mt-24 pt-10 flex flex-col sm:flex-row justify-between items-center gap-6\" data-kid=\"1-6-2\" data-name=\"footer bottom section\">\n<span class=\"font-mono text-[11px] text-white/30 tracking-[0.2em] uppercase font-bold\" data-kid=\"1-6-2-1\" data-name=\"copyright text\">© 2024 KRISHNA AUTOMOBILE — ALL RIGHTS RESERVED.</span>\n<span class=\"font-instrument font-black italic text-base text-red-600/40 uppercase tracking-widest\" data-kid=\"1-6-2-2\" data-name=\"footer tagline\">Engineered for Performance</span>\n</div>\n</footer>\n</div>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"9\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"10\"></script>\n<script type=\"module\" data-kid=\"11\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  import Snap from \"https://esm.sh/lenis@1/snap\"\n  \n  const lenis = new Lenis()\n  function raf(time) {\n    lenis.raf(time)\n    requestAnimationFrame(raf)\n  }\n  requestAnimationFrame(raf)\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Entrance animations\n  window.addEventListener('DOMContentLoaded', () => {\n    // Staggered section reveal\n    gsap.utils.toArray('.section-reveal').forEach((section, i) => {\n      gsap.from(section, {\n        opacity: 0,\n        y: 100,\n        duration: 1.2,\n        ease: 'power4.out',\n        scrollTrigger: {\n          trigger: section,\n          start: 'top 85%'\n        }\n      });\n    });\n\n    // Text splitting style animation for hero\n    gsap.from('.animate-text', {\n      y: 150,\n      opacity: 0,\n      skewY: 5,\n      duration: 1.5,\n      ease: 'power4.out',\n      delay: 0.2\n    });\n\n    // Form container special entrance\n    gsap.from('#form-container', {\n      scale: 0.95,\n      opacity: 0,\n      duration: 1.5,\n      ease: 'expo.out',\n      scrollTrigger: {\n        trigger: '#form-container',\n        start: 'top 90%'\n      }\n    });\n\n    // Coordinate parallax\n    gsap.to('.technical-grid-coord', {\n      y: (i, target) => i % 2 === 0 ? 100 : -100,\n      scrollTrigger: {\n        trigger: 'body',\n        start: 'top top',\n        end: 'bottom bottom',\n        scrub: 1\n      }\n    });\n  });\n</script>\n<link data-kid=\"2\" data-name=\"font awesome icons library link\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css\" rel=\"stylesheet\">\n<link data-kid=\"3\" data-name=\"lenis scroll library link\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" rel=\"stylesheet\">\n",
