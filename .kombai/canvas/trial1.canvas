        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Instrument+Sans:wght@400;700;800;900&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    @import url('https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css');\n\n    :root {\n        --crimson: #DC143C;\n        --deep-gray: #050505;\n        --crimson-charcoal: #151010;\n        --alabaster: #E5E4E2;\n    }\n\n    body {\n        margin: 0;\n        background-color: var(--deep-gray);\n        font-family: 'Inter', sans-serif;\n        color: var(--alabaster);\n        overflow-x: clip;\n    }\n\n    .brutalist-border {\n        border: 2px solid rgba(255, 255, 255, 0.15);\n    }\n\n    .hard-shadow:hover {\n        box-shadow: 12px 12px 0 var(--crimson);\n        transform: translate(-8px, -8px);\n    }\n\n    .text-outline {\n        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.05);\n        color: transparent;\n    }\n\n    /* Prevent text selection for watermarks */\n    .no-select {\n        user-select: none;\n        pointer-events: none;\n    }\n\n</style>\n<section class=\"relative min-h-screen bg-[var(--deep-gray)] py-32 px-6 md:px-12 overflow-x-clip flex flex-col items-center\" data-kid=\"1\" data-name=\"social proof section\" id=\"the-riders-word\">\n\n<div class=\"absolute inset-0 z-0 opacity-10 no-select\" data-kid=\"1-1\" data-name=\"gritty background container\">\n<img alt=\"Gritty motorcycle engine\" class=\"w-full h-full object-cover\" data-kid=\"1-1-1\" data-name=\"motorcycle engine image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1776344947913-d1d5f3712828?auto=format&amp;w=1600&amp;q=80&amp;fit=crop\">\n<div class=\"absolute inset-0 bg-gradient-to-b from-[var(--deep-gray)] via-transparent to-[var(--deep-gray)]\" data-kid=\"1-1-2\" data-name=\"background gradient overlay\"></div>\n</div>\n\n<div class=\"absolute top-[20%] left-0 w-full no-select overflow-hidden z-0 pointer-events-none flex whitespace-nowrap garage-watermark\" data-kid=\"1-2\" data-name=\"oversized text watermark container\">\n<div class=\"text-[12vw] font-black uppercase tracking-tighter leading-none opacity-[0.03] text-white pr-20\" data-kid=\"1-2-1\" data-name=\"repeated typography watermark\">\n            WORD ON THE STREET • WORD ON THE STREET • WORD ON THE STREET\n        </div>\n</div>\n<div class=\"relative z-10 w-full max-w-7xl\" data-kid=\"1-3\" data-name=\"content wrapper\">\n\n<div class=\"mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8\" data-kid=\"1-3-1\" data-name=\"section header container\">\n<div class=\"max-w-3xl\" data-kid=\"1-3-1-1\" data-name=\"headline group\">\n<span class=\"text-[var(--crimson)] font-black text-xs uppercase tracking-[0.5em] block mb-4\" data-kid=\"1-3-1-1-1\" data-name=\"social proof label\">Social Proof</span>\n<h2 class=\"text-6xl md:text-[9rem] font-black font-['Instrument_Sans'] uppercase tracking-tighter leading-[0.85] text-white\" data-kid=\"1-3-1-1-2\" data-name=\"main section headline\">\n                    THE RIDER'S <br data-kid=\"1-3-1-1-2-1\" data-name=\"headline line break\"><span class=\"text-[var(--crimson)]\" data-kid=\"1-3-1-1-2-2\" data-name=\"highlighted word\">WORD.</span>\n</h2>\n</div>\n<div class=\"md:text-right\" data-kid=\"1-3-1-2\" data-name=\"description container\">\n<p class=\"text-white/40 font-bold uppercase text-[10px] tracking-[0.3em] leading-loose max-w-[200px] ml-auto\" data-kid=\"1-3-1-2-1\" data-name=\"short description text\">\n                    A wall of praise straight from the garage floor.\n                </p>\n</div>\n</div>\n\n<div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 items-start\" data-kid=\"1-3-2\" data-name=\"masonry grid container\">\n\n<div class=\"flex flex-col gap-8 md:gap-12\" data-kid=\"1-3-2-1\" data-name=\"parallax column one\" data-scroll=\"\" data-scroll-speed=\"0.1\" id=\"col-1\">\n<div class=\"bg-[var(--crimson-charcoal)] p-8 md:p-10 brutalist-border hard-shadow relative garage-card group\" data-kid=\"1-3-2-1-1\" data-name=\"testimonial card one\">\n<p class=\"text-xl md:text-2xl font-black mb-8 leading-tight italic text-white\" data-kid=\"1-3-2-1-1-1\" data-name=\"testimonial text one\">\n                        \"Great experience! Fixed my scooty perfectly. Fast service, fair price.\"\n                    </p>\n<div class=\"flex flex-col gap-0\" data-kid=\"1-3-2-1-1-2\" data-name=\"author identity block\">\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--crimson)]\" data-kid=\"1-3-2-1-1-2-1\" data-name=\"author name\">Sahil Raj</span>\n<span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"1-3-2-1-1-2-2\" data-name=\"author role\">Local Guide</span>\n</div>\n</div>\n<div class=\"bg-[var(--crimson-charcoal)] p-8 md:p-10 brutalist-border hard-shadow relative garage-card group border-l-4 border-l-[var(--crimson)]\" data-kid=\"1-3-2-1-2\" data-name=\"testimonial card two\">\n<div class=\"flex items-center gap-2 mb-6 text-[var(--crimson)]\" data-kid=\"1-3-2-1-2-1\" data-name=\"specialist label container\">\n<i class=\"ti ti-bolt text-2xl\" data-kid=\"1-3-2-1-2-1-1\" data-name=\"lightning bolt icon\"></i>\n<span class=\"text-xs font-black uppercase tracking-widest\" data-kid=\"1-3-2-1-2-1-2\" data-name=\"specialist title\">OLA / EV SPECIALIST</span>\n</div>\n<p class=\"text-lg leading-relaxed mb-10 text-[var(--alabaster)]/80\" data-kid=\"1-3-2-1-2-2\" data-name=\"testimonial text two\">\n                        \"Ola repairing centre, electric charging system resolve. Finally found someone who understands EV electronics in this area. Highly recommended for EV owners.\"\n                    </p>\n<div class=\"flex flex-col gap-0\" data-kid=\"1-3-2-1-2-3\" data-name=\"author identity block\">\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--crimson)]\" data-kid=\"1-3-2-1-2-3-1\" data-name=\"author name\">Asif Sayyed</span>\n<span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"1-3-2-1-2-3-2\" data-name=\"author role\">EV Enthusiast</span>\n</div>\n</div>\n</div>\n\n<div class=\"flex flex-col gap-8 md:gap-12 md:pt-32\" data-kid=\"1-3-2-2\" data-name=\"parallax column two\" data-scroll=\"\" data-scroll-speed=\"-0.1\" id=\"col-2\">\n<div class=\"bg-[var(--crimson-charcoal)] p-8 md:p-10 brutalist-border hard-shadow relative garage-card group\" data-kid=\"1-3-2-2-1\" data-name=\"testimonial card three\">\n<p class=\"text-lg leading-relaxed mb-10 text-[var(--alabaster)]/80\" data-kid=\"1-3-2-2-1-1\" data-name=\"testimonial text three\">\n                        \"I have gone everywhere but there is no electric scooty service. But they are very skilled. They fixed my Ola S1 Pro battery issue which even the official center was struggling with. Master hands at work!\"\n                    </p>\n<div class=\"flex flex-col gap-0\" data-kid=\"1-3-2-2-1-2\" data-name=\"author identity block\">\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--crimson)]\" data-kid=\"1-3-2-2-1-2-1\" data-name=\"author name\">Rahul Kumar</span>\n<span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"1-3-2-2-1-2-2\" data-name=\"author role\">Daily Commuter</span>\n</div>\n</div>\n<div class=\"bg-[var(--crimson)] p-12 brutalist-border flex flex-col items-start justify-center relative overflow-hidden garage-card group hover:shadow-[12px 12px 0 white] hover:-translate-y-2\" data-kid=\"1-3-2-2-2\" data-name=\"trust score card\">\n<span class=\"text-[10px] font-black text-black uppercase tracking-[0.4em] mb-6\" data-kid=\"1-3-2-2-2-1\" data-name=\"trust score label\">UNSTOPPABLE TRUST</span>\n<div class=\"flex items-end gap-2 mb-4\" data-kid=\"1-3-2-2-2-2\" data-name=\"rating group\">\n<h3 class=\"text-9xl font-black text-black leading-none tracking-tighter\" data-kid=\"1-3-2-2-2-2-1\" data-name=\"rating number text\">4.8</h3>\n<span class=\"text-2xl font-black text-black mb-3\" data-kid=\"1-3-2-2-2-2-2\" data-name=\"rating scale text\">/ 5.0</span>\n</div>\n<div class=\"h-1 w-full bg-black/20 mb-6\" data-kid=\"1-3-2-2-2-3\" data-name=\"progress bar container\">\n<div class=\"h-full bg-black w-[96%]\" data-kid=\"1-3-2-2-2-3-1\" data-name=\"progress bar fill\"></div>\n</div>\n<span class=\"text-xs font-black text-black uppercase tracking-widest opacity-60\" data-kid=\"1-3-2-2-2-4\" data-name=\"review source label\">Verified Google Garage Reviews</span>\n</div>\n</div>\n\n<div class=\"flex flex-col gap-8 md:gap-12 md:pt-16\" data-kid=\"1-3-2-3\" data-name=\"parallax column three\" data-scroll=\"\" data-scroll-speed=\"0.2\" id=\"col-3\">\n<div class=\"bg-[var(--crimson-charcoal)] p-8 md:p-10 brutalist-border hard-shadow relative garage-card group\" data-kid=\"1-3-2-3-1\" data-name=\"testimonial card four\">\n<p class=\"text-xl md:text-2xl font-black mb-8 leading-tight italic text-white\" data-kid=\"1-3-2-3-1-1\" data-name=\"testimonial text four\">\n                        \"Excellent bike repair garage! Very skilled mechanics who know their way around high-performance engines.\"\n                    </p>\n<div class=\"flex flex-col gap-0\" data-kid=\"1-3-2-3-1-2\" data-name=\"author identity block\">\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--crimson)]\" data-kid=\"1-3-2-3-1-2-1\" data-name=\"author name\">Mohit Sharma</span>\n<span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"1-3-2-3-1-2-2\" data-name=\"author role\">Pulsar NS200</span>\n</div>\n</div>\n<div class=\"bg-[var(--crimson-charcoal)] p-8 md:p-10 brutalist-border hard-shadow relative garage-card group\" data-kid=\"1-3-2-3-2\" data-name=\"testimonial card five\">\n<p class=\"text-lg leading-relaxed mb-10 text-[var(--alabaster)]/80\" data-kid=\"1-3-2-3-2-1\" data-name=\"testimonial text five\">\n                        \"Very good service for my hunter 350. The tuning is perfect now, feels like a new machine. The clutch and gear shifts are much smoother. Genuine mechanical skill.\"\n                    </p>\n<div class=\"flex flex-col gap-0\" data-kid=\"1-3-2-3-2-2\" data-name=\"author identity block\">\n<span class=\"text-sm font-black uppercase tracking-widest text-[var(--crimson)]\" data-kid=\"1-3-2-3-2-2-1\" data-name=\"author name\">Vikram Singh</span>\n<span class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"1-3-2-3-2-2-2\" data-name=\"author role\">Royal Enfield Owner</span>\n</div>\n</div>\n<div class=\"aspect-square w-full brutalist-border overflow-hidden grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all duration-700 no-select\" data-kid=\"1-3-2-3-3\" data-name=\"mechanic image container\">\n<img alt=\"Mechanic work\" class=\"w-full h-full object-cover scale-110 hover:scale-100 transition-transform duration-700\" data-kid=\"1-3-2-3-3-1\" data-name=\"mechanic photo\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/11890963/pexels-photo-11890963.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"3\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"4\"></script>\n<script data-kid=\"5\">\n    // Initialize Locomotive Scroll v5\n    const locomotiveScroll = new LocomotiveScroll();\n\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Animation for entries - target specific cards without transitions\n    gsap.from(\".garage-card\", {\n        opacity: 0,\n        y: 80,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power3.out\",\n        scrollTrigger: {\n            trigger: \"#the-riders-word\",\n            start: \"top 85%\",\n            once: true\n        }\n    });\n\n    // Parallax for watermark\n    gsap.to(\".garage-watermark\", {\n        xPercent: -20,\n        ease: \"none\",\n        scrollTrigger: {\n            trigger: \"#the-riders-word\",\n            start: \"top bottom\",\n            end: \"bottom top\",\n            scrub: true\n        }\n    });\n</script>\n",
      "comments": [],
      "created": "2026-07-12T02:03:18.747454+00:00",
      "modified": "2026-07-12T02:03:18.747454+00:00",
